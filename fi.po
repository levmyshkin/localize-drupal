msgstr "Ota lomakkeen jakaminen käyttöön"

msgid "Enable form sharing for webform nodes"
msgstr "Ota lomakkeen jakaminen käyttöön webform-solmuissa"

msgid "Shared form theme"
msgstr "Jaettu lomaketeema"

