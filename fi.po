msgstr "Webform-näkymien integraatio"

msgid "D8 Webform and Webform Views Integration @ Drupalcamp Colorado"
msgstr "D8 Webform ja Webform Views -integraatio @ Drupalcamp Colorado"

msgid "RateIt is used to provide a customizable rating element."
msgstr "RateItia käytetään tarjoamaan muokattava arvosteluosa."

msgid "more submission views"
msgstr "enemmän lähetysten näkymiä"

msgid ""
"A webform submission embed display. The selected view should also "
"include contextual filters. "
"{webform_id}/{source_entity_type}/{source_entity_id}/{account_id}/{in_draft}"
msgstr ""
"Verkkolomakkeen lähetyksen upotettu näyttö. Valitun näkymän "
"tulisi myös sisältää kontekstuaaliset suodattimet. "
"{webform_id}/{source_entity_type}/{source_entity_id}/{account_id}/{in_draft}"

msgid ""
"The name to be displayed in the URL when there are multiple submission "
"views available."
msgstr ""
"Nimi, joka näytetään URL-osoitteessa, kun saatavilla on useita "
"lähetys-näkymiä."

