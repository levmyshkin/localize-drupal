msgstr "Drupal @version moduulin nimi"

msgid "Drupal @version machine name"
msgstr "Drupal @version koneen nimi"

msgid "The human-readable name of the mapping"
msgstr "Kartoituksen ihmisen luettava nimi"

msgid "The machine name of the mapping"
msgstr "Kartoituksen koneellinen nimi"

msgid "The group this mapping belongs to"
msgstr "Ryhmä, johon tämä kartoitus kuuluu"

