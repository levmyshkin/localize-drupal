msgstr ""
"Ratkaistiin polku %path tietokannassa. Tarkista ohitettujen lista ja "
"tallenna asetukset."

msgid "Undefined @langcode"
msgstr "Määrittelemätön @langcode"

msgid "There are no 404 errors to fix."
msgstr "Korjattavia 404-virheitä ei ole."

