msgstr ""
"Ten screencast przedstawia przegląd sposobu wykorzystania wariantów "
"webform do tworzenia testów A/B, segmentacji odbiorców oraz "
"personalizacji."

msgid ""
"Webform module now supports variants, which can be used for A/B tests, "
"segmentation, and personalization"
msgstr ""
"Moduł Webform obsługuje teraz warianty, które można wykorzystać "
"do testów A/B, segmentacji i personalizacji."

msgid "Configuration: Variants"
msgstr "Konfiguracja: warianty"

msgid ""
"The <strong>Variants configuration</strong> page allows administrators "
"to enable/disable variants."
msgstr ""
"Strona <strong>Konfiguracja wariantów</strong> umożliwia "
"administratorom włączanie i wyłączanie wariantów."

msgid ""
"<strong>Variants</strong> are used for A/B testing, segmentation, and "
"personalization."
msgstr ""
"<strong>Warianty</strong> są używane do testów A/B, segmentacji "
"oraz personalizacji."

msgid "Plugins: Variants"
msgstr "Wtyczki: warianty"

msgid ""
"The <strong>Variants</strong> page allows variations of a webform to "
"be created and managed for A/B testing, segmentation, and "
"personalization."
msgstr ""
"Strona <strong>Warianty</strong> umożliwia tworzenie i zarządzanie "
"wariantami formularza internetowego na potrzeby testów A/B, "
"segmentacji i personalizacji."

msgid "@total variants"
msgstr "@total wariantów"

msgid "variants"
msgstr "warianty"

msgid "No variant available."
msgstr "Brak dostępnego wariantu."

msgid "Enter @none to hide this message."
msgstr "Wpisz @none, aby ukryć ten komunikat."

msgid "Apply variants?"
msgstr "Zastosować warianty?"

msgid "Delete the selected variants"
msgstr "Usuń wybrane warianty"

msgid "Delete all variants"
msgstr "Usuń wszystkie warianty"

msgid "Do not delete any variants"
msgstr "Nie usuwaj żadnych wariantów"

msgid "Please select variants to be applied to the webform."
msgstr ""
"Proszę wybrać warianty, które mają zostać zastosowane do "
"formularza internetowego."

msgid "The selected webform variants have been applied and deleted."
msgstr "Wybrane warianty webformularza zostały zastosowane i usunięte."

msgid "The webform variant %title has been applied and deleted."
msgstr ""
"Wariant formularza internetowego %title został zastosowany i "
"usunięty."

msgid ""
"The selected webform variants have been applied and all variants have "
"been deleted."
msgstr ""
"Wybrane warianty webform zostały zastosowane, a wszystkie warianty "
"zostały usunięte."

msgid ""
"The webform variant %title has been applied and all variants have been "
"deleted."
msgstr ""
"Wariant formularza internetowego %title został zastosowany, a "
"wszystkie warianty zostały usunięte."

msgid "The selected webform variants have been applied."
msgstr "Wybrane warianty formularza zostały zastosowane."

msgid "The webform variant %title has been applied."
msgstr "Wariant webformu %title został zastosowany."

msgid "The webform variant %name has been deleted."
msgstr "Wariant formularza internetowego %name został usunięty."

msgid "Edit @label variant"
msgstr "Edytuj wariant @label"

msgid "The webform variant was successfully added."
msgstr "Wariant formularza internetowego został pomyślnie dodany."

msgid "The webform variant was successfully updated."
msgstr "Wariant webformularza został pomyślnie zaktualizowany."

msgid ""
"Select variants and then click submit, which will redirect you to the "
"@operation form."
msgstr ""
"Wybierz warianty, a następnie kliknij „Wyślij”. Zostaniesz "
"przekierowany(-a) do formularza @operation."

msgid "Filter webforms default category"
msgstr "Domyślna kategoria formularzy internetowych"

msgid ""
"Select the filter webforms default category selected on the <a "
"href=\":href\">webform overview page</a>."
msgstr ""
"Wybierz domyślną kategorię webformularzy zaznaczoną w filtrze na "
"<a href=\":href\">stronie przeglądu webformularzy</a>."

msgid "Filter webforms default state"
msgstr "Domyślny stan filtrowania formularzy Webform"

msgid ""
"Select the filter webforms default state selected on the <a "
"href=\":href\">webform overview page</a>."
msgstr ""
"Wybierz domyślnie zaznaczony stan filtrów formularzy na stronie <a "
"href=\":href\">przeglądu formularzy</a>."

msgid "Form URL path settings"
msgstr "Ustawienia ścieżki URL formularza"

msgid "Select available variants"
msgstr "Wybierz dostępne warianty"

msgid "All excluded variants must be manually removed from existing webforms."
msgstr ""
"Wszystkie wykluczone warianty muszą zostać ręcznie usunięte z "
"istniejących webform."

msgid "Allow element to be populated using query string parameters."
msgstr ""
"Umożliwia wypełnianie elementu przy użyciu parametrów "
"przekazywanych w ciągu zapytania (query string)."

msgid ""
"Note that the CAPTCHA module disables page caching of pages that "
"include a CAPTCHA challenge."
msgstr ""
"Zwróć uwagę, że moduł CAPTCHA wyłącza buforowanie stron "
"zawierających wyzwanie CAPTCHA."

msgid ""
"This is used after a submission has been saved and finalized to the "
"database."
msgstr ""
"Jest to używane po zapisaniu i ostatecznym zatwierdzeniu zgłoszenia "
"w bazie danych."

msgid "Provides a form element for enabling and tracking webform variants."
msgstr ""
"Udostępnia element formularza umożliwiający włączanie i "
"śledzenie wariantów webformularza."

msgid ""
"<strong>ATTENTION DEVELOPERS!!!</strong> Please make sure to download "
"and update the <a href=\":href\">Input Mask</a> library to version "
"5.0.x"
msgstr ""
"<strong>UWAGA, DEWELOPERZY!!!</strong> Upewnijcie się, że "
"pobraliście i zaktualizowaliście bibliotekę <a href=\":href\">Input "
"Mask</a> do wersji 5.0.x"

msgid ""
"<a href=\":href\">Learn more about updating the Webform module's "
"external libraries</a>"
msgstr ""
"<a href=\":href\">Dowiedz się więcej o aktualizowaniu zewnętrznych "
"bibliotek modułu Webform</a>"

msgid ""
"Learn more about <a "
"href=\"https://www.drupal.org/docs/8/api/form-api\">Form API in Drupal "
"8</a>."
msgstr ""
"Dowiedz się więcej o <a "
"href=\"https://www.drupal.org/docs/8/api/form-api\">Form API w Drupal "
"8</a>."

msgid "Do not schedule email if the action should be triggered in the past"
msgstr ""
"Nie planuj wysyłki e-maila, jeśli akcja ma zostać uruchomiona w "
"przeszłości"

msgid "Given name on card"
msgstr "Imię na karcie"

msgid "Card expiry month"
msgstr "Miesiąc ważności karty"

msgid "Card expiry year"
msgstr "Rok ważności karty"

msgid "Transaction currency"
msgstr "Waluta transakcji"

