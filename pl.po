msgid "noindex - Prevents search engines from indexing this page."
msgstr "noindex – Uniemożliwia wyszukiwarkom indeksowanie tej strony."

msgid "nofollow - Prevents search engines from following links on this page."
msgstr ""
"nofollow – uniemożliwia wyszukiwarkom podążanie za linkami na tej "
"stronie."

msgid ""
"noarchive - Prevents cached copies of this page from appearing in "
"search results."
msgstr ""
"noarchive – zapobiega wyświetlaniu w wynikach wyszukiwania "
"zbuforowanych (cache) kopii tej strony."

msgid ""
"nosnippet - Prevents descriptions from appearing in search results, "
"and prevents page caching."
msgstr ""
"nosnippet – Uniemożliwia wyświetlanie opisów w wynikach "
"wyszukiwania oraz zapobiega buforowaniu strony."

msgid ""
"noimageindex - Prevent search engines from indexing images on this "
"page."
msgstr ""
"noimageindex – Uniemożliwia wyszukiwarkom indeksowanie obrazów na "
"tej stronie."

msgid ""
"notranslate - Prevent search engines from offering to translate this "
"page in search results."
msgstr ""
