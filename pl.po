msgid ""
"The following webform sub-modules have been deprecated: @module_list. "
"Please download the <a href=\":url\">Webform Deprecated</a> project."
msgstr ""
"Następujące podmoduły Webform zostały wycofane (deprecated): "
"@module_list. Pobierz projekt <a href=\":url\">Webform Deprecated</a>."

msgid ""
"@element_file_limit limit per file. The accumulated size of all files "
"in this form cannot exceed @webform_file_limit."
msgstr ""
"Limit @element_file_limit na plik. Łączny rozmiar wszystkich plików "
"w tym formularzu nie może przekroczyć @webform_file_limit."

