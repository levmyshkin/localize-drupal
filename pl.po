msgid "Extension is available"
msgstr "Rozszerzenie jest dostępne"

msgid "Module '@name' is not available."
msgstr "Moduł „@name” jest niedostępny."

msgid "Theme '@name' is not available."
msgstr "Motyw „@name” nie jest dostępny."

msgid "Profile '@name' is not available."
msgstr "Profil „@name” nie jest dostępny."

