msgstr "Nie znaleziono wyszukiwarek obsługujących przesyłanie mapy witryny."

msgid "Sitemap submission is disabled."
msgstr "Przesyłanie mapy witryny jest wyłączone."

msgid ""
"The last IndexNow submission was <em>@entity</em> to @engine_label on "
"@time"
msgstr ""
"Ostatnie zgłoszenie do IndexNow: <em>@entity</em> do @engine_label "
"dnia @time"

msgid "IndexNow settings can be configured <a href=\"@url\">here</a>."
msgstr "Ustawienia IndexNow można skonfigurować <a href=\"@url\">tutaj</a>."

msgid "No search engines supporting IndexNow have been found."
msgstr "Nie znaleziono żadnych wyszukiwarek obsługujących IndexNow."

msgid "IndexNow submission is disabled."
msgstr "Zgłaszanie do IndexNow jest wyłączone."

msgid "Notify IndexNow search engines of changes <em>by default</em>"
msgstr "Powiadamiaj wyszukiwarki IndexNow o zmianach <em>domyślnie</em>"

msgid "Notify IndexNow search engines of changes <em>now</em>"
msgstr ""
"Powiadom wyszukiwarki obsługujące IndexNow o zmianach <em>już "
