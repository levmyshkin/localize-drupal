msgstr "Umożliwia przełączenie mobilnego menu na całą szerokość."

msgid "Configuring a previously-placed block"
msgstr "Konfigurowanie wcześniej umieszczonego bloku"

msgid "Managing blocks"
msgstr "Zarządzanie blokami"

msgid "Placing a block"
msgstr "Umieszczanie bloku"

msgid "Managing height, width, and resolution breakpoints"
msgstr ""
"Zarządzanie progami breakpointów dla wysokości, szerokości i "
"rozdzielczości"

msgid "Managing the fields of contact forms"
msgstr "Zarządzanie polami formularzy kontaktowych"

msgid "Configuring personal contact forms"
msgstr "Konfigurowanie osobistych formularzy kontaktowych"

msgid "Creating a new contact form"
msgstr "Tworzenie nowego formularza kontaktowego"

msgid "Managing contact forms"
msgstr "Zarządzanie formularzami kontaktowymi"

msgid "Setting a default contact form"
msgstr "Ustawianie domyślnego formularza kontaktowego"

msgid "Using contextual links"
msgstr "Korzystanie z linków kontekstowych"

msgid "Changing the appearance of your site"
msgstr "Zmiana wyglądu Twojej witryny"

msgid "Managing content structure"
msgstr "Zarządzanie strukturą treści"

msgid "Running and configuring cron"
msgstr "Uruchamianie i konfigurowanie crona"

msgid "Extending and modifying your site functionality"
msgstr "Rozszerzanie i modyfikowanie funkcjonalności Twojej witryny"

msgid "Maintaining and troubleshooting your site"
msgstr "Utrzymanie i rozwiązywanie problemów z Twoją witryną"

