msgstr ""
"Példa webűrlapokat biztosít az akadálymentesség áttekintéséhez "
"és teszteléséhez."

msgid "This @label handler was @op."
msgstr "Ez a(z) @label kezelő @op lett."

msgid "Webform Accessibility"
msgstr "Webűrlap akadálymentessége"

msgid "Drupal 8 Accessibility"
msgstr "Drupal 8 akadálymentesség"

msgid ""
"Progress tracking allows analytic software to capture a multi-step "
