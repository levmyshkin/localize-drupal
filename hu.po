msgid "CKEditor 5 toolbar item dependency"
msgstr "A CKEditor 5 eszköztár-elem függősége"

msgid "Depends on %toolbar_item, which is not enabled."
msgstr "A(z) %toolbar_item modultól függ, amely nincs engedélyezve."

msgid ""
"Move a button into the <em>Active toolbar</em> to enable it, or into "
"the list of <em>Available buttons</em> to disable it. Buttons may be "
"moved with the mouse or keyboard arrow keys."
msgstr ""
"Egy gomb engedélyezéséhez helyezze át az <em>Aktív "
"eszköztár</em> területre, letiltásához pedig az <em>Elérhető "
"gombok</em> listájába. A gombok áthelyezhetők egérrel vagy a "
"billentyűzet nyílbillentyűivel."

