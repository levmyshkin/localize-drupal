msgid "Decide to prefetch aliases"
msgstr "Aliasok előtöltésének eldöntése"

msgid "Set chunk size"
msgstr "Darabméret beállítása"

msgid "Set batch limit"
msgstr "Kötegelt feldolgozási limit beállítása"

msgid "Path of the XML generated files"
msgstr "Az XML által generált fájlok elérési útja"

msgid "Priority of the frontpage"
msgstr "A címlap prioritása"

msgid "Change frequency for frontpage"
msgstr "Kezdőlap frissítési gyakorisága"

