msgstr "Mentés + Elem hozzáadása"

msgid "Webform access controls"
msgstr "Webűrlap-hozzáférés-vezérlők"

msgid "Access Control | Tag1 Consulting"
msgstr "Hozzáférés-vezérlés | Tag1 Consulting"

msgid "Opening webforms in modal dialogs"
msgstr "Webűrlapok megnyitása modális párbeszédablakokban"

