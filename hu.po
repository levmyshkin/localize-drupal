"    three:  Three -- This "
"is the number 3.\n"
""
msgstr ""
"states:\n"
"  '#type': 'webform_options_custom:us_states'\n"
"  '#title': "
"'Amerikai államok'\n"
"  '#required': true\n"
"button:\n"
"  '#type': "
"'webform_options_custom:buttons'\n"
"  '#title': 'Gombok'\n"
