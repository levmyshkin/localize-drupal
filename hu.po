msgid_plural "Installed %module modules."
msgstr[0] "Telepítve: %module modul."
msgstr[1] "Telepítve: %module modulok."

msgid "Set property of a config entity"
msgstr "Konfigurációs entitás tulajdonságának beállítása"

msgid "This value is not a valid extension name."
msgstr "Ez az érték nem érvényes bővítménynév."

msgid "Menu link depth"
msgstr "Menühivatkozás mélysége"

msgid "Preprocess callback is not valid: %error."
msgstr "Az előfeldolgozó visszahívás érvénytelen: %error."

