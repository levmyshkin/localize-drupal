"%label elemben hivatkozott, hiányzó @target_type %missing_id "
"azonosítójú hivatkozást, mert a hivatkozott @target_type nem "
"létezik."

msgid "View @entity_label"
msgstr "@entity_label megjelenítése"

msgid "View @entity_bundle @entity_id"
msgstr "Nézet: @entity_bundle @entity_id"

msgid "Maintenance mode enabled."
msgstr "Karbantartási mód engedélyezve."

