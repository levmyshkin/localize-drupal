"@form: The '@type' email address (@email) for '@handler' handler is "
"not valid."
msgstr ""
"@form: A(z) „@handler” kezelőhöz megadott „@type” "
"e-mail-cím (@email) érvénytelen."

msgid ""
"@form: Email not sent for @handler handler because a To, CC, or BCC "
"email was not provided"
msgstr ""
"@form: Az e-mail nem lett elküldve a(z) @handler kezelőhöz, mert "
"nem volt megadva Címzett, Másolat (CC) vagy Titkos másolat (BCC) "
"e-mail-cím."

msgid "Webform jQuery UI Datepicker module not installed."
msgstr "A Webform jQuery UI Datepicker modul nincs telepítve."

msgid ""
"The Webform jQuery UI Datepicker module is required to support "
"datepickers. Disable this datepicker warning by <a "
"href=\":href\">removing #datepicker property from all webforms</a>."
msgstr ""
"A Webform jQuery UI Datepicker modul szükséges a dátumválasztók "
"támogatásához. Tiltsa le ezt a dátumválasztó figyelmeztetést "
"azzal, hogy <a href=\":href\">eltávolítja a #datepicker "
"tulajdonságot az összes webűrlapról</a>."

msgid "The source entity type."
msgstr "A forrás entitástípus."

msgid ""
"If checked, the preview page/card will include 'Edit' buttons for each "
"previous page/card."
msgstr ""
