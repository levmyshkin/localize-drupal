msgstr "@label (Felhasználók, egyéni e-mail-címek, adminisztrátorok)"

msgid ""
"If you enjoy and value Drupal and the Webform module consider <a "
"href=\":href_involved\">getting involved in the Drupal community</a>, "
"<a href=\":href_join\">joining the Drupal Association</a>, and <a "
"href=\":href_opencollective\">contributing funds to the Webform "
"module's Open Collective</a>."
msgstr ""
"Ha szereted és fontosnak tartod a Drupalt és a Webform modult, "
"fontold meg, hogy <a href=\":href_involved\">bekapcsolódsz a Drupal "
"közösségébe</a>, <a href=\":href_join\">csatlakozol a Drupal "
"Associationhöz</a>, és <a href=\":href_opencollective\">anyagi "
"támogatással hozzájárulsz a Webform modul Open Collective "
"oldalán</a>."

msgid "This behavior is not supported when Ajax is enabled."
msgstr "Ez a viselkedés nem támogatott, ha az Ajax engedélyezve van."

