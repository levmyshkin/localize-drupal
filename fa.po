"If checked, all rows and elements within the table will be prefixed "
"with the table's element key and a  incremented numeric value. (i.e. "
"table_01_first_name)"
msgstr ""
"اگر این گزینه انتخاب شود، همهٔ "
"ردیف‌ها و عناصر داخل جدول با کلید "
"عنصرِ جدول و یک مقدار عددی افزایشی "
"پیشوندگذاری می‌شوند. (مثلاً "
"table_01_first_name)"

