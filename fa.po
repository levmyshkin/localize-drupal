"stylesheets[all][] = mycolorbox/colorbox_mycolorbox.css</br>scripts[] "
"= mycolorbox/colorbox_mycolorbox.js"
msgstr ""
"stylesheets[all][] = mycolorbox/colorbox_mycolorbox.css</br>scripts[] "
"= mycolorbox/colorbox_mycolorbox.js"

