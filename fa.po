msgstr "تنظیم «%name» نام معتبری برای تنظیم نیست."

msgid "Element %key is not a valid element key."
msgstr "عنصر %key یک کلید معتبر برای عنصر نیست."

msgid "Handler %id is not a valid handler id."
msgstr ""
"مدیریت‌کنندهٔ %id یک شناسهٔ معتبر برای "
