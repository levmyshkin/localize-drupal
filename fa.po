msgstr "تاریخ/زمان رویداد"

msgid "Maximum number of registrants"
msgstr "حداکثر تعداد ثبت‌نام‌کنندگان"

msgid "Demo: Event Registration"
msgstr "دمو: ثبت‌نام رویداد"

msgid "A demonstration of an event registration form."
msgstr ""
"یک نمونهٔ نمایشی از فرم ثبت‌نام "
"رویداد."

msgid "Demo: Region Contact"
msgstr "دمو: تماس با منطقه"

msgid "A demonstration of a region based contact form."
msgstr ""
"یک نمونهٔ نمایشی از فرم تماس مبتنی بر "
"ناحیه."

msgid "Employee: Email"
msgstr "کارمند: ایمیل"

msgid "Demo: Region Contact: Employee"
msgstr "دمو: تماس ناحیه: کارمند"

msgid "Manager: Email"
msgstr "مدیر: ایمیل"

msgid "Demo: Region Contact: Manager"
msgstr "دمو: تماس منطقه: مدیر"

msgid "This email is sent to managers."
msgstr "این ایمیل برای مدیران ارسال شده است."

msgid "Everyone: Email"
msgstr "Everyone: ایمیل"

msgid "Demo: Region Contact: Everyone"
msgstr "دمو: تماس با ناحیه: همه"

