msgstr "تنظیم اندازهٔ بخش"

msgid "Set batch limit"
msgstr "تنظیم محدودیت دسته‌ای"

msgid "Path of the XML generated files"
msgstr "مسیر فایل‌های تولیدشدهٔ XML"

msgid "Priority of the frontpage"
msgstr "اولویتِ صفحهٔ اصلی"

msgid "Change frequency for frontpage"
msgstr ""
"تغییر تناوب به‌روزرسانی برای صفحهٔ "
"اصلی"

msgid "Gz"
msgstr "Gz"

