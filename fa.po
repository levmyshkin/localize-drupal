msgstr "فعال شده"

msgid "Pre-content"
msgstr "پیش‌محتوا"

msgid "Active menu trail"
msgstr "مسیر فعال منو"

msgid "Configuration updates"
msgstr "به‌روزرسانی‌های پیکربندی"

msgid "The listed configuration will be updated."
msgstr ""
"پیکربندی‌های فهرست‌شده به‌روزرسانی "
"خواهند شد."

msgid "An entity field containing a password value."
msgstr ""
"یک فیلد موجودیت که حاوی مقدار گذرواژه "
