msgstr ""
"بررسی کنید که هنگام استفاده از ماژول "
"Clientside Validation، ماژول Webform Clientside Validation "
"نصب شده باشد"

msgid "Webform: Clientside validation"
msgstr "وب‌فرم: اعتبارسنجی سمتِ کاربر"

