msgid "Contact URL"
msgstr "URL تماس"

msgid "Webforms: Submissions log"
msgstr "وب‌فرم‌ها: گزارش ثبت‌ها"

msgid "Default wizard confirmation label"
msgstr "برچسب پیش‌فرضِ تأییدِ ویزارد"

msgid "Default more title"
msgstr "عنوان «بیشتر» پیش‌فرض"

msgid "Default section title tag"
msgstr "تگ عنوان پیش‌فرضِ بخش"

msgid "Wizard confirmation label"
msgstr "برچسب تأیید جادوگر"

msgid "Track wizard progress in the URL"
msgstr ""
"پیگیری پیشرفت ویزارد در نشانی "
"اینترنتی (URL)"

msgid "Schedule emails for all existing submissions"
msgstr ""
"برای همهٔ ارسال‌های موجود ایمیل‌ها "
"را زمان‌بندی کنید"

msgid "Webforms: Templates"
msgstr "وب‌فرم‌ها: قالب‌ها"

msgid "Emailing & handling submissions"
msgstr "ایمیل‌کردن و رسیدگی به ارسال‌ها"

msgid "Collecting webform submissions"
msgstr "جمع‌آوری ارسال‌های وب‌فرم"

msgid "Understanding a webform submission"
msgstr "درک یک ارسال فرم وب (Webform)"

msgid "Attaching webforms to nodes"
msgstr "پیوست کردن وب‌فرم‌ها به نودها"

msgid "Placing webforms as blocks"
msgstr "قرار دادن وب‌فرم‌ها به‌صورت بلاک"

msgid ""
"The <strong>Templates</strong> page lists reusable templates that can "
"be duplicated and customized to create new webforms."
msgstr ""
"صفحهٔ <strong>الگوها</strong> فهرستی از "
"الگوهای قابل‌استفادهٔ مجدد را نمایش "
"می‌دهد که می‌توان آن‌ها را تکثیر و "
"سفارشی‌سازی کرد تا وب‌فرم‌های جدید "
"ایجاد شوند."

msgid ""
"The <strong>Forms configuration</strong> page allows administrators to "
"manage form settings, behaviors, labels, messages and CSS classes."
msgstr ""
"صفحه <strong>پیکربندی فرم‌ها</strong> به "
"مدیران اجازه می‌دهد تنظیمات فرم، "
"رفتارها، برچسب‌ها، پیام‌ها و "
"کلاس‌های CSS را مدیریت کنند."

msgid "Configuration: Elements"
msgstr "پیکربندی: عناصر"

msgid ""
"The <strong>Elements configuration</strong> page allows administrators "
"to enable/disable element types and manage element specific settings, "
"properties, behaviors and formatting."
msgstr ""
"صفحهٔ <strong>پیکربندی عناصر</strong> به "
"مدیران اجازه می‌دهد نوع‌های عنصر را "
"فعال یا غیرفعال کنند و تنظیمات، "
"ویژگی‌ها، رفتارها و قالب‌بندیِ مخصوص "
"هر عنصر را مدیریت کنند."

msgid "Configuration: Options"
msgstr "پیکربندی: گزینه‌ها"

msgid ""
"The <strong>Options configuration</strong> page lists reusable "
"predefined options/values available for select menus, radio buttons, "
"checkboxes and Likert elements."
msgstr ""
"صفحهٔ <strong>پیکربندی گزینه‌ها</strong> "
"فهرستی از گزینه‌ها/مقادیر از پیش "
"تعریف‌شده و قابل‌استفادهٔ مجدد را "
"نمایش می‌دهد که برای منوهای انتخاب، "
"دکمه‌های رادیویی، چک‌باکس‌ها و "
"عناصر لیکرت در دسترس هستند."

msgid "Configuration: Submissions"
msgstr "پیکربندی: ارسال‌ها"

msgid ""
"The <strong>Submissions configuration</strong> page allows "
"administrators to manage submissions settings, behaviors and messages."
msgstr ""
"صفحهٔ <strong>پیکربندی ارسال‌ها</strong> به "
"مدیران اجازه می‌دهد تنظیمات، رفتارها "
"و پیام‌های مربوط به ارسال‌ها را "
"مدیریت کنند."

msgid "Configuration: Handlers"
msgstr "پیکربندی: مدیریت‌کننده‌ها"

msgid ""
"The <strong>Handlers configuration</strong> page allows administrators "
"to enable/disable handlers and configure default email settings and "
"messages."
msgstr ""
"صفحهٔ <strong>پیکربندی هندلرها</strong> به "
"مدیران اجازه می‌دهد هندلرها را "
"فعال/غیرفعال کنند و تنظیمات پیش‌فرض "
"ایمیل و پیام‌ها را پیکربندی کنند."

msgid ""
"<strong>Handlers</strong> are used to route submitted data to external "
"applications and send notifications & confirmations."
msgstr ""
"<strong>هندلرها</strong> برای هدایت داده‌های "
"ارسال‌شده به برنامه‌های خارجی و "
"ارسال اعلان‌ها و پیام‌های تأیید "
"به‌کار می‌روند."

msgid "Configuration: Exporters"
msgstr "پیکربندی: صادرکننده‌ها"

msgid ""
"The <strong>Exporters configuration</strong> page allows "
"administrators to enable/disable exporters and configure default "
"export settings."
msgstr ""
"صفحهٔ <strong>پیکربندی صادرکننده‌ها</strong> "
"به مدیران اجازه می‌دهد صادرکننده‌ها "
"را فعال/غیرفعال کنند و تنظیمات "
"پیش‌فرض صادرات را پیکربندی کنند."

msgid ""
"<strong>Exporters</strong> are used to export results into a "
"downloadable format that can be used by MS Excel, Google Sheets and "
"other spreadsheet applications."
msgstr ""
"<strong>اکسپورت‌کننده‌ها</strong> برای "
"خروجی گرفتن از نتایج در قالبی قابل "
"دانلود استفاده می‌شوند که بتوان از آن "
"در MS Excel، Google Sheets و سایر برنامه‌های "
"صفحه‌گسترده استفاده کرد."

msgid "Configuration: Libraries"
msgstr "پیکربندی: کتابخانه‌ها"

msgid ""
"The <strong>Libraries configuration</strong> page allows "
"administrators to enable/disable libraries and define global custom "
"CSS/JavaScript used by all webforms."
msgstr ""
"صفحهٔ <strong>پیکربندی کتابخانه‌ها</strong> "
"به مدیران اجازه می‌دهد کتابخانه‌ها "
"را فعال/غیرفعال کنند و CSS/JavaScript سفارشیِ "
"سراسری را که توسط همهٔ وب‌فرم‌ها "
"استفاده می‌شود، تعریف کنند."

msgid "Configuration: Libraries: Help"
msgstr "پیکربندی: کتابخانه‌ها: راهنما"

msgid "Configuration: Advanced"
msgstr "پیکربندی: پیشرفته"

msgid ""
"The <strong>Advanced configuration</strong> page allows an "
"administrator to enable/disable UI behaviors, manage requirements and "
"define data used for testing webforms."
msgstr ""
"صفحهٔ <strong>پیکربندی پیشرفته</strong> به "
"مدیر سایت امکان می‌دهد رفتارهای رابط "
"کاربری را فعال یا غیرفعال کند، "
"پیش‌نیازها را مدیریت کند و داده‌های "
"مورد استفاده برای آزمون وب‌فرم‌ها را "
"تعریف کند."

msgid "Configuration: Translate"
msgstr "پیکربندی: ترجمه"

msgid ""
"The <strong>Translate configuration</strong> page allows webform "
"messages and labels to be translated into multiple languages."
msgstr ""
"صفحهٔ <strong>ترجمهٔ پیکربندی</strong> امکان "
"ترجمهٔ پیام‌ها و برچسب‌های وب‌فرم را "
"به چندین زبان فراهم می‌کند."

msgid ""
"The <strong>Element plugins</strong> overview page lists all available "
"webform element plugins."
msgstr ""
"صفحهٔ مرور کلی <strong>افزونه‌های "
"عنصر</strong> همهٔ افزونه‌های عنصرِ "
"وب‌فرمِ در دسترس را فهرست می‌کند."

msgid ""
"<strong>Webform Element</strong> plugins are used to enhance existing "
"render/form elements. Webform element plugins provide default "
"properties, data normalization, custom validation, element "
"configuration form and customizable display formats."
msgstr ""
"افزونه‌های <strong>Webform Element</strong> برای "
"بهبود عناصر موجودِ render/form استفاده "
"می‌شوند. افزونه‌های عنصر وب‌فرم "
"(Webform) ویژگی‌های پیش‌فرض، نرمال‌سازی "
"داده‌ها، اعتبارسنجی سفارشی، فرم "
"پیکربندی عنصر و قالب‌های نمایش قابل "
"سفارشی‌سازی را فراهم می‌کنند."

msgid "Plugins: Emails/Handlers"
msgstr "پلاگین‌ها: ایمیل‌ها/هندلرها"

msgid ""
"The <strong>Handler plugins</strong> overview page lists all available "
"webform handler plugins."
msgstr ""
"صفحهٔ نمای کلی <strong>افزونه‌های "
"Handler</strong> همهٔ افزونه‌های handler موجود "
"برای وب‌فرم را فهرست می‌کند."

msgid "Plugins: Exporters"
msgstr "پلاگین‌ها: صادرکننده‌ها"

msgid ""
"The <strong>Exporter plugins</strong> overview page lists all "
"available results exporter plugins."
msgstr ""
"صفحهٔ نمای کلیِ <strong>پلاگین‌های "
"صادرکننده</strong> همهٔ پلاگین‌های "
"صادرکنندهٔ نتایجِ در دسترس را فهرست "
"می‌کند."

msgid ""
"The (View) <strong>Source</strong> page allows developers to edit a "
"webform's render array using YAML markup."
msgstr ""
"صفحهٔ <strong>Source</strong> (View) به "
"توسعه‌دهندگان اجازه می‌دهد تا با "
"استفاده از نشانه‌گذاری YAML، آرایهٔ "
"رندر یک وب‌فرم را ویرایش کنند."

msgid ""
"Developers can use the (View) <strong>Source</strong> page to alter a "
"webform's labels quickly, cut-n-paste multiple elements, reorder "
"elements, as well as  add custom properties and markup to elements."
msgstr ""
"توسعه‌دهندگان می‌توانند از صفحهٔ (View) "
"<strong>Source</strong> برای تغییر سریع "
"برچسب‌های یک وب‌فرم، کپی‌/پیست کردن "
"چندین عنصر، تغییر ترتیب عناصر، و "
"همچنین افزودن ویژگی‌های سفارشی و "
"نشانه‌گذاری (markup) به عناصر استفاده "
"کنند."

msgid ""
"The <strong>Test</strong> form allows a webform to be tested using a "
"customizable test dataset."
msgstr ""
"فرم <strong>آزمون</strong> این امکان را "
"می‌دهد که یک وب‌فرم با استفاده از یک "
"مجموعه‌دادهٔ آزمایشی "
"قابل‌سفارشی‌سازی، تست شود."

msgid ""
"The <strong>API</strong> form allows developers to test a webform's "
"API."
msgstr ""
"فرم <strong>API</strong> به توسعه‌دهندگان "
"اجازه می‌دهد API یک وب‌فرم را آزمایش "
"کنند."

msgid ""
"The <strong>Translate</strong> page allows a webform's configuration "
"and elements to be translated into multiple languages."
msgstr ""
"صفحه <strong>Translate</strong> امکان ترجمهٔ "
"پیکربندی و عناصر یک وب‌فرم را به چندین "
"زبان فراهم می‌کند."

msgid ""
"The <strong>Elements</strong>  page allows users to add, update, "
"duplicate and delete elements and wizard pages."
msgstr ""
"صفحه <strong>عناصر</strong> به کاربران امکان "
"می‌دهد عناصر و صفحه‌های ویزارد را "
"اضافه، به‌روزرسانی، تکثیر و حذف کنند."

msgid ""
"The <strong>Emails/Handlers</strong> page allows additional actions "
"and behaviors to be processed when a webform or submission is created, "
"updated, or deleted."
msgstr ""
"صفحه <strong>ایمیل‌ها/هندلرها</strong> امکان "
"انجام اقدامات و رفتارهای اضافی را "
"فراهم می‌کند تا هنگام ایجاد، "
"به‌روزرسانی یا حذف یک وب‌فرم یا "
"ارسال، پردازش شوند."

msgid "Settings: General"
msgstr "تنظیمات: عمومی"

msgid ""
"The <strong>General</strong> settings page allows a webform's "
"administrative information, paths, behaviors and third-party settings "
"to be customized."
msgstr ""
"صفحهٔ تنظیمات <strong>عمومی</strong> امکان "
"سفارشی‌سازی اطلاعات مدیریتی، مسیرها، "
"رفتارها و تنظیمات طرفِ ثالثِ یک "
"وب‌فرم را فراهم می‌کند."

msgid "Settings: Form"
msgstr "تنظیمات: فرم"

msgid "Settings: Submissions"
msgstr "تنظیمات: ارسال‌ها"

msgid ""
"The <strong>Submissions</strong> settings page allows a submission's "
"labels, behaviors, limits and draft settings to be customized."
msgstr ""
"صفحهٔ تنظیمات <strong>ارسال‌ها</strong> "
"امکان سفارشی‌سازی برچسب‌ها، "
"رفتارها، محدودیت‌ها و تنظیمات "
"پیش‌نویسِ یک ارسال را فراهم می‌کند."

msgid "Settings: Confirmation"
msgstr "تنظیمات: تأیید"

msgid ""
"The <strong>Confirmation</strong> settings page allows the submission "
"confirmation type, message and URL to be customized."
msgstr ""
"صفحهٔ تنظیمات <strong>تأیید</strong> امکان "
"سفارشی‌سازی نوع تأیید ارسال، پیام و "
"نشانی اینترنتی (URL) را فراهم می‌کند."

msgid "Settings: Assets"
msgstr "تنظیمات: دارایی‌ها"

msgid ""
"The <strong>CSS/JS</strong> settings page allows site builders to "
"attach custom CSS and JavaScript to a webform."
msgstr ""
"صفحهٔ تنظیمات <strong>CSS/JS</strong> به "
"سازندگان سایت اجازه می‌دهد CSS و JavaScript "
"سفارشی را به یک وب‌فرم پیوست کنند."

msgid "Settings: Access"
msgstr "تنظیمات: دسترسی"

msgid ""
"The <strong>Submissions</strong> page lists all incoming submissions "
"for all webforms."
msgstr ""
"صفحهٔ <strong>ارسال‌ها</strong> همهٔ "
"ارسال‌های ورودیِ مربوط به تمام "
"وب‌فرم‌ها را فهرست می‌کند."

msgid "Submissions: Log"
msgstr "ارسال‌ها: گزارش"

msgid ""
"The <strong>Submissions log</strong> page tracks all submission events "
"for all webforms that have submission logging enabled. Submission "
"logging can be enabled globally or on a per webform basis."
msgstr ""
"صفحه <strong>گزارش ارسال‌ها</strong> همه "
"رویدادهای ارسال را برای تمام "
"وب‌فرم‌هایی که ثبت گزارشِ ارسال برای "
"آن‌ها فعال شده است، ردیابی می‌کند. "
"ثبت گزارشِ ارسال می‌تواند به‌صورت "
"سراسری یا به‌صورت جداگانه برای هر "
"وب‌فرم فعال شود."

msgid "Results: Submissions"
msgstr "نتایج: ارسال‌ها"

msgid "Results: Log"
msgstr "نتایج: گزارش"

msgid ""
"The <strong>Results Log</strong> lists all webform submission events "
"for the current webform."
msgstr ""
"<strong>گزارش نتایج</strong> همهٔ رویدادهای "
"ثبت ارسال‌های وب‌فرم را برای وب‌فرمِ "
"فعلی فهرست می‌کند."

msgid "Results: Download"
msgstr "نتایج: دانلود"

msgid "Submission: View"
msgstr "ارسال: مشاهده"

msgid ""
"The <strong>Data (YAML)</strong> page displays a submission's raw data "
"as YAML."
msgstr ""
"صفحهٔ <strong>داده‌ها (YAML)</strong> داده‌های "
"خامِ یک ارسال را به‌صورت YAML نمایش "
"می‌دهد."

msgid "Submission: Log"
msgstr "ارسال: گزارش"

msgid ""
"The <strong>Log</strong> page shows all events and transactions for a "
"submission."
msgstr ""
"صفحهٔ <strong>لاگ</strong> همهٔ رویدادها و "
"تراکنش‌های مربوط به یک ارسال را نمایش "
"می‌دهد."

msgid "Submission: Edit"
msgstr "ارسال: ویرایش"

msgid ""
"The <strong>Edit</strong> form allows the administrator to update a "
"submission."
msgstr ""
"فرم <strong>ویرایش</strong> به مدیر اجازه "
"می‌دهد یک ارسال را به‌روزرسانی کند."

msgid ""
"The <strong>Edit all</strong> form allows administrator to update all "
"values for submission create from a multi-step form."
msgstr ""
"فرم <strong>ویرایش همه</strong> به مدیر سایت "
"اجازه می‌دهد همهٔ مقادیرِ یک ارسال "
"(submission) را که از یک فرم چندمرحله‌ای "
"ایجاد شده است، به‌روزرسانی کند."

msgid "Submission: Resend"
msgstr "ارسال: ارسال مجدد"

msgid "Submission: Notes"
msgstr "ارسال: یادداشت‌ها"

msgid ""
"The <strong>Notes</strong> form allows administrator to flag and "
"annotate a submission."
msgstr ""
"فرم <strong>یادداشت‌ها</strong> به مدیر اجازه "
"می‌دهد یک ارسال را علامت‌گذاری کرده و "
"برای آن یادداشت ثبت کند."

msgid "Devel: Export"
msgstr "Devel: درون‌ریزی/برون‌ریزی"

msgid ""
"The <strong>Schema</strong> page displays an overview of a webform's "
"elements and specified data types, which can be used to map webform "
"submissions to an external API."
msgstr ""
"صفحهٔ <strong>Schema</strong> نمای کلی‌ای از "
"عناصر یک وب‌فرم و نوع داده‌های "
"تعریف‌شده را نمایش می‌دهد؛ از این "
"اطلاعات می‌توان برای نگاشت ارسال‌های "
"وب‌فرم به یک API خارجی استفاده کرد."

msgid ""
"A <strong>Webform Node</strong> allows webforms to be fully integrated "
"into a website as nodes."
msgstr ""
"یک <strong>نود وب‌فرم</strong> این امکان را "
"فراهم می‌کند که وب‌فرم‌ها به‌صورت "
"کامل به‌عنوان نودها در یک وب‌سایت "
"یکپارچه شوند."

msgid "Webform Node: References"
msgstr "نود وبفرم: ارجاع‌ها"

msgid ""
"The <strong>Reference</strong> pages displays an overview of a "
"webform's references and allows you to quickly create new references "
"(a.k.a Webform nodes)."
msgstr ""
"صفحه‌های <strong>Reference</strong> نمای کلی از "
"ارجاع‌های یک وب‌فرم را نمایش می‌دهند "
"و به شما امکان می‌دهند به‌سرعت "
"ارجاع‌های جدید (که با نام گره‌های "
"وب‌فرم (Webform nodes) نیز شناخته می‌شوند) "
"ایجاد کنید."

msgid "Webform Node: Results: Submissions"
msgstr "نود وب‌فرم: نتایج: ارسال‌ها"

msgid "Submissions can be reviewed, updated, flagged and annotated."
msgstr ""
"ارسال‌ها می‌توانند بازبینی، "
"به‌روزرسانی، پرچم‌گذاری و "
"یادداشت‌گذاری شوند."

msgid "Webform Node: Results: Log"
msgstr "نود وبفرم: نتایج: گزارش"

msgid "Webform Node: Results: Download"
msgstr "نود وب‌فرم: نتایج: دانلود"

msgid ""
"The <strong>Download</strong> page allows a webform node's submissions "
"to be exported into a customizable CSV (Comma Separated Values) file "
"and other common data formats."
msgstr ""
"صفحه <strong>دانلود</strong> این امکان را "
"فراهم می‌کند که ارسال‌های یک نود "
"وب‌فرم (Webform) به یک فایل CSV (مقادیر "
"جداشده با ویرگول) قابل سفارشی‌سازی و "
"همچنین سایر فرمت‌های رایج داده صادر "
"(Export) شوند."

msgid ""
"A <strong>Webform Block</strong> allows a webform to be placed "
"anywhere on a website."
msgstr ""
"یک <strong>بلوک وب‌فرم</strong> به شما امکان "
"می‌دهد یک وب‌فرم را در هر نقطه‌ای از "
"وب‌سایت قرار دهید."

msgid "Message: Webform UI Disabled"
msgstr "پیام: رابط کاربری Webform غیرفعال است"

msgid ""
"Please enable the <strong>Webform UI</strong> module if you would like "
"to add easily add and manage elements using a drag-n-drop user "
"interface."
msgstr ""
"لطفاً اگر می‌خواهید عناصر را "
"به‌سادگی با استفاده از رابط کاربری "
"کشیدن و رها کردن (Drag & Drop) اضافه و مدیریت "
"کنید، ماژول <strong>Webform UI</strong> را فعال "
"کنید."

msgid "Star/flag the status of this submission"
msgstr ""
"ستاره بزنید/پرچم‌گذاری کنید وضعیت این "
"ارسال را"

msgid ""
"Inline (reloads the current page and replaces the webform with the "
"confirmation message)"
msgstr ""
"درون‌خطی (صفحهٔ فعلی را دوباره "
"بارگذاری می‌کند و وب‌فرم را با پیام "
"تأیید جایگزین می‌کند)"

msgid ""
"Modal (reloads the current page/form and displays the confirmation "
"message in a modal dialog)"
msgstr ""
"مودال (صفحه/فرم فعلی را دوباره "
"بارگذاری می‌کند و پیام تأیید را در یک "
"پنجرهٔ محاوره‌ای مودال نمایش می‌دهد)"

msgid ""
"If checked, users will not be allowed to navigate back to the form "
"using the browser's back button."
msgstr ""
"اگر انتخاب شود، کاربران اجازه نخواهند "
"داشت با استفاده از دکمه «بازگشت» "
"مرورگر به فرم برگردند."

msgid "Track wizard progress in the URL by"
msgstr "پیگیری روند پیشرفت ویزارد در URL با"

msgid "Page name (?page=contact)"
msgstr "نام صفحه (?page=contact)"

msgid "Page index (?page=2)"
msgstr "فهرست صفحه (?page=2)"

msgid ""
"Properties do not have to prepended with a hash (#) character, the "
"hash character will be automatically added to the custom properties."
msgstr ""
"ویژگی‌ها لازم نیست با نویسهٔ هش (#) "
"شروع شوند؛ این نویسه به‌صورت خودکار "
"به ویژگی‌های سفارشی اضافه خواهد شد."

msgid ""
"If saving of submissions is disabled, submission settings, submission "
"limits, purging and the saving of drafts will be disabled. Submissions "
"must be sent via an email or processed using a custom <a "
"href=\":href\">webform handler</a>."
msgstr ""
"اگر ذخیره‌سازی ارسال‌ها غیرفعال "
"باشد، تنظیمات ارسال، محدودیت‌های "
"ارسال، پاک‌سازی و ذخیرهٔ "
"پیش‌نویس‌ها نیز غیرفعال خواهد شد. در "
"این حالت، ارسال‌ها باید از طریق ایمیل "
"ارسال شوند یا با استفاده از یک <a "
"href=\":href\">هندلر وب‌فرم</a> سفارشی پردازش "
"شوند."

msgid "Convert anonymous user drafts and submissions to authenticated user"
msgstr ""
"تبدیل پیش‌نویس‌ها و ارسال‌های "
"کاربران ناشناس به کاربرِ احراز "
"هویت‌شده"

msgid ""
"If checked users will be able to update a submission using the "
"webform's URL appended with the submission's (secure) token."
msgstr ""
"اگر این گزینه تیک بخورد، کاربران "
"می‌توانند با استفاده از نشانی وب‌فرم "
"که توکن (امن) ارسال به آن اضافه شده است، "
"یک ارسال را به‌روزرسانی کنند."

msgid ""
"Only webforms that are open to new submissions can be updated using "
"the secure token."
msgstr ""
"فقط وب‌فرم‌هایی که برای دریافت "
"ارسال‌های جدید باز هستند را می‌توان "
"با استفاده از توکن امن به‌روزرسانی "
"کرد."

msgid "All submission event are being logged for all webforms"
msgstr ""
"تمام رویدادهای ارسال برای همهٔ "
"وب‌فرم‌ها ثبت (لاگ) می‌شوند."

msgid ""
"Submissions accessed using the (secure) token will by-pass all webform "
"submission access rules."
msgstr ""
"ارسال‌هایی که با استفاده از توکن (امن) "
"به آن‌ها دسترسی پیدا شود، همهٔ قوانین "
"دسترسی به ارسال‌های وب‌فرم را دور "
"می‌زنند."

msgid ""
"Limit the number of submissions per user. A user is identified by "
"their user id if logged-in, or by their Cookie if anonymous."
msgstr ""
"تعداد ارسال‌ها را برای هر کاربر محدود "
"کنید. کاربر در صورت وارد شدن (لاگین) با "
"شناسهٔ کاربری‌اش شناسایی می‌شود و "
"اگر ناشناس باشد، با کوکی‌اش شناسایی "
"می‌شود."

msgid "Above test data is keyed by element #type."
msgstr ""
"داده‌های آزمایشی بالا بر اساس عنصر با "
"‎#type‎ کلیدگذاری شده‌اند."

msgid ""
"Batch email size is used by any handler that sends out bulk emails. "
"This include the scheduled email handler."
msgstr ""
"اندازهٔ ایمیل‌های دسته‌ای توسط هر "
"هندلری که ایمیل‌های انبوه ارسال "
"می‌کند استفاده می‌شود. این شامل هندلر "
"ایمیل زمان‌بندی‌شده نیز می‌شود."

msgid ""
"Allowed tags are applied to any element property that may contain HTML "
"markup. Element properties which can contain HTML markup include "
"#title, #description, #field_prefix, and #field_suffix."
msgstr ""
"تگ‌های مجاز روی هر ویژگیِ عنصر که ممکن "
"است شامل نشانه‌گذاری HTML باشد اعمال "
"می‌شوند. ویژگی‌های عنصر که می‌توانند "
"شامل نشانه‌گذاری HTML باشند شامل #title، "
"#description، #field_prefix و #field_suffix هستند."

msgid ""
"The label to show for the first default option for a required select "
"menus."
msgstr ""
"برچسبی که برای اولین گزینهٔ پیش‌فرض "
"در منوهای انتخابیِ اجباری نمایش داده "
"می‌شود."

msgid ""
"The label to show for the first default option for an optional select "
"menus."
msgstr ""
"برچسبی که برای اولین گزینهٔ پیش‌فرض "
"در منوهای انتخابیِ اختیاری نمایش داده "
"می‌شود."

msgid ""
"Redirect anonymous users to login when attempting to access private "
"file uploads"
msgstr ""
"هدایت کاربران ناشناس به صفحهٔ ورود "
"هنگام تلاش برای دسترسی به فایل‌های "
"خصوصیِ آپلودشده"

msgid ""
"If checked, anonymous users will be redirected to the user login page "
"when attempting to access private file uploads."
msgstr ""
"اگر این گزینه فعال باشد، کاربران "
"ناشناس هنگام تلاش برای دسترسی به "
"فایل‌های آپلودشدهٔ خصوصی، به صفحهٔ "
"ورود کاربران هدایت می‌شوند."

msgid "Display collapse/expand all details link on all webforms"
msgstr ""
"نمایش لینک جمع‌کردن/بازکردن همهٔ "
"جزئیات در همهٔ وب‌فرم‌ها"

msgid ""
"If checked, an expand/collapse all details link will be added to all "
"webforms which contain two or more details elements."
msgstr ""
"اگر این گزینه علامت‌گذاری شود، یک "
"پیوند «باز/بسته کردن همهٔ جزئیات» به "
"همهٔ وب‌فرم‌هایی که شامل دو یا چند "
"عنصر جزئیات هستند اضافه خواهد شد."

msgid ""
"The default email address that a recipient will see when they are "
"replying to an email. Leave blank to automatically use the 'From "
"email' address. Setting the 'Reply-to' to the 'From email' prevent "
"emails from being flagged as spam."
msgstr ""
"آدرس ایمیل پیش‌فرضی که گیرنده هنگام "
"پاسخ دادن به یک ایمیل مشاهده می‌کند. "
"اگر خالی بگذارید، به‌صورت خودکار از "
"آدرس «From email» استفاده می‌شود. تنظیم "
"«Reply-to» روی آدرس «From email» باعث می‌شود "
"ایمیل‌ها به‌عنوان اسپم علامت‌گذاری "
"نشوند."

msgid ""
"The default email address to which bounce messages are delivered. "
"Leave blank to automatically use the 'From email' address."
msgstr ""
"نشانی ایمیل پیش‌فرضی که پیام‌های "
"برگشتی (Bounce) به آن تحویل داده می‌شوند. "
"برای استفادهٔ خودکار از نشانی «ایمیل "
"فرستنده (From email)» این فیلد را خالی "
"بگذارید."

msgid ""
"The default sender name which is used along with the default sender "
"email address."
msgstr ""
"نام پیش‌فرضِ فرستنده که همراه با آدرس "
"ایمیلِ پیش‌فرضِ فرستنده استفاده "
"می‌شود."

msgid ""
"Enter the amount of submissions to be purged during single cron run. "
"You may want to lower this number if you are facing memory or timeout "
"issues when purging via cron."
msgstr ""
"تعداد ارسال‌هایی را که باید در یک "
"اجرای کران پاک‌سازی شوند وارد کنید. "
"اگر هنگام پاک‌سازی از طریق کران با "
"مشکل کمبود حافظه یا پایان زمان اجرا "
"(timeout) مواجه می‌شوید، بهتر است این عدد "
"را کاهش دهید."

msgid "Multiple settings"
msgstr "چندین تنظیم"

msgid ""
"If checked, the composite sub-element titles will be displayed as the "
"table header labels."
msgstr ""
"اگر تیک زده شود، عنوان‌های زیرعنصرهای "
"ترکیبی به‌عنوان برچسب‌های سربرگ جدول "
"نمایش داده خواهند شد."

msgid ""
"This is used as the table header for this webform element when "
"displaying multiple values."
msgstr ""
"این متن به‌عنوان سرستون جدول برای این "
"عنصر وب‌فرم استفاده می‌شود، زمانی که "
"چند مقدار نمایش داده می‌شوند."

msgid "Number of empty items"
msgstr "تعداد موارد خالی"

msgid "Number of add more items"
msgstr "تعداد گزینه‌های «افزودن موارد بیشتر»"

msgid "If unchecked, the elements will no longer be sortable."
msgstr ""
"اگر این گزینه غیرفعال باشد، دیگر امکان "
"مرتب‌سازی عناصر وجود نخواهد داشت."

msgid ""
"If unchecked, the add/remove (+/x) buttons will be removed from each "
"table row."
msgstr ""
"اگر تیک نخورده باشد، دکمه‌های "
"افزودن/حذف (+/x) از هر ردیف جدول حذف "
"خواهند شد."

msgid "The click-able label used to open and close more text."
msgstr ""
"برچسبِ قابل‌کلیک که برای باز کردن و "
"بستن متنِ بیشتر استفاده می‌شود."

msgid "More text"
msgstr "متن بیشتر"

msgid ""
"A long description of the element that provides form additional "
"information which can opened and closed."
msgstr ""
"توضیح مفصلِ این عنصر که اطلاعات "
"تکمیلیِ فرم را فراهم می‌کند و می‌توان "
"آن را باز و بسته کرد."

msgid ""
"Check that entered values for this element are unique for the current "
"user."
msgstr ""
"بررسی کنید که مقادیر واردشده برای این "
"عنصر، برای کاربر فعلی یکتا باشند."

msgid ""
"If set, this message will be used when an element's value are not "
"unique, instead of the default \"@message\" message."
msgstr ""
"اگر تنظیم شود، به‌جای پیام پیش‌فرض "
"«@message»، زمانی که مقدار یک عنصر یکتا "
"نباشد از این پیام استفاده خواهد شد."

msgid "Item format custom HTML"
msgstr "قالب آیتم: HTML سفارشی"

msgid "Item format custom Text"
msgstr "فرمت آیتم: متن سفارشی"

msgid "Items format custom HTML"
msgstr "قالب‌بندی موارد در HTML سفارشی"

msgid "Items format custom Text"
msgstr "قالب سفارشی اقلام (متن)"

msgid ""
"Properties do not have to be prepended with a hash (#) character, the "
"hash character will be automatically added to the custom properties."
msgstr ""
"نیازی نیست قبل از ویژگی‌ها کاراکتر هش "
"(#) را قرار دهید؛ این کاراکتر به‌صورت "
"خودکار به ویژگی‌های سفارشی اضافه "
"می‌شود."

msgid "Display limit and total submissions for the"
msgstr "محدودیت نمایش و مجموع ارسال‌ها برای"

msgid ""
"Restrict limit and total submissions to current or specified source "
"entity"
msgstr ""
"محدود کردن سقف و مجموع ارسال‌ها به "
"موجودیت منبعِ فعلی یا مشخص‌شده"

msgid ""
"You may use tokens. Tokens should use the 'html_date' or "
"'html_datetime' date format. (i.e. @date_format)"
msgstr ""
"می‌توانید از توکن‌ها استفاده کنید. "
"توکن‌ها باید از قالب تاریخ «html_date» یا "
"«html_datetime» استفاده کنند. (یعنی @date_format)"

msgid "Output the range's value"
msgstr "مقدار بازه را نمایش دهید"

msgid "Include existing submission values"
msgstr "شامل کردن مقادیر موجودِ ارسال‌شده"

msgid ""
"Provides a form element to create custom composites using a grid/table "
"layout."
msgstr ""
"یک عنصر فرم فراهم می‌کند تا بتوانید با "
