msgstr ""
"نمایش «@display» دارای افزونهٔ سبک "
"نامعتبر است."

msgid "Exposed form: @view-@display_id"
msgstr "فرم نمایان‌شده: @view-@display_id"

msgid "Attachment settings"
msgstr "تنظیمات ضمیمه"

msgid "Inherit exposed filters"
msgstr "به ارث بردن فیلترهای نمایان‌شده"

msgid "Multiple displays"
msgstr "چندین نمایش"

