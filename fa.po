msgstr "نقشهٔ سایت %label ذخیره شد."

msgid "Updated the %label sitemap."
msgstr "نقشهٔ سایت %label به‌روزرسانی شد."

msgid ""
"No custom links available. <a href=\"@custom_link\">Add custom "
"link</a>"
msgstr ""
"هیچ پیوند سفارشی‌ای در دسترس نیست. <a "
"href=\"@custom_link\">افزودن پیوند سفارشی</a>"

