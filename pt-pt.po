msgid ""
"If you enjoy and value Drupal and the Webform module consider <a "
"href=\":href_involved\">getting involved in the Drupal community</a>, "
"<a href=\":href_join\">joining the Drupal Association</a>, and <a "
"href=\":href_opencollective\">contributing funds to the Webform "
"module's Open Collective</a>."
msgstr ""
"Se gosta e valoriza o Drupal e o módulo Webform, considere <a "
"href=\":href_involved\">envolver-se na comunidade Drupal</a>, <a "
"href=\":href_join\">juntar-se à Drupal Association</a> e <a "
"href=\":href_opencollective\">contribuir financeiramente para o Open "
"Collective do módulo Webform</a>."

msgid "This behavior is not supported when Ajax is enabled."
msgstr "Este comportamento não é suportado quando o Ajax está ativado."

