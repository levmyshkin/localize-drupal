msgstr "Selecione o idioma que será utilizado para apresentar este e-mail."

msgid "Enter custom data that will be included in all remote CRUD requests."
msgstr ""
"Introduza dados personalizados que serão incluídos em todos os "
"pedidos CRUD remotos."

msgid ""
"If checked, elements with 'Display element' unchecked (i.e., "
"<code>'#access': false</code> will not be included in the request "
"data."
msgstr ""
"Se selecionado, os elementos com “Exibir elemento” desmarcado (ou "
"seja, <code>'#access': false</code>) não serão incluídos nos dados "
"do pedido."

msgid "Remote CRUD request return @status_code status code."
msgstr "O pedido CRUD remoto devolve o código de estado @status_code."

msgid "Remote HTTP operation successful!"
msgstr "Operação HTTP remota concluída com sucesso!"

msgid "Debug: Remote HTTP operation: @title [@state]"
msgstr "Depuração: Operação HTTP remota: @title [@state]"

msgid "Remote HTTP Operations"
msgstr "Operações remotas de HTTP"

msgid ""
"Execute HTTP operation <small>(GET, POST, PUT, or PATCH request "
"methods)</small> to a URL, (optionally) including the webform "
"submissions."
msgstr ""
"Executar uma operação HTTP <small>(métodos de pedido GET, POST, PUT "
"ou PATCH)</small> para um URL, incluindo (opcionalmente) as "
"submissões do webform."

