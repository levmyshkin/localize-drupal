"Requested changes:\n"
"@change_list"
msgstr ""
"Alterações solicitadas:\r\n"
"@change_list"

msgid "- Updated @name from @installed_version to @updated_version"
msgstr "- Atualizar @name de @installed_version para @updated_version"

