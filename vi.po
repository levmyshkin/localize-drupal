msgstr "sao lưu nhanh"

msgid "Settings Tab - Destinations"
msgstr "Tab Cài Đặt - Điểm Đến"

msgid ""
"<h3>@title</h3><p>Sources store your source settings you want to "
"backup, for now is available 4 default sources to use. Follow module "
"issues list for new source features.</p>"
msgstr ""
"<h3>@title</h3><p>Các nguồn lưu trữ cài đặt nguồn mà "
"bạn muốn sao lưu, hiện tại có 4 nguồn mặc định để "
"sử dụng. Theo dõi danh sách các vấn đề của module để "
"biết các tính năng nguồn mới.</p>"

