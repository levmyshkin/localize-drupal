msgid "Webform Cards"
msgstr "Thẻ Webform"

msgid ""
"Provides a 'Card' container element for fast clientside multistep form "
"pagination."
msgstr ""
"Cung cấp một phần tử chứa 'Card' để phân trang biểu "
"mẫu đa bước nhanh phía khách hàng."

