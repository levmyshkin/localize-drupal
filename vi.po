msgid "Null"
msgstr "Null"

msgid "Link to translate @entity_type_label"
msgstr "Liên kết để dịch @entity_type_label"

msgid "Provide a translation link to the @entity_type_label."
msgstr "Cung cấp liên kết dịch sang @entity_type_label."

msgid "Interface text language selected for page"
msgstr "Ngôn ngữ văn bản giao diện đã chọn cho trang"

msgid ""
"Customize %language_name language detection to differ from Interface "
"text language detection settings"
msgstr ""
"Tùy chỉnh phát hiện ngôn ngữ %language_name để khác với "
"cài đặt phát hiện ngôn ngữ văn bản giao diện"

msgid ""
"The domain for %language may only contain the domain name, not a "
"trailing slash, protocol and/or port."
msgstr ""
"Tên miền cho %language chỉ được chứa tên miền, không "
"bao gồm dấu gạch chéo ở cuối, giao thức và/hoặc "
"cổng."

msgid "@language translation of the @type %label has been deleted."
