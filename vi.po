msgid ""
"Tippy.js a tiny, low-level library for creating \"floating\" elements "
"like tooltips, popovers, dropdowns, menus, and more."
msgstr ""
"Tippy.js là một thư viện nhỏ gọn, cấp thấp dùng để "
"tạo các phần tử \"nổi\" như tooltip, popover, dropdown, menu "
