"Drush was unable to download the DOMPurify library from @remote. "
"@exception"
msgstr ""
"Drush không thể tải thư viện DOMPurify từ @remote. "
"@exception"

msgid "Error: unable to unzip DOMPurify file."
msgstr "Lỗi: không thể giải nén tập tin DOMPurify."

