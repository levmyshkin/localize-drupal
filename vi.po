"Trên trang <a href=\":upgrade\">Nâng cấp</a>, bạn sẽ được "
"hướng dẫn thực hiện nâng cấp qua một số bước."

msgid "Reviewing the upgrade log"
msgstr "Xem lại nhật ký nâng cấp"

msgid ""
