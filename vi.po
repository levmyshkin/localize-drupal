msgstr "Một bản trình diễn của biểu mẫu đăng ký sự kiện."

msgid "Demo: Region Contact"
msgstr "Dùng thử: Vùng Liên hệ"

msgid "A demonstration of a region based contact form."
msgstr "Một minh họa về biểu mẫu liên hệ dựa trên vùng."

msgid "Employee: Email"
msgstr "Nhân viên: Email"

msgid "Demo: Region Contact: Employee"
msgstr "Demo: Khu vực Liên hệ: Nhân viên"

msgid "Manager: Email"
msgstr "Quản lý: Email"

msgid "Demo: Region Contact: Manager"
msgstr "Demo: Vùng Liên hệ: Người quản lý"

