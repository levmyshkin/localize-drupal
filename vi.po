msgid ""
"\n"
"        <p>You can align images, videos, blockquotes and so on to "
"the left, right or center. Examples:</p>\n"
"        <ul>\n"
"          "
"<li>Align an image to the left: <code>&lt;img src=\"\" "
"data-align=\"left\" /&gt;</code></li>\n"
"          <li>Align an image "
"to the center: <code>&lt;img src=\"\" data-align=\"center\" "
"/&gt;</code></li>\n"
"          <li>Align an image to the right: "
"<code>&lt;img src=\"\" data-align=\"right\" /&gt;</code></li>\n"
"       "
"   <li>… and you can apply this to other elements as well: "
"<code>&lt;video src=\"\" data-align=\"center\" /&gt;</code></li>\n"
"    "
"    </ul>"
msgstr ""
"<p>Bạn có thể căn chỉnh hình ảnh, video, trích dẫn và "
"các phần tử khác sang trái, phải hoặc giữa. Ví "
"dụ:</p>\n"
"<ul>\n"
"  <li>Căn hình ảnh sang trái: <code>&lt;img "
"src=\"\" data-align=\"left\" /&gt;</code></li>\n"
"  <li>Căn hình "
"ảnh ở giữa: <code>&lt;img src=\"\" data-align=\"center\" "
"/&gt;</code></li>\n"
"  <li>Căn hình ảnh sang phải: <code>&lt;img "
"src=\"\" data-align=\"right\" /&gt;</code></li>\n"
"  <li>… và bạn "
"cũng có thể áp dụng điều này cho các phần tử khác: "
"<code>&lt;video src=\"\" data-align=\"center\" "
"/&gt;</code></li>\n"
"</ul>"

msgid "Align images"
msgstr "Căn chỉnh hình ảnh"

msgid ""
"Uses a <code>data-align</code> attribute on <code>&lt;img&gt;</code> "
"tags to align images."
msgstr ""
"Sử dụng thuộc tính <code>data-align</code> trên các thẻ "
"<code>&lt;img&gt;</code> để căn chỉnh hình ảnh."

msgid ""
"\n"
"        <p>You can caption images, videos, blockquotes, and so on. "
"Examples:</p>\n"
"        <ul>\n"
"            <li><code>&lt;img src=\"\" "
"data-caption=\"This is a caption\" /&gt;</code></li>\n"
"            "
"<li><code>&lt;video src=\"\" data-caption=\"The Drupal Dance\" "
"/&gt;</code></li>\n"
"            <li><code>&lt;blockquote "
"data-caption=\"Dries Buytaert\"&gt;Drupal is "
"awesome!&lt;/blockquote&gt;</code></li>\n"
"            "
"<li><code>&lt;code data-caption=\"Hello world in "
"JavaScript.\"&gt;alert(\"Hello world!\");&lt;/code&gt;</code></li>\n"
"  "
"      </ul>"
msgstr ""
"<p>Bạn có thể thêm chú thích cho hình ảnh, video, trích "
"dẫn, v.v. Ví dụ:</p>\n"
"<ul>\n"
"    <li><code>&lt;img src=\"\" "
"data-caption=\"Đây là chú thích\" /&gt;</code></li>\n"
"    "
"<li><code>&lt;video src=\"\" data-caption=\"Điệu nhảy Drupal\" "
"/&gt;</code></li>\n"
"    <li><code>&lt;blockquote data-caption=\"Dries "
"Buytaert\"&gt;Drupal thật tuyệt "
"vời!&lt;/blockquote&gt;</code></li>\n"
"    <li><code>&lt;code "
"data-caption=\"Hello world trong JavaScript.\"&gt;alert(\"Hello "
"world!\");&lt;/code&gt;</code></li>\n"
"</ul>"

msgid "Caption images"
msgstr "Chú thích hình ảnh"

