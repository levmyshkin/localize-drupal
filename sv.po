msgstr ""
"Det fanns inga åsidosatta Metatag-poster som behövde uppdateras för "
"att lagra data med JSON."

msgid ""
"Processed @processed of @total updating Metatag records with the "
"Publisher or Name meta tags."
msgstr ""
"Bearbetat @processed av @total uppdaterar Metatag-poster med "
"Publisher- eller Name-meta-taggar."

msgid "There were no Metatag records to update."
msgstr "Det fanns inga Metatag-poster att uppdatera."

