msgstr "<a href=\":href\">Inaktivera CDN-varning</a>"

msgid ""
"@total libraries (@installed installed; @excluded excluded; @missing "
"CDN)"
msgstr ""
"@total bibliotek (@installed installerade; @excluded uteslutna; "
"@missing CDN)"

msgid "Drupal Association"
msgstr "Drupal Association"

msgid ""
"The below requirements are checked by the <a href=\":href\">Status "
"report</a>."
msgstr "Följande krav kontrolleras av <a href=\":href\">Statusrapporten</a>."

msgid ""
"If unchecked, all warnings about Webform SPAM protection will be "
"disabled."
msgstr ""
"Om den inte är markerad kommer alla varningar om Webform SPAM-skydd "
"att inaktiveras."

msgid "Check that all entered values for this element are unique."
msgstr "Kontrollera att alla inskrivna värden för detta element är unika."

msgid ""
"Check that entered values for this element is unique for the current "
"source entity."
msgstr ""
"Kontrollera att angivna värden för detta element är unika för den "
"aktuella källentiteten."

