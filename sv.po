msgstr "Påverka alla element som använder dessa bilder"

msgid "%label is used by the below webform(s)."
msgstr "%label används av nedanstående webbformulär."

msgid "Delete all related submissions"
msgstr "Radera alla relaterade inskickningar"

msgid "Affect any fields or nodes which reference this webform"
msgstr "Påverka alla fält eller noder som refererar till detta webbformulär"

msgid "Affect any elements which use these options"
msgstr "Påverka alla element som använder dessa alternativ"

msgid "%label is used by the below composite element(s)."
msgstr "%label används av nedanstående sammansatta element."

