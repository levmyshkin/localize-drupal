msgstr ""
"Begäran om avslutande av konto för [user:display-name] på "
"[site:name]"

msgid "Replacement login information for [user:display-name] at [site:name]"
msgstr ""
"Ersättande inloggningsuppgifter för [user:display-name] på "
"[site:name]"

