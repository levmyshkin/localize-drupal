msgstr ""
"Composer kan inte användas eftersom funktionen "
"<code>proc_open()</code> är inaktiverad."

msgid "Unable to determine Composer <code>@key</code> setting."
msgstr "Kan inte avgöra Composer <code>@key</code>-inställning."

msgid "TLS must be enabled for HTTPS Composer downloads."
msgstr "TLS måste vara aktiverat för HTTPS-nedladdningar i Composer."

msgid ""
"@message See <a href=\":url\">the help page</a> for more information "
"on how to configure Composer to download packages securely."
msgstr ""
"@message Se <a href=\":url\">hjälpsidan</a> för mer information om "
