"<code>@installed_version</code>."
msgstr ""
"<code>@name</code> stöds, men endast version "
"<code>@supported_version</code>; version "
"<code>@installed_version</code> hittades."

msgid ""
"Composer cannot be used because the <code>proc_open()</code> function "
