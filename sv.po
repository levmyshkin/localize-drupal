"%submission: Email <b>not scheduled</b> for %handler handler because "
"%send is not a valid date/token."
msgstr ""
"%submission: E-post <b>inte schemalagd</b> för %handler-hanteraren "
"eftersom %send inte är ett giltigt datum/token."

msgid ""
"%submission: Email <b>@action</b> by %handler handler to be sent on "
"%date."
msgstr ""
"%submission: E-post <b>@action</b> av %handler-hanterare ska skickas "
"den %date."

