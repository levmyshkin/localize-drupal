msgstr "Android Mobile: Alternativa ao link do app para Android"

msgid "Android Mobile: Manifest"
msgstr "Android Mobile: Manifesto"

msgid "Apple Mobile: iTunes App"
msgstr "Apple Mobile: App do iTunes"

