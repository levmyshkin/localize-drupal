msgstr "Exemplo de um manipulador de envio de submissões de webform."

msgid ""
"Inline (Displays message when access is denied to field, nodes, and "
"blocks)"
msgstr ""
"Inline (Exibe mensagem quando o acesso é negado a campos, nós e "
"blocos)"

msgid ""
"Page (Displays message when access is denied to forms, fields, nodes, "
"and blocks)"
msgstr ""
"Página (Exibe mensagem quando o acesso é negado a formulários, "
"campos, conteúdos e blocos)"

msgid ""
"Login (Redirects to user login form and displays message. Field, "
"nodes, and block only display the message.)"
msgstr ""
"Login (Redireciona para o formulário de login do usuário e exibe uma "
"mensagem. Em campos, nós e blocos, apenas a mensagem é exibida.)"

msgid ""
"When this container is hidden all this container's subelement values "
"will be cleared."
msgstr ""
"Quando este contêiner estiver oculto, todos os valores dos "
"subelementos deste contêiner serão apagados."

msgid "When this element is hidden, this element's value will be cleared."
msgstr ""
"Quando este elemento estiver oculto, o valor deste elemento será "
"limpo."

msgid "Input hiding"
msgstr "Ocultar entrada"

msgid "Hide the input of the element when the input is not being focused."
msgstr "Ocultar o campo do elemento quando ele não estiver em foco."

