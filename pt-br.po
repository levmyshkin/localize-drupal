" "
"       <ul>\n"
"          <li>Alinhar uma imagem à esquerda: "
"<code>&lt;img src=\"\" data-align=\"left\" /&gt;</code></li>\n"
"        "
"  <li>Alinhar uma imagem ao centro: <code>&lt;img src=\"\" "
"data-align=\"center\" /&gt;</code></li>\n"
"          <li>Alinhar uma "
