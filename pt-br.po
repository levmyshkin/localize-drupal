msgstr "Remova a opção/caixa de seleção"

msgid ""
"This message is displayed when the remaining submission is greater "
"than one."
msgstr ""
"Esta mensagem é exibida quando o número de envios restantes é maior "
"que um."

msgid "One remaining message"
msgstr "Uma mensagem restante"

