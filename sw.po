msgstr "Kugawana fomu kumewezeshwa kwa fomu zote za wavuti."

msgid "If checked, form sharing will be enabled for this webform."
msgstr ""
"Ikiwa imechaguliwa, kushiriki fomu kutawezeshwa kwa fomu hii ya "
"wavuti."

msgid "If checking, form sharing will be enabled for all webform nodes."
msgstr ""
"Kama inakaguliwa, kushiriki fomu kutawekwa kuwezesha kwa node zote za "
"webform."

msgid "Select the theme that will be used to render all shared webforms."
msgstr "Chagua mandhari itakayotumika kuonyesha webforms zote zilizoshirikiwa."

msgid "Sort the options by their (translated) labels."
msgstr "Panga chaguzi kwa alama zao (zilizo tafsiriwa)."

