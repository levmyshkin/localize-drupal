"Module %name has been installed. Configure <a href=\":link\">related "
"permissions</a>."
msgid_plural ""
"@count modules have been installed: %names. Configure <a "
"href=\":link\">related permissions</a>."
msgstr[0] ""
"Moduli %name imewekwa. Sanidi <a href=\":link\">idhini "
"zinazohusiana</a>.  \n"
"@count moduli zimewekwa: %names. Sanidi <a "
"href=\":link\">idhini zinazohusiana</a>."

msgid "Module %name has been installed."
msgid_plural "@count modules have been installed: %names."
msgstr[0] "Moduli %name imewekwa."
msgstr[1] "Moduli @count zimewekwa: %names."

