msgstr "Configuracions Xdebug"

msgid "xdebug.max_nesting_level is set to %value."
msgstr "xdebug.max_nesting_level es fixat a %value."

msgid ""
"Set <code>xdebug.max_nesting_level=@level</code> in your PHP "
