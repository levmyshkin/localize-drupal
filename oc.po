msgstr ""
"Aplica las classas al caire de l'afichatge de l'element. causissètz "
"« personalizat… » per dintrar de classas personalizadas."

msgid "Apply custom styles to the element's display wrapper."
msgstr "Aplica d'estils personalizats al drapèl d'afichatge de l'element."

msgid ""
"Enter additional attributes to be added to the element's display "
"wrapper."
msgstr ""
"Inserissètz d'atributs complementaris que seràn aponduts al "
"contengut d'afichatge de l'element."

msgid "Vehicle identification number (VIN)"
msgstr "Número d'identificacion del veïcul (VIN)"

