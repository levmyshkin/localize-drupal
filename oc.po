msgstr "Android mòbil : Manifest"

msgid "Apple Mobile: iTunes App"
msgstr "Apple Mobil: Aplicacion iTunes"

msgid "Apple Mobile: Web App Capable"
msgstr "Apple Mobile: Capable d’aplicacion web"

msgid "Apple Mobile: Web App Status bar color"
msgstr "Apple Mobile: Color de la barra d'estat de l'aplicacion Web"

msgid "Apple Mobile: Web App Title"
msgstr "Apple Mobile: Títol de l'aplicacion web"

msgid "Mobile: Cleartype"
msgstr "Mobil: Cleartype"

msgid "Apple Mobile: Format Detection"
msgstr "Apple Mobile: Deteccion del format"

msgid "Mobile: Handheld-Friendly"
msgstr "Mòbil : Adaptat als aparelhs de man"

