msgstr "Memòria cau de la mapa de previsualizacion de la tipografia"

msgid "Font filepath"
msgstr "Camin del fichièr de la polida"

msgid "Font Size in Image Captcha"
msgstr "Taille de la fònt dins Captcha amb imatge"

