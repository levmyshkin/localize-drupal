msgstr "Editar l’efièch %label sus l’estil %style"

msgid "Maintenance mode Retry-After header settings"
msgstr "Paramètres de l'en-tèsta Retry-After del mode de mantenença"

msgid "Minimum value for Retry-After header in seconds"
msgstr "Valor minima per l'entesta Retry-After en segondas"

