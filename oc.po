msgstr "Solucion simpla de pan e zoom per SVG dins HTML."

msgid "Svg-pan-zoom is used by custom options elements."
msgstr "Svg-pan-zoom es utilizat pels elements d’opcions personalizats."

msgid ""
"Provides a webform element for converting HTML or SVG markup into a "
"selectable single or multiple options input."
msgstr ""
"Proporciona un element de formulari web per convertir un marcage HTML "
"o SVG en una entrada seleccionabla amb una sola opcion o multiplas "
"opcions."

msgid "Add custom options"
msgstr "Apondre d’opcions personalizadas"

msgid "Webforms: Custom options"
msgstr "Formularis web: Opcions personalizadas"

msgid "Edit custom options"
msgstr "Modificar las opcions personalizadas"

msgid "Preview custom options"
msgstr "Preveire las opcions personalizadas"

msgid "Duplicate custom options"
msgstr "Opcions personalizadas duplicadas"

msgid "Delete custom options"
msgstr "Escafar las opcions personalizadas"

