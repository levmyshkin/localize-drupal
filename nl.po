msgstr ""
"Genereert menu-link-URL's door de 'entity'-URL-generator te "
"overschrijven."

msgid "Entity URL generator"
msgstr "Entiteits-URL-generator"

msgid "Generates URLs for entity bundles and bundle overrides."
msgstr "Genereert URL’s voor entiteitsbundels en bundeloverschrijvingen."

msgid "Add sitemap"
msgstr "Sitemap toevoegen"

msgid "Garbage collection in the simple_sitemap_views table"
msgstr "Garbage collection in de tabel simple_sitemap_views"

msgid "Views URL generator"
msgstr "Views-URL-generator"

