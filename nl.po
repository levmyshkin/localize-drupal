msgstr[1] "Weet u zeker dat u verouderde modules wil installeren?"

msgid "Once uninstalled, the %install_profile profile cannot be reinstalled."
msgstr ""
"Als het verwijderd is kan het profiel %install_profile niet opnieuw "
"geïnstalleerd worden."

msgid "Revert all term revisions"
msgstr "Alle revisies van een term terugzetten"

