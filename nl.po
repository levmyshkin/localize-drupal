msgid "Event date/time"
msgstr "Datum/tijd van gebeurtenis"

msgid "Maximum number of registrants"
msgstr "Maximumaantal registranten"

msgid "Demo: Event Registration"
msgstr "Demo: Evenementregistratie"

msgid "A demonstration of an event registration form."
msgstr "Een demonstratie van een evenementregistratieformulier."

msgid "Demo: Region Contact"
msgstr "Demo: Contactregio"

