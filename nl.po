msgid "Edit custom options"
msgstr "Aangepaste opties bewerken"

msgid "Preview custom options"
msgstr "Voorbeeld van aangepaste opties"

msgid "Duplicate custom options"
msgstr "Dubbele aangepaste opties"

msgid "Delete custom options"
msgstr "Aangepaste opties verwijderen"

msgid "Type of custom options"
msgstr "Type aangepaste opties"

msgid "HTML/SVG markup"
msgstr "HTML/SVG opmaak"

msgid "HTML/SVG URL"
msgstr "HTML/SVG-URL"

