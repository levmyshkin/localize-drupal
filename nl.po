msgid ""
"This screencast introduces you to the maintainer and community behind "
"the Webform module."
msgstr ""
"In deze screencast maak je kennis met de maintainer en de community "
"achter de Webform-module."

msgid "Where is the Drupal Community? | Drupal.org"
msgstr "Waar is de Drupal-community? | Drupal.org"

msgid "Contributing to Drupal | Drupalize.me"
msgstr "Bijdragen aan Drupal | Drupalize.me"

msgid "Concept: The Drupal Project | Drupalize.me"
msgstr "Concept: Het Drupal-project | Drupalize.me"

msgid "Extending Drupal 8 | Drupal.org"
msgstr "Drupal 8 uitbreiden | Drupal.org"

msgid "Installing a Module | Drupalize.me"
msgstr "Een module installeren | Drupalize.me"

msgid "Form API | Drupal.org"
msgstr "Form API | Drupal.org"

