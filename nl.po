msgstr "Het installatieprofiel '@profile_name' vereist '@module_name'"

msgid ""
"Ideal for exact counts and measures (prices, temperatures, distances, "
"volumes, etc.)"
msgstr ""
"Ideaal voor exacte getallen en maten (prijs, temperatuur, afstand, "
"inhoud, enz.)"

