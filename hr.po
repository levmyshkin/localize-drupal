msgstr "hoverIntent timeout"

msgid "Hide Toolbar (Alt+p)"
msgstr "Sakrij alatnu traku (Alt+p)"

msgid "Toolbar sticky behavior"
msgstr "Ljepljivo ponašanje alatne trake"

msgid "Toolbar hoverIntent behavior"
msgstr "Ponašanje hoverIntent na alatnoj traci"

