msgstr "%label se koristi u sljedećem/navednom obrascu/obrazcima."

msgid "Delete all related submissions"
msgstr "Izbriši sve povezane prijave"

msgid "Affect any fields or nodes which reference this webform"
msgstr ""
"Utječe na bilo koja polja ili čvorove koji referenciraju ovaj web "
"obrazac"

msgid "Affect any elements which use these options"
msgstr "Utječe na sve elemente koji koriste ove opcije"

