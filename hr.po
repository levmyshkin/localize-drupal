msgstr ""
"Opcije %title su prilagođene. Poništavanjem dolje navedenih opcija "
"omogućit ćete %module_names @module da dinamički popuni ove opcije."

msgid ""
"Accepts any date in any <a "
"href=\"https://www.gnu.org/software/tar/manual/html_chapter/tar_7.html#Date-input-formats\">GNU "
