msgstr "@level - visoka"

msgid "No TrueType support"
msgstr "Nema podrške za TrueType"

msgid ""
"The Image CAPTCHA module can not use TrueType fonts because your PHP "
"setup does not support it. You can only use a PHP built-in bitmap font "
"of fixed size."
msgstr ""
"Modul Image CAPTCHA ne može koristiti TrueType fontove jer vaša PHP "
"konfiguracija to ne podržava. Možete koristiti samo ugrađeni PHP "
"bitmap font fiksne veličine."

