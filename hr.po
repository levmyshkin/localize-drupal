msgstr ""
"Filtriraj sadržaj prema pristupu prikazu. <strong>Nije potrebno ako "
"koristite čvor kao svoju osnovnu tablicu.</strong>"

msgid "Show a marker if the content is new or updated."
msgstr "Prikaži oznaku ako je sadržaj nov ili ažuriran."

msgid "Show only content that is new or updated."
msgstr "Prikaži samo sadržaj koji je nov ili ažuriran."

