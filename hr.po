msgstr "Drush nije uspio preuzeti biblioteku colorbox s @remote. @exception"

msgid "Error: unable to unzip colorbox file."
msgstr "Pogreška: nije moguće raspakirati datoteku colorbox."

msgid "The colorbox library has been successfully downloaded to @path."
msgstr "Biblioteka colorbox je uspješno preuzeta na @path."

