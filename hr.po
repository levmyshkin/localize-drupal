"Controls the color of the Back and Forward buttons in the pinned site "
"browser window."
msgstr ""
"Upravlja bojom tipki Natrag i Naprijed u prozoru preglednika za "
"prikačenu stranicu."

msgid "MSApplication - Notification"
msgstr "MSApplication - Obavijest"

msgid "MSApplication - Square logo, 150px x 150px"
msgstr "MSApplication - Kvadratni logotip, 150px x 150px"

msgid "MSApplication - Square logo, 310px x 310px"
msgstr "MSApplication - Kvadratni logo, 310px x 310px"

