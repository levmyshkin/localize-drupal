msgstr ""
"Sljedeći podmoduli web obrasca su zastarjeli: @module_list. Molimo "
"preuzmite <a href=\":url\">Webform Deprecated</a> projekt."

msgid ""
"@element_file_limit limit per file. The accumulated size of all files "
