msgid ""
"Ideal when date and time needs to be input by users, like event dates "
"and times"
msgstr ""
"Idealno kada korisnici trebaju unijeti datum i vrijeme, poput datuma i "
"vremena događaja"

msgid "Date or date and time stored in a readable string format"
msgstr "Datum ili datum i vrijeme pohranjeni u čitljivom formatu niza"

