msgstr ""
"Morate omogućiti korisnicima slanje prijava s namjenskog URL-a kako "
"bi se ova webforma otvorila kao dijalog."

msgid "Please delete submissions from the selected webforms."
msgstr "Molimo izbrišite prijave s odabranih web-obrazaca."

msgid "The selected webforms have a total of @total submissions."
msgstr "Odabrani web obrasci imaju ukupno @total prijava."

msgid ""
"You may not delete these webforms until there is less than @batch "
"total submissions."
msgstr ""
"Ne smijete izbrisati ove web obrasce dok ukupno nema manje od @batch "
"prijava."

