msgstr "Stilovi responzivnih slika"

msgid "Edit responsive image style"
msgstr "Uredi stil responzivne slike"

msgid "Add responsive image style"
msgstr "Dodaj stil responzivne slike"

msgid "Image style mappings"
msgstr "Mapa stilova slike"

