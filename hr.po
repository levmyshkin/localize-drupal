msgid "…when <b>submission is locked</b>."
msgstr "…kada je <b>predaja zaključana</b>."

msgid "Post data when <b>submission is completed</b>."
msgstr "Pošalji podatke kada je <b>predaja dovršena</b>."

msgid "Post data when <b>submission is updated</b>."
msgstr "Pošalji podatke kada je <b>predaja ažurirana</b>."

