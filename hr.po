msgstr ""
"Datum i vrijeme pohranjeni u obliku sekundi od 1. siječnja 1970. "
"(UTC)"

msgid "Compact and efficient for storage, sorting and calculations"
msgstr "Kompaktan i učinkovit za pohranu, sortiranje i izračune"

