"Note: This is only to be used with the Drupal Bootstrap Theme, NOT "
"with other Bootstrap Framework related Themes (like Radix)."
msgstr ""
"Napomena: Ovo se koristi samo s Drupal Bootstrap Temom, NE s drugim "
"Temama vezanim uz Bootstrap Framework (kao što je Radix)."

msgid "Send on (date / datetime string or [token])"
msgstr "Pošalji na (datum / niz datuma i vremena ili [token])"

