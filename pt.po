msgstr "Notificação IndexNow ativada"

msgid "IndexNow notification disabled"
msgstr "Notificação IndexNow desativada"

msgid "IndexNow"
msgstr "IndexNow"

msgid "Simple XML Sitemap IndexNow"
msgstr "Índice Simples XML Sitemap IndexNow"

