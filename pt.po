msgstr ""
"Nota: Isto deve ser usado apenas com o Tema Drupal Bootstrap, NÃO com "
"outros temas relacionados ao Framework Bootstrap (como Radix)."

msgid "Send on (date / datetime string or [token])"
msgstr "Enviar em (data / string de data e hora ou [token])"

