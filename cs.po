msgstr "@backend nastavení připojení"

msgid "Change connection type"
msgstr "Změnit typ připojení"

msgid "Site under maintenance"
msgstr "Údržba webu"

msgid "Completed @current of @total."
msgstr "Dokončeno @current z @total."

