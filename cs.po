msgstr ""
"Tato hodnota by měla odpovídat komponentě hostitele URI podle RFC "
"3986."

msgid "The UUID of the uploaded file."
msgstr "UUID nahraného souboru."

msgctxt "Validation"
msgid "File encoding"
msgstr "Kódování souboru"

