msgstr "Non é un éxito, pero non se recibiron códigos de erro!"

msgid "The challenge response timed out or was already verified."
msgstr "A resposta de reto expirou ou xa foi verificada."

msgid "Use reCAPTCHA globally"
msgstr "Usar reCAPTCHA globalmente"

