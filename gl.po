msgstr "Elixa a acción a realizar."

msgid ""
"Invalid action argument \"@invalid_action\". Please use one of: "
"@valid_actions"
msgstr ""
"Argumento de acción non válido \"@invalid_action\". Empregue un dos "
"seguintes: @valid_actions"

