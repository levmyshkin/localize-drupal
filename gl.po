msgstr "<strong>@title</strong> (Instalado)"

msgid ""
"The <a href=\":homepage_href\">@title</a> library is installed by the "
"<b><a href=\":module_href\">@module</a></b> module."
msgstr ""
"A biblioteca <a href=\":homepage_href\">@title</a> está instalada "
"polo módulo <b><a href=\":module_href\">@module</a></b>."

