msgstr ""
"Tipo de argumento inválido \"@invalid_types\". Por favor, elixa entre "
"os seguintes: @valid_types"

msgid "Generate a URL alias for un-aliased paths only."
msgstr "Xerar un alias de URL só para rutas sen alias."

