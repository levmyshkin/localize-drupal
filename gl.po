msgid "Default delete button label"
msgstr "Etiqueta do botón de eliminación predeterminada"

msgid ""
"Check if Webform Clientside Validation module is installed when using "
"the Clientside Validation module"
msgstr ""
"Comproba se o módulo Webform Clientside Validation está instalado "
"cando se utiliza o módulo Clientside Validation"

