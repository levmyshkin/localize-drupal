msgstr "Leiti vananenud moodulid: %module_list."

msgid "Deprecated themes found: %theme_list."
msgstr "Leitud aegunud teemasid: %theme_list."

msgid "Database support for JSON"
msgstr "Andmebaasi tugi JSON-ile"

msgid "Non-stable modules"
msgstr "Stabiilsed moodulid"

msgid "@lifecycle"
msgstr "@elutsükkel"

