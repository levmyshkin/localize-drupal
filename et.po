msgstr "Kontrollitud %langcode tõlge projektile %project."

msgid "Downloaded %langcode translation for %project."
msgstr "Laaditi alla %project %langcode tõlge."

msgid "Importing %langcode translation for %project."
msgstr "Imporditakse %langcode tõlget projektile %project."

