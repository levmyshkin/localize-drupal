msgstr ""
"Этот @name находится в состоянии "
"<strong>@state</strong>"

msgid "when <strong>@logic</strong> of the following conditions are met:"
msgstr ""
"когда выполняется <strong>@logic</strong> из "
"следующих условий:"

msgid ""
"When <strong>@logic</strong> of the following (nested) conditions are "
"met:"
msgstr ""
"Когда выполняется <strong>@logic</strong> "
"следующих (вложенных) условий:"

