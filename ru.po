msgstr ""
"%bundle_label <span class=\"description\">(карты сайта: "
"%sitemaps)</span>"

msgid "Configure %label entity type"
msgstr "Настроить тип сущности %label"

msgid "IndexNow notification enabled"
msgstr "Уведомления IndexNow включены"

msgid "IndexNow notification disabled"
msgstr "Уведомления IndexNow отключены"

msgid "IndexNow"
msgstr "IndexNow"

msgid "Simple XML Sitemap IndexNow"
msgstr "Простой XML Sitemap IndexNow"

msgid "Verification key in Drupal State"
msgstr "Ключ проверки в состоянии Drupal"

msgid "Verification key not available"
msgstr "Ключ подтверждения недоступен"

msgid ""
"In order to generate a verification key for the IndexNow service and "
"choose which sitemaps are to be submitted to search engines, visit <a "
"href=\"@url\">this</a> configuration page."
msgstr ""
"Чтобы создать ключ проверки для "
"сервиса IndexNow и выбрать, какие карты "
"сайта нужно отправлять в поисковые "
"системы, перейдите на <a href=\"@url\">эту</a> "
"страницу настроек."

msgid ""
"Submits sitemaps to search engines and notifies IndexNow compatible "
"engines about changes to entities."
msgstr ""
"Отправляет карты сайта в поисковые "
"системы и уведомляет совместимые с "
"IndexNow поисковые системы об изменениях "
"в сущностях."

msgid "Index entity on save"
msgstr ""
"Индексировать сущность при "
"сохранении"

msgid ""
"Allows optionally sending a change notice to IndexNow compatible "
"search engines on entity form save."
msgstr ""
"Позволяет по желанию отправлять "
"уведомление об изменениях в поисковые "
"системы, совместимые с IndexNow, при "
"сохранении формы сущности."

msgid "IndexNow URL"
msgstr "URL IndexNow"

msgid "IndexNow bundle settings"
msgstr "Настройки набора IndexNow"

msgid "IndexNow submission enabled"
msgstr "Отправка через IndexNow включена"

msgid "Selected engine for IndexNow submissions"
msgstr ""
"Выбранный механизм для отправки "
"данных в IndexNow"

msgid "IndexNow on entity save"
msgstr "IndexNow при сохранении сущности"

msgid "No search engines supporting sitemap submission have been found."
msgstr ""
"Не найдено ни одной поисковой системы, "
"поддерживающей отправку карты сайта."

msgid "Sitemap submission is disabled."
msgstr "Отправка карты сайта отключена."

msgid ""
"The last IndexNow submission was <em>@entity</em> to @engine_label on "
"@time"
msgstr ""
"Последняя отправка в IndexNow была "
"<em>@entity</em> в @engine_label в @time"

msgid "IndexNow settings can be configured <a href=\"@url\">here</a>."
msgstr ""
"Настройки IndexNow можно настроить <a "
"href=\"@url\">здесь</a>."

msgid "No search engines supporting IndexNow have been found."
msgstr ""
"Не найдено ни одной поисковой системы, "
"поддерживающей IndexNow."

msgid "IndexNow submission is disabled."
msgstr "Отправка в IndexNow отключена."

msgid "Notify IndexNow search engines of changes <em>by default</em>"
msgstr ""
"Уведомлять поисковые системы IndexNow об "
"изменениях <em>по умолчанию</em>"

msgid "Notify IndexNow search engines of changes <em>now</em>"
msgstr ""
"Уведомить поисковые системы IndexNow об "
"изменениях <em>прямо сейчас</em>"

msgid ""
"Send change notice to IndexNow compatible search engines right after "
"submitting entity forms of this type.<br/>Changes include creating, "
"deleting and updating of an entity. This setting can be overridden on "
"the entity form."
msgstr ""
"Отправлять уведомление об изменениях "
"в совместимые с IndexNow поисковые "
"системы сразу после отправки форм "
"сущности этого типа.<br/>Изменения "
"включают создание, удаление и "
"обновление сущности. Этот параметр "
"можно переопределить в форме "
"сущности."

msgid ""
"Send change notice to IndexNow compatible search engines right after "
"submitting this form."
msgstr ""
"Отправлять уведомление об изменении в "
"совместимые с IndexNow поисковые системы "
"сразу после отправки этой формы."

msgid "Sitemap submission settings"
msgstr "Настройки отправки карты сайта"

msgid "Submit sitemaps to search engines"
msgstr ""
"Отправить карты сайта в поисковые "
"системы"

msgid "IndexNow settings"
msgstr "Настройки IndexNow"

msgid "Submit changes to IndexNow capable engines"
msgstr ""
"Отправить изменения в поисковые "
"системы, поддерживающие IndexNow"

msgid "Preferred IndexNow engine"
msgstr ""
"Предпочтительный поисковый движок "
"IndexNow"

msgid ""
"All IndexNow requests will be sent to the engine selected here. Only "
"one engine needs to be notified, as it will notify other IndexNow "
"compatible engines for you.<br/>For the sake of equality of "
"opportunity, <strong>consider leaving this at "
"<em>Random</em></strong>, so a random engine can be picked on each "
"submission."
msgstr ""
"Все запросы IndexNow будут отправляться в "
"выбранный здесь поисковик. Достаточно "
"уведомить только один поисковик — он "
"сам уведомит остальные поисковики, "
"совместимые с IndexNow, за вас.<br/>Ради "
"равенства возможностей "
"<strong>рекомендуем оставить значение "
"<em>Random</em></strong>, чтобы при каждой "
"отправке выбирался случайный "
"поисковик."

msgid "Index on every entity save operation"
msgstr ""
"Индексировать при каждом сохранении "
"сущности"

msgid ""
"If checked, all entity save operations for <a "
"href=\"@inclusion_url\">included entities</a> will trigger "
"notification of IndexNow search engines.<br/>If unchecked, this will "
"only be possible by adding/altering/deleting an entity through a "
"form.<br/>This should be unchecked if there are mass operations "
"performed on entities that are irrelevant to indexing."
msgstr ""
"Если отмечено, все операции "
"сохранения сущностей для <a "
"href=\"@inclusion_url\">включённых сущностей</a> "
"будут инициировать отправку "
"уведомления поисковым системам "
"IndexNow.<br/>Если не отмечено, это будет "
"возможно только при "
"добавлении/изменении/удалении "
"сущности через форму.<br/>Это следует "
"отключить, если выполняются массовые "
"операции над сущностями, не имеющими "
"отношения к индексации."

msgid ""
"The IndexNow verification key is saved in <em>Drupal state</em>. "
"Consider defining it in <em>settings.php</em> like so:<br/>@code"
msgstr ""
"Ключ подтверждения IndexNow сохраняется в "
"<em>Drupal state</em>. Рекомендуем задать его в "
"<em>settings.php</em> следующим образом:<br/>@code"

msgid ""
"An IndexNow verification key needs to be generated and optionally "
"added to <em>settings.php</em> in order for IndexNow engines to get "
"notified about changes. This warning only applies to the production "
"environment."
msgstr ""
"Ключ верификации IndexNow необходимо "
"сгенерировать и при необходимости "
"добавить в <em>settings.php</em>, чтобы "
"поисковые системы, поддерживающие "
"IndexNow, получали уведомления об "
"изменениях. Это предупреждение "
"относится только к производственной "
"среде."

msgid ""
"Simple XML Sitemap settings will be added only to entity forms of "
"entity types enabled here. Settings for specific entity bundles (e.g. "
"<em>page</em>) can be adjusted here or on the bundle pages."
msgstr ""
"Настройки Simple XML Sitemap будут добавлены "
"только в формы сущностей тех типов "
"сущностей, которые включены здесь. "
"Настройки для конкретных бандлов "
"сущностей (например, <em>page</em>) можно "
"изменить здесь или на страницах "
"бандлов."

msgid "Simple XML Sitemap settings"
msgstr "Настройки Simple XML Sitemap"

msgid ""
"A sitemap index which lists all other sitemaps is now available and "
"can be enabled."
msgstr ""
"Индекс карты сайта, содержащий список "
"всех остальных карт сайта, теперь "
"доступен и может быть включён."

msgid "IndexNow notification"
msgstr "Уведомление IndexNow"

msgid "IndexNow notification checkbox"
msgstr "Флажок уведомления IndexNow"

msgid "Remove verification key from state"
msgstr "Удалить ключ проверки из состояния"

msgid "Generate verification key"
msgstr "Сгенерировать ключ подтверждения"

msgid "The IndexNow verification key is saved in <em>settings.php</em>: @key"
msgstr ""
"Ключ верификации IndexNow сохранён в "
"<em>settings.php</em>: @key"

msgid ""
"The IndexNow verification key is defined in <em>Drupal state</em>: "
"@key"
msgstr ""
"Ключ проверки IndexNow задан в "
"<em>состоянии Drupal</em>: @key"

msgid ""
"The IndexNow verification key is saved in <em>settings.php</em> and "
"can be safely removed from <em>Drupal state</em>."
msgstr ""
"Ключ проверки IndexNow сохраняется в "
"<em>settings.php</em>, поэтому его можно "
"безопасно удалить из <em>состояния "
"Drupal</em>."

msgid "Include this sitemap during generation"
msgstr ""
"Включить эту карту сайта при "
"генерации"

msgid ""
"Do not index entities of type <em>@bundle</em> in sitemap "
"<em>@sitemap</em>"
msgstr ""
"Не индексировать сущности типа "
"<em>@bundle</em> в карте сайта <em>@sitemap</em>"

msgid "Index entities of type <em>@bundle</em> in sitemap <em>@sitemap</em>"
msgstr ""
"Индексировать сущности типа <em>@bundle</em> "
"в карте сайта <em>@sitemap</em>"

msgid "Do not index this <em>@bundle</em> entity in sitemap <em>@sitemap</em>"
msgstr ""
"Не индексировать тип сущности "
"<em>@bundle</em> в карте сайта <em>@sitemap</em>"

msgid "Index this <em>@bundle</em> entity in sitemap <em>@sitemap</em>"
msgstr ""
"Индексировать тип сущности <em>@bundle</em> в "
"карте сайта <em>@sitemap</em>"

msgid "Do not index entities of this type in sitemap <em>@sitemap</em>"
msgstr ""
"Не индексировать сущности этого типа "
"в карте сайта <em>@sitemap</em>"

msgid "Index entities of this type in sitemap <em>@sitemap</em>"
msgstr ""
"Индексировать сущности этого типа в "
"карте сайта <em>@sitemap</em>"

msgid "Generates an index of your sitemaps."
msgstr "Создаёт индекс ваших файлов sitemap."

msgid "Sitemap URL generator"
msgstr "Генератор URL для карты сайта"

msgid "Generates sitemap URLs for a sitemap index."
msgstr ""
"Генерирует URL-адреса карты сайта для "
"индекса карты сайта."

msgid "Hide branding"
msgstr "Скрыть брендинг"

msgid ""
"Remove the 'Generated by the Simple XML Sitemap Drupal module' string "
"from the XSL output."
msgstr ""
"Удалите строку «Generated by the Simple XML Sitemap "
"Drupal module» из вывода XSL."

msgid "Generated by the <a href=\"@url\">@module_name</a> Drupal module."
msgstr ""
"Сгенерировано модулем Drupal <a "
"href=\"@url\">@module_name</a>."

msgid "Add custom internal drupal paths to specific sitemaps."
msgstr ""
"Добавляйте пользовательские "
"внутренние пути Drupal в определённые "
"файлы sitemap."

msgid ""
"Specify drupal internal (relative) paths, one per line. Do not forget "
"to prepend the paths with a '/'.<br>Optionally link priority <em>(0.0 "
"- 1.0)</em> can be added by appending it after a space.<br> Optionally "
"link change frequency <em>(always / hourly / daily / weekly / monthly "
"/ yearly / never)</em> can be added by appending it after a space."
msgstr ""
"Укажите внутренние (относительные) "
"пути Drupal — по одному в строке. Не "
"забудьте добавить в начале пути "
"«/».<br>При необходимости можно указать "
"приоритет ссылки <em>(0.0 – 1.0)</em>, добавив "
"его после пробела.<br>При необходимости "
"можно указать частоту изменения "
"ссылки <em>(always / hourly / daily / weekly / monthly / yearly "
"/ never)</em>, добавив её после пробела."

msgid ""
"<strong>Examples:</strong><br><em>/ 1.0 daily</em> -> home page with "
"the highest priority and daily change frequency<br><em>/contact</em> "
"-> contact page with the default priority and no change frequency "
"information"
msgstr ""
"<strong>Примеры:</strong><br><em>/ 1.0 ежедневно</em> "
"-> главная страница с наивысшим "
"приоритетом и ежедневной частотой "
"обновления<br><em>/contact</em> -> страница "
"контактов со стандартным приоритетом "
"и без информации о частоте обновления"

msgid ""
"<strong>@sitemap, line @line</strong>: The path <em>@path</em> does "
"not exist."
msgstr ""
"<strong>@sitemap, line @line</strong>: Путь <em>@path</em> не "
"существует."

msgid ""
"<strong>@sitemap, line @line</strong>: The path <em>@path</em> needs "
"to start with a '/'."
msgstr ""
"<strong>@sitemap, line @line</strong>: Путь <em>@path</em> "
"должен начинаться с «/»."

msgid ""
"<strong>@sitemap, line @line</strong>: The priority setting "
"<em>@priority</em> for path <em>@path</em> is incorrect. Set the "
"priority from 0.0 to 1.0."
msgstr ""
"<strong>@sitemap, line @line</strong>: Значение "
"приоритета <em>@priority</em> для пути <em>@path</em> "
"задано некорректно. Укажите приоритет "
"в диапазоне от 0.0 до 1.0."

msgid ""
"<strong>@sitemap, line @line</strong>: The changefreq setting "
"<em>@changefreq</em> for path <em>@path</em> is incorrect. The "
"following are the correct values: <em>@changefreq_options</em>."
msgstr ""
"<strong>@sitemap, line @line</strong>: Значение "
"параметра changefreq <em>@changefreq</em> для пути "
"<em>@path</em> указано неверно. Допустимые "
"значения: <em>@changefreq_options</em>."

msgid "There are no languages other than the default language available."
msgstr ""
"Кроме языка по умолчанию, других "
"языков нет."

msgid "The sitemaps need to be regenerated."
msgstr ""
"Карты сайта нужно сгенерировать "
"заново."

msgid "Sitemap submission status (ping protocol)"
msgstr ""
"Статус отправки карты сайта (протокол "
"ping)"

msgid ""
"Submission settings can be configured <a "
"href=\"@url\">here</a>.<br/>The ping protocol is <strong>being "
"deprecated</strong>, use IndexNow if applicable."
msgstr ""
"Параметры отправки можно настроить <a "
"href=\"@url\">здесь</a>.<br/>Протокол ping "
"<strong>устаревает</strong>; если возможно, "
"используйте IndexNow."

msgid "Page submission status (IndexNow protocol)"
msgstr ""
"Статус отправки страницы (протокол "
"IndexNow)"

msgid ""
"This enables/disables sitemap submission; don't forget to choose "
"sitemaps below.<br/>The ping protocol is <strong>being "
"deprecated</strong>, use IndexNow if applicable."
msgstr ""
"Это включает/отключает отправку карты "
"сайта; не забудьте выбрать карты сайта "
"ниже.<br/>Протокол ping "
"<strong>устаревает</strong>; при возможности "
"используйте IndexNow."

msgid ""
"Generates URLs from data sets collected in the "
"hook_simple_sitemap_arbitrary_links_alter hook."
msgstr ""
"Генерирует URL-адреса из наборов "
"данных, собранных в хуке "
"hook_simple_sitemap_arbitrary_links_alter."

