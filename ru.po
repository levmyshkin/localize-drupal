msgstr "Пользовательские параметры Webform"

msgid "custom options"
msgstr "пользовательские параметры"

msgid "Filter custom options"
msgstr "Пользовательские параметры фильтра"

msgid "Show all custom options"
msgstr ""
"Показать все пользовательские "
"параметры"

msgid "(Entity reference)"
msgstr "(Ссылка на сущность)"

msgid "Option text / description"
msgstr "Текст опции / описание"

msgid "Custom element"
msgstr "Пользовательский элемент"

msgid ""
"Provides a form element for creating custom options using HTML and SVG "
"markup."
msgstr ""
"Предоставляет элемент формы для "
"создания пользовательских опций с "
"использованием разметки HTML и SVG."

msgid "Custom elements"
msgstr "Пользовательские элементы"

msgid "Custom entity reference"
msgstr "Пользовательская ссылка на сущность"

msgid ""
"Provides a form element for creating custom options using HTML and SVG "
"markup with entity references."
msgstr ""
"Предоставляет элемент формы для "
"создания пользовательских опций с "
"использованием HTML- и SVG-разметки и "
"ссылок на сущности."

msgid ""
"Webform module supports creating custom elements using HTML and SVG "
