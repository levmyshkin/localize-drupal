msgstr ""
"Детали учётной записи [user:display-name] на "
"сайте «[site:name]» (ожидает одобрения "
"администратором)"

msgid ""
"[user:display-name] has applied for an account.\n"
"\n"
"[user:edit-url]"
msgstr ""
"[user:display-name] подал заявку на получение "
"учётной записи.\r\n"
"\r\n"
"[user:edit-url]"

