msgstr ""
"Пользовательские параметры можно "
"обновить только через <a "
"href=\":href\">исходный YAML-файл</a>."

msgid "Custom options can only be updated via the YAML source."
msgstr ""
"Пользовательские параметры можно "
"обновлять только через исходный "
"YAML-файл."

msgid "every @increment seconds"
msgstr "каждые @increment секунд"

