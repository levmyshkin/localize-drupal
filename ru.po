msgid "Selection criteria"
msgstr "Критерий выбора"

msgid "Bulk generate"
msgstr "Массовая генерация"

msgid "Selection logic"
msgstr "Логика выбора"

msgid "Pattern type"
msgstr "Тип шаблона"

msgid "Delete options"
msgstr "Опции удаления"

