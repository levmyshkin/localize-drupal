"states:\n"
"  '#type': 'webform_options_custom:us_states'\n"
"  '#title': "
"'U.S. States'\n"
"  '#required': true\n"
"button:\n"
"  '#type': "
"'webform_options_custom:buttons'\n"
"  '#title': 'Buttons'\n"
"  "
"'#required': true\n"
"  '#options':\n"
"    one: One -- This is the number "
"1.\n"
"    two: Two -- This is the number 2.\n"
"    three:  Three -- This "
"is the number 3.\n"
""
