msgstr ""
"Разрешает просмотр <em>собственных</em> "
"отправленных данных для всех веб-форм."

msgid "Allows updating <em>own</em> submissions for all webforms."
msgstr ""
"Разрешает обновлять <em>свои</em> "
"отправленные данные для всех веб-форм."

msgid "Allows deleting <em>own</em> submissions for all webforms."
msgstr ""
"Разрешает удалять <em>свои</em> "
"отправленные данные для всех веб-форм."

