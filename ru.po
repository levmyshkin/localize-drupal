msgstr[1] "@count ссылки"

msgid "Configuration: Custom options"
msgstr ""
"Конфигурация: Пользовательские "
"параметры"

msgid ""
"The <strong>Custom options configuration</strong> page lists reusable "
"HTML/SVG custom options elements."
msgstr ""
"Страница <strong>Настройка "
"пользовательских опций</strong> содержит "
"список повторно используемых "
"элементов пользовательских опций "
"HTML/SVG."

msgid "SVG Pan & Zoom"
msgstr "Панорамирование и масштабирование SVG"

msgid "Simple pan/zoom solution for SVGs in HTML."
msgstr ""
"Простое решение для панорамирования и "
"масштабирования SVG в HTML."

msgid "Svg-pan-zoom is used by custom options elements."
msgstr ""
"Svg-pan-zoom используется "
"пользовательскими элементами опций."

msgid ""
"Provides a webform element for converting HTML or SVG markup into a "
"selectable single or multiple options input."
msgstr ""
"Предоставляет элемент webform для "
"преобразования HTML- или SVG-разметки в "
"поле ввода с выбором одного или "
"нескольких вариантов."

msgid "Add custom options"
msgstr "Добавить пользовательские параметры"

msgid "Webforms: Custom options"
msgstr "Веб-формы: пользовательские параметры"

msgid "Edit custom options"
msgstr ""
"Редактировать пользовательские "
"параметры"

msgid "Preview custom options"
msgstr ""
"Предпросмотр пользовательских "
"параметров"

msgid "Duplicate custom options"
msgstr ""
"Дублировать пользовательские "
"параметры"

msgid "Delete custom options"
msgstr "Удалить пользовательские параметры"

msgid "Type of custom options"
msgstr "Тип пользовательских опций"

msgid "HTML/SVG markup"
msgstr "HTML/SVG-разметка"

msgid "HTML/SVG URL"
msgstr "HTML/SVG URL"

msgid "Option text attribute names"
msgstr "Названия атрибутов текста опций"

