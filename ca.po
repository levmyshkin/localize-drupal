msgstr "Un booleà que indica si aquesta traducció necessita ser actualitzada"

msgid "JSON:API allowed operations"
msgstr "Operacions permeses del JSON:API"

msgid "All (create, read, update, delete)"
msgstr "Tots (crear, llegir, actualitzar, eliminar)"

