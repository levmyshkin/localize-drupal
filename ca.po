msgstr "Gestió dels comptes d’usuari i dels visitants del lloc"

msgid "Modifying the permissions for a role"
msgstr "Modificant els permisos d’un rol"

msgid "Configuring how user accounts are created and deleted"
msgstr "Configuració de com es creen i s'eliminen els comptes d'usuari"

msgid "Modifying or deleting a user account"
msgstr "Modificar o eliminar un compte d'usuari"

