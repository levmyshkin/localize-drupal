msgid "Enabling and disabling maintenance mode"
msgstr "Activar i desactivar el mode de manteniment"

msgid "Installing a module"
msgstr "Instal·lació d’un mòdul"

msgid "Uninstalling a module"
msgstr "Desinstal·lar un mòdul"

msgid "Running reports on your site"
msgstr "Executant informes al vostre lloc web"

msgid "Installing a theme and setting default themes"
msgstr "Instal·lant un tema i configurant els temes predeterminats"

msgid "Uninstalling an unused theme"
msgstr "Desinstal·lar un tema no utilitzat"

