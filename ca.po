msgstr "Executar i configurar cron"

msgid "Extending and modifying your site functionality"
msgstr "Ampliant i modificant la funcionalitat del vostre lloc"

msgid "Maintaining and troubleshooting your site"
msgstr "Manteniment i resolució de problemes del vostre lloc"

