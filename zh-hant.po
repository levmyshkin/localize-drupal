msgstr "支援 JSON 的資料庫"

msgid "Non-stable modules"
msgstr "非穩定模組"

msgid "@lifecycle"
msgstr "@lifecycle"

msgid "View information on the @lifecycle status of the module @module"
msgstr "檢視模組 @module 的 @lifecycle 狀態資訊"

