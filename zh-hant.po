msgstr "Android 行動裝置：Android 應用程式連結替代方案"

msgid "Android Mobile: Manifest"
msgstr "Android 行動版：資訊清單 (Manifest)"

msgid "Apple Mobile: iTunes App"
msgstr "Apple 行動裝置：iTunes App"

msgid "Apple Mobile: Web App Capable"
msgstr "Apple 行動裝置：可作為網頁應用程式使用"

msgid "Apple Mobile: Web App Status bar color"
msgstr "Apple 行動裝置：Web App 狀態列顏色"

msgid "Apple Mobile: Web App Title"
msgstr "Apple 行動裝置：網頁 App 標題"

msgid "Mobile: Cleartype"
msgstr "行動版：Cleartype"

