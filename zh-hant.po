msgstr "在網站地圖 <em>@sitemap</em> 中索引此類型的實體"

msgid "Generates an index of your sitemaps."
msgstr "生成網站地圖索引。"

msgid "Sitemap URL generator"
msgstr "網站地圖 URL 產生器"

