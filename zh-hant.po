msgid "Add Pathauto pattern"
msgstr "新增 Pathauto 路徑別名模式"

msgid "Pathauto pattern config"
msgstr "Pathauto 路徑自動化模式設定"

msgid "Pathauto state"
msgstr "Pathauto 狀態"

msgid "Whether an automated alias should be created or not."
msgstr "是否應建立自動化別名。"

