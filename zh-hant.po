msgstr "管理 reCAPTCHA"

msgid "Normal (default)"
msgstr "一般（預設）"

msgid "Light (default)"
msgstr "淺色（預設）"

msgid "The type of CAPTCHA to serve."
msgstr "要提供的 CAPTCHA 類型。"

