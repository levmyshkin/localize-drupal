msgstr ""
"用於控制此 Webform "
"是否應開放或關閉，以停止接受新的提交內容的旗標。"

msgid "A webform containing default submission values."
msgstr "包含預設提交值的 Webform。"

msgid "Webform PHP mailer"
msgstr "Webform PHP 郵件寄送器"

