msgid "Default file upload limit per form"
msgstr "Standard grense for filopplasting per skjema"

msgid "Invoked @id: @class_name:@method_name @context1"
msgstr "Kjørt @id: @class_name:@method_name @context1"

msgid "Example of a webform submission handler."
msgstr "Eksempel på en innsendingbehandler for et webskjema."

msgid ""
"Inline (Displays message when access is denied to field, nodes, and "
"blocks)"
msgstr ""
"Inline (viser melding når tilgang nektes til felt, innholdselementer "
"og blokker)"

msgid ""
"Page (Displays message when access is denied to forms, fields, nodes, "
"and blocks)"
msgstr ""
"Side (Viser melding når tilgang nektes til skjemaer, felt, noder og "
"blokker)"

msgid ""
"Login (Redirects to user login form and displays message. Field, "
"nodes, and block only display the message.)"
msgstr ""
"Logg inn (Viderekobler til innloggingsskjemaet for brukere og viser en "
"melding. Felt, noder og blokker viser bare meldingen.)"

msgid ""
"When this container is hidden all this container's subelement values "
"will be cleared."
msgstr ""
"Når denne beholderen er skjult, vil alle verdiene i under­elementene "
"i denne beholderen bli tømt."

msgid "When this element is hidden, this element's value will be cleared."
msgstr ""
"Når dette elementet er skjult, vil verdien for dette elementet bli "
"tømt."

msgid "Input hiding"
msgstr "Skjuling av inndata"

msgid "Hide the input of the element when the input is not being focused."
msgstr "Skjul inndatafeltet til elementet når feltet ikke er i fokus."

msgid "Append the below suffixes to alter the returned value."
msgstr "Legg til suffiksene nedenfor for å endre den returnerte verdien."

msgid "<code>:urlencode</code> URL encodes returned value."
msgstr "<code>:urlencode</code> URL-koder den returnerte verdien."

msgid "Submission exclude empty elements"
msgstr "Innsending: ekskluder tomme elementer"

msgid "Submission exclude unselected checkboxes"
msgstr "Innsending: ekskluder uvalgte avkrysningsbokser"

msgid "@source_entity: @webform"
msgstr "@source_entity: @webform"

msgid ""
"Select how the form's title is displayed when this webform is attached "
"to a source entity. This title is only displayed when a webform is "
"linked to from a source entity or opened in dialog."
msgstr ""
"Velg hvordan skjemaets tittel skal vises når dette nettskjemaet er "
"knyttet til en kildeentitet. Denne tittelen vises bare når et "
"nettskjema er lenket fra en kildeentitet eller åpnes i en dialog."

msgid "Source entity: Webform"
msgstr "Kildeentitet: Webform"

msgid "Webform: Source entity"
msgstr "Webform: Kildeentitet"

msgid "Included submission values"
msgstr "Inkluderte innsendingsverdier"

msgid ""
"If you wish to include only parts of the submission when viewing as "
"HTML, table, or plain text, select the elements that should be "
"included. Please note, element specific access controls are still "
"applied to displayed elements."
msgstr ""
"Hvis du ønsker å inkludere bare deler av innsendingen når du viser "
