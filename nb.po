msgid ""
"Below is an example of how to programmatically validate and submit a "
"webform submission using PHP."
msgstr ""
"Nedenfor er et eksempel på hvordan du kan validere og sende inn en "
"webform-innsending programmatisk ved hjelp av PHP."

msgid "Unable to parse CSV file. Please review the CSV file's formatting."
msgstr ""
"Kan ikke tolke CSV-filen. Vennligst kontroller formateringen av "
"CSV-filen."

msgid "Administer webform overview"
msgstr "Administrer oversikt over nettskjemaer"

msgid "Filter webforms and perform bulk actions on overview page."
msgstr "Filtrer webskjemaer og utfør massehandlinger på oversiktssiden."

msgid "File upload limit message"
msgstr "Melding om grense for filopplasting"

msgid "Check if an element is displayed"
msgstr "Sjekk om et element vises"

msgid "Default file upload limit per form message"
msgstr "Standard grense for filopplasting per skjema-melding"

msgid "Webform deprecated modules"
msgstr "Avviklede Webform-moduler"

msgid ""
"The following webform sub-modules have been deprecated: @module_list. "
"Please download the <a href=\":url\">Webform Deprecated</a> project."
msgstr ""
"Følgende Webform-undermoduler er avviklet: @module_list. Vennligst "
"last ned prosjektet <a href=\":url\">Webform Deprecated</a>."

msgid ""
"@element_file_limit limit per file. The accumulated size of all files "
"in this form cannot exceed @webform_file_limit."
msgstr ""
"@element_file_limit grense per fil. Den samlede størrelsen på alle "
"filene i dette skjemaet kan ikke overstige @webform_file_limit."

msgid ""
"The accumulated size of all files in this form cannot exceed "
"@webform_file_limit."
msgstr ""
"Den totale størrelsen på alle filene i dette skjemaet kan ikke "
"overstige @webform_file_limit."

msgid ""
"Note: This is only to be used with the Drupal Bootstrap Theme, NOT "
"with other Bootstrap Framework related Themes (like Radix)."
msgstr ""
"Merk: Dette skal kun brukes med Drupal Bootstrap-temaet, IKKE med "
"andre Bootstrap-rammeverkrelaterte temaer (som Radix)."

msgid "Send on (date / datetime string or [token])"
msgstr "Send videre (dato-/datotidstreng eller [token])"

msgid "Please delete submissions from the %title webform."
msgstr "Vennligst slett innsendinger fra %title-nettskjemaet."

msgid "%title webform has @total submissions."
msgstr "%title webskjema har @total innsendinger."

msgid ""
"You may not delete %title webform until you have removed all of the "
"%title submissions."
msgstr ""
"Du kan ikke slette nettkjemaet %title før du har fjernet alle "
"innsendingene til %title."

msgid ""
"Please make sure to install additional <a "
"href=\":libraries_href\">third-party libraries</a>, <a "
"href=\":submodules_href\">sub-modules</a> and optional <a "
"href=\":ecosystem_href\">add-ons</a>."
msgstr ""
"Pass på å installere flere <a "
"href=\":libraries_href\">tredjepartsbiblioteker</a>, <a "
"href=\":submodules_href\">undermoduler</a> og valgfrie <a "
"href=\":ecosystem_href\">tillegg</a>."

msgid "File upload limit per form message"
msgstr "Maksimal filopplastingsgrense per skjema – melding"

msgid ""
"Enter message to be displayed when file upload limit is reached. You "
"may use %quota as a placeholder."
msgstr ""
"Skriv inn meldingen som skal vises når grensen for filopplasting er "
"nådd. Du kan bruke %quota som en plassholder."

msgid ""
"You must allow users to post submissions from a dedicated URL to use "
"open this webform is a dialog."
msgstr ""
"Du må tillate at brukere kan sende inn bidrag fra en egen URL for å "
"kunne åpne dette nettskjemaet i en dialog."

msgid "Please delete submissions from the selected webforms."
msgstr "Vennligst slett innsendinger fra de valgte webskjemaene."

msgid "The selected webforms have a total of @total submissions."
msgstr "De valgte webskjemaene har totalt @total innsendinger."

msgid ""
"You may not delete these webforms until there is less than @batch "
"total submissions."
msgstr ""
"Du kan ikke slette disse nettskjemaene før det er færre enn @batch "
"innsendinger totalt."

msgid "Filter by data and/or notes"
msgstr "Filtrer etter data og/eller notater"

msgid ""
"If checked, support option, displayed on the <a "
"href=\":help_href\">Help</a> page will be disabled."
msgstr ""
"Hvis avkrysset, vil støttealternativet som vises på <a "
"href=\":help_href\">Hjelp</a>-siden, bli deaktivert."

msgid "Minimum amount of items displayed"
msgstr "Minimum antall elementer som vises"

msgid "Date part title display"
msgstr "Visning av tittelen på datodelen"

