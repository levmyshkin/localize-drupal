msgid ""
"It is not possible to map the source field @source_field_name of a "
"media type."
msgstr ""
"Det er ikke mulig å mappe kildefeltet @source_field_name for en "
"medietype."

msgid "Migration messages"
msgstr "Migrasjonsmeldinger"

