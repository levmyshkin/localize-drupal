msgstr ""
"Hvis den er avkrysset, vil elementer der «Vis element» ikke er "
"avkrysset (dvs. <code>'#access': false</code>) ikke bli inkludert i "
"forespørselsdataene."

msgid "Remote CRUD request return @status_code status code."
msgstr "Ekstern CRUD-forespørsel returnerer statuskode @status_code."

msgid "Remote HTTP operation successful!"
msgstr "Ekstern HTTP-operasjon var vellykket!"

msgid "Debug: Remote HTTP operation: @title [@state]"
msgstr "Debug: Fjern-HTTP-operasjon: @title [@state]"

msgid "Remote HTTP Operations"
msgstr "Fjernstyrte HTTP-operasjoner"

