msgstr "Attributter for melding om nektet tilgang til innsending"

msgid "Default submission view replace"
msgstr "Erstatt standard visning av innsendelser"

msgid "Default submission access denied message"
msgstr "Standardmelding når tilgang til innsending er nektet"

