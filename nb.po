msgstr "Rediger blokktype %label"

msgid "Block type %label has been updated."
msgstr "Blokktype %label har blitt oppdatert."

msgid "Block type %label has been added."
msgstr "Blokktype %label er lagt til."

msgid "Add %type content block"
msgstr "Legg til innholdsblokk av typen %type"

msgid "Content block ID"
msgstr "Innholdsblokk-ID"

