msgstr ""
"For mer avanserte brukstilfeller, som rendrerte entiteter eller mer "
"kompleks filtrering eller sortering av entiteter, kan det være "
"aktuelt å bruke referansemetoden «Views: Filter by an entity "
"reference view»."

msgid "Justify content"
msgstr "Juster innholdet"

msgid "Space between (space-between)"
msgstr "Mellomrom mellom (space-between)"

