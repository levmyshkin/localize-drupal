msgstr "Lagre + Legg til element"

msgid "Webform access controls"
msgstr "Tilgangskontroller for Webform"

msgid "Access Control | Tag1 Consulting"
msgstr "Tilgangskontroll | Tag1 Consulting"

msgid "Opening webforms in modal dialogs"
msgstr "Åpne webskjemaer i modale dialogbokser"

