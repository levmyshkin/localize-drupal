msgstr "<a href=\":href\">Deaktiver CDN-advarsel</a>"

msgid ""
"@total libraries (@installed installed; @excluded excluded; @missing "
"CDN)"
msgstr ""
"@total biblioteker (@installed installert; @excluded ekskludert; "
"@missing CDN)"

msgid "Drupal Association"
msgstr "Drupal Association"

msgid ""
"The below requirements are checked by the <a href=\":href\">Status "
"report</a>."
msgstr ""
"Kravene nedenfor kontrolleres av <a "
"href=\":href\">Statusrapporten</a>."

msgid ""
"If unchecked, all warnings about Webform SPAM protection will be "
"disabled."
msgstr ""
"Hvis det ikke er krysset av, blir alle advarsler om Webform "
"SPAM-beskyttelse deaktivert."

msgid "Check that all entered values for this element are unique."
msgstr "Kontroller at alle angitte verdier for dette elementet er unike."

