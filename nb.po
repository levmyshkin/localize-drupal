"For token support the <a href=\"@token_url\">token module</a> must be "
"installed."
msgstr ""
"For token-støtte må <a href=\"@token_url\">Token-modulen</a> være "
"installert."

msgid "Plain (mainly for images)"
msgstr "Plain (hovedsakelig for bilder)"

