"<strong>@sitemap, line @line</strong>: The path <em>@path</em> needs "
"to start with a '/'."
msgstr ""
"<strong>@sitemap, line @line</strong>: Stien <em>@path</em> må "
"begynne med «/»."

msgid ""
"<strong>@sitemap, line @line</strong>: The priority setting "
"<em>@priority</em> for path <em>@path</em> is incorrect. Set the "
"priority from 0.0 to 1.0."
msgstr ""
"<strong>@sitemap, linje @line</strong>: Prioritetsinnstillingen "
"<em>@priority</em> for stien <em>@path</em> er feil. Angi prioriteten "
"fra 0.0 til 1.0."

msgid ""
"<strong>@sitemap, line @line</strong>: The changefreq setting "
"<em>@changefreq</em> for path <em>@path</em> is incorrect. The "
"following are the correct values: <em>@changefreq_options</em>."
msgstr ""
"<strong>@sitemap, linje @line</strong>: Innstillingen changefreq "
"<em>@changefreq</em> for stien <em>@path</em> er ugyldig. Følgende "
"verdier er gyldige: <em>@changefreq_options</em>."

