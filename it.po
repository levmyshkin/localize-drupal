"        <ul>\r\n"
"   "
"       <li>Allinea una immagine a sinistra: <code>&lt;img src=\"\" "
"data-align=\"left\" /&gt;</code></li>\r\n"
"          <li>Allinea una "
"immagine al centro: <code>&lt;img src=\"\" data-align=\"center\" "
"/&gt;</code></li>\r\n"
"          <li>Allinea una immagine a destra: "
"<code>&lt;img src=\"\" data-align=\"right\" /&gt;</code></li>\r\n"
"     "
