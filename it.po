msgid "Webform Cards"
msgstr "Schede Webform"

msgid ""
"Provides a 'Card' container element for fast clientside multistep form "
"pagination."
msgstr ""
"Fornisce un elemento contenitore 'Card' per una rapida paginazione "
"multistep dei moduli lato client."

