msgstr "@label リビジョンから実際の @label を取得する"

msgid "Database connection supports the JSON type."
msgstr "データベースはJSON型をサポートしています。"

msgid ""
"<a href=\"https://www.drupal.org/docs/system-requirements\">Database "
