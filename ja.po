msgstr "主要ブランドカラー"

msgid "A clean, accessible, and flexible Drupal front-end theme."
msgstr "クリーンでアクセシブル、かつ柔軟なDrupalフロントエンドテーマ。"

msgid "Wide (1090)"
msgstr "ワイド（1090）"

msgid "Olivero Medium"
