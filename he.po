msgstr "התצורה המפורטת תמחק."

msgid "User's roles"
msgstr "תפקידי המשתמש"

msgid "Single name"
msgstr "שם יחיד"

msgid "If none are selected, all are allowed."
msgstr "אם לא נבחר אף אחד, כולם מותרים."

