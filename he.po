msgstr "הסטטוס שפורסם של קובץ."

msgid "The time that the file was added."
msgstr "הזמן שבו הקובץ התווסף."

msgid "The Drupal files path."
msgstr "נתיב הקבצים של Drupal."

msgid "TRUE if the files directory is public otherwise FALSE."
msgstr ""
"TRUE אם ספריית הקבצים היא ציבורית, אחרת "
"FALSE."

