msgid ""
"The installer requires that you create a translations directory as "
"part of the installation process. Create the directory "
"%translations_directory . More details about installing Drupal are "
"available in <a href=\":install_txt\">INSTALL.txt</a>."
msgstr ""
"התקנת התוכנה דורשת ליצור ספריית "
"תרגומים כחלק מתהליך ההתקנה. צור את "
"הספרייה %translations_directory . פרטים נוספים "
"אודות התקנת Drupal ניתן למצוא ב- <a "
"href=\":install_txt\">INSTALL.txt</a>."

msgid ""
"The installer requires read permissions to %translations_directory at "
"all times. The <a href=\":handbook_url\">webhosting issues</a> "
"documentation section offers help on this and other topics."
msgstr ""
"התקנה דורשת הרשאות קריאה ל- "
"%translations_directory בכל עת. סעיף התיעוד <a "
"href=\":handbook_url\">בעיות אחסון אתרים</a> מציע "
"עזרה בנושא זה ובנושאים אחרים."

msgid ""
"The installer requires write permissions to %translations_directory "
"during the installation process. The <a "
"href=\":handbook_url\">webhosting issues</a> documentation section "
"offers help on this and other topics."
msgstr ""
"התקנת התוכנה דורשת הרשאות כתיבה "
"לתיקיית %translations_directory במהלך תהליך "
"ההתקנה. סעיף התיעוד <a "
"href=\":handbook_url\">בעיות אחסון אתרים</a> מציע "
"עזרה בנושא זה ובנושאים אחרים."

msgid ""
"The installer requires to contact the translation server to download a "
"translation file. Check your internet connection and verify that your "
"website can reach the translation server at <a "
"href=\":server_url\">@server_url</a>."
msgstr ""
"התוכנה דורשת יצירת קשר עם שרת התרגום "
"כדי להוריד קובץ תרגום. בדוק את חיבור "
"האינטרנט שלך וודא שהאתר שלך יכול להגיע "
"לשרת התרגום בכתובת <a "
"href=\":server_url\">@server_url</a>."

msgid ""
"The %language translation file is not available at the translation "
"server. <a href=\":url\">Choose a different language</a> or select "
"English and translate your website later."
msgstr ""
"קובץ התרגום %language אינו זמין בשרת "
"התרגום. <a href=\":url\">בחר שפה אחרת</a> או בחר "
"אנגלית ותרגם את האתר שלך מאוחר יותר."

msgid ""
"The %language translation file could not be downloaded. <a "
"href=\":url\">Choose a different language</a> or select English and "
"translate your website later."
msgstr ""
"לא ניתן להוריד את קובץ התרגום בשפה %. <a "
"href=\":url\">בחר שפה אחרת</a> או בחר באנגלית "
"ותרגם את האתר שלך מאוחר יותר."

msgid ""
"The @drupal installer requires that you create a %file as part of the "
"installation process. Copy the %default_file file to %file. More "
"details about installing Drupal are available in <a "
"href=\":install_txt\">INSTALL.txt</a>."
msgstr ""
"מתקין @drupal דורש שתיצור קובץ %file כחלק "
"מתהליך ההתקנה. העתק את הקובץ %default_file "
"לקובץ %file. פרטים נוספים אודות התקנת Drupal "
"זמינים ב-<a href=\":install_txt\">INSTALL.txt</a>."

msgid ""
"@drupal requires read permissions to %file at all times. The <a "
"href=\":handbook_url\">webhosting issues</a> documentation section "
"offers help on this and other topics."
msgstr ""
"@drupal דורש הרשאות קריאה ל-%file בכל עת. "
"סעיף התיעוד <a href=\":handbook_url\">בעיות אחסון "
"אתרים</a> מציע עזרה בנושא זה ובנושאים "
"אחרים."

msgid ""
"The @drupal installer requires write permissions to %file during the "
"installation process. The <a href=\":handbook_url\">webhosting "
"issues</a> documentation section offers help on this and other topics."
msgstr ""
"מתקין @drupal דורש הרשאות כתיבה ל-%file "
"במהלך תהליך ההתקנה. סעיף התיעוד <a "
"href=\":handbook_url\">בעיות אחסון אתרים</a> מציע "
"עזרה בנושא זה ובנושאים אחרים."

msgid ""
"The @drupal installer failed to create a %file file with proper file "
"ownership. Log on to your web server, remove the existing %file file, "
"and create a new one by copying the %default_file file to %file. More "
"details about installing Drupal are available in <a "
"href=\":install_txt\">INSTALL.txt</a>. The <a "
"href=\":handbook_url\">webhosting issues</a> documentation section "
"offers help on this and other topics."
msgstr ""
"מתקין @drupal לא הצליח ליצור קובץ %file עם "
"בעלות נכונה על הקובץ. התחבר לשרת "
"האינטרנט שלך, הסר את קובץ %file הקיים "
"וצור קובץ חדש על ידי העתקת קובץ %default_file "
"ל- %file. פרטים נוספים על התקנת Drupal זמינים "
"ב- <a href=\":install_txt\">INSTALL.txt</a>. סעיף התיעוד <a "
"href=\":handbook_url\">בעיות אחסון אתרים</a> מציע "
"עזרה בנושא זה ובנושאים אחרים."

msgid ""
"Check the messages and <a href=\":retry\">retry</a>, or you may choose "
"to <a href=\":cont\">continue anyway</a>."
msgstr ""
"בדוק את ההודעות ו<a href=\":retry\">נסה שוב</a>, "
"או שתוכל לבחור <a href=\":cont\">להמשיך בכל "
"מקרה</a>."

msgid "Check the messages and <a href=\":url\">try again</a>."
msgstr "בדוק את ההודעות ו<a href=\":url\">נסה שוב</a>."

msgid ""
"The following modules are required but were not found. Move them into "
"the appropriate modules subdirectory, such as <em>/modules</em>. "
"Missing modules: @modules"
msgstr ""
"המודולים הבאים נדרשים אך לא נמצאו. "
"העבר אותם לספריית המשנה המתאימה, כגון "
"<em>/modules</em>. מודולים חסרים: @modules"

msgid "Updating @module"
msgstr "עדכון @module"

msgid ""
"Entity type mismatch on rename. @old_type not equal to @new_type for "
"existing configuration @old_name and staged configuration @new_name."
msgstr ""
"אי התאמה בין סוגי הישויות בעת שינוי "
"השם. @old_type אינו שווה ל-@new_type עבור התצורה "
"הקיימת @old_name והתצורה המוכנה @new_name."

msgid ""
"Rename operation for simple configuration. Existing configuration "
"@old_name and staged configuration @new_name."
msgstr ""
"פעולת שינוי שם לתצורה פשוטה. תצורה "
"קיימת @old_name ותצורה מבוימת @new_name."

msgid ""
"The %driver database must use %encoding encoding to work with Drupal. "
"Recreate the database with %encoding encoding. See <a "
"href=\"INSTALL.pgsql.txt\">INSTALL.pgsql.txt</a> for more details."
msgstr ""
"מסד הנתונים %driver חייב להשתמש בקידוד "
"%encoding כדי לעבוד עם Drupal. צור מחדש את מסד "
"הנתונים עם קידוד %encoding. ראה <a "
"href=\"INSTALL.pgsql.txt\">INSTALL.pgsql.txt</a> לפרטים "
"נוספים."

msgid ""
"The %setting setting is currently set to '%current_value', but needs "
"to be '%needed_value'. Change this by running the following query: "
"<code>@query</code>"
msgstr ""
"ההגדרה %setting מוגדרת כרגע כ-'%current_value', אך "
"צריכה להיות '%needed_value'. שנה זאת על ידי "
"הפעלת השאילתה הבאה: <code>@query</code>"

msgid "@uri"
msgstr "@uri"

msgid "Operating in maintenance mode. <a href=\":url\">Go online.</a>"
msgstr ""
"\"האתר נמצא כעת ב\"מצב תחזוקה. <a "
"href=\":url\">לעלות חזרה לאויר.</a>"

msgid "Textfield size: @size"
msgstr "גודל שדה הטקסט: @size"

msgid "Number of rows: @rows"
msgstr "מספר שורות: @rows"

msgid "URI field size: @size"
msgstr "גודל שדה URI: @size"

msgid ""
"WARNING: You are not using an encrypted connection, so your password "
"will be sent in plain text. <a href=\":https-link\">Learn more</a>."
msgstr ""
"אזהרה: אינך משתמש בחיבור מוצפן, ולכן "
"הסיסמה שלך תישלח בטקסט רגיל. <a "
"href=\":https-link\">למידע נוסף</a>."

msgid ""
"@name cannot be longer than %max characters but is currently %length "
"characters long."
msgstr ""
"@name לא יכול להיות ארוך מ-%max תווים, אך "
"כרגע הוא באורך %length תווים."

msgid ""
"<ul>\n"
"<li>To start over, you must empty your existing database and "
"copy <em>default.settings.php</em> over "
"<em>settings.php</em>.</li>\n"
"<li>To upgrade an existing installation, "
"proceed to the <a href=\":update-url\">update "
"script</a>.</li>\n"
"<li>View your <a href=\":base-url\">existing "
"site</a>.</li>\n"
"</ul>"
msgstr ""
"<ul> <li>כדי להתחיל מחדש, עליך לרוקן את מסד "
"הנתונים הקיים ולהעתיק את הקובץ "
"<em>default.settings.php</em> מעל הקובץ "
"<em>settings.php</em>.</li>\n"
"<li>כדי לשדרג התקנה "
"קיימת, המשך ל-<a href=\":update-url\">סקריפט "
"העדכון</a>.</li> <li>הצג את <a href=\":base-url\">האתר "
"הקיים שלך</a>.</li> </ul>"

msgid ""
"All necessary changes to %dir and %file have been made, so you should "
"remove write permissions to them now in order to avoid security risks. "
"If you are unsure how to do so, consult the <a "
"href=\":handbook_url\">online handbook</a>."
msgstr ""
"כל השינויים הדרושים ב-%dir ו-%file בוצעו, "
"ולכן עליך להסיר את הרשאות הכתיבה אליהם "
"כעת על מנת למנוע סיכוני אבטחה. אם אינך "
"בטוח כיצד לעשות זאת, עיין ב<a "
"href=\":handbook_url\">המדריך המקוון</a>."

msgctxt "Validation"
msgid "Unique field constraint"
msgstr "אילוץ שדה ייחודי"

msgid "A @entity_type with @field_name %value already exists."
msgstr "@entity_type עם @field_name %value כבר קיים."

msgid ""
"The message that should be sent. You may include placeholders like "
"[node:title], [user:account-name], [user:display-name] and "
"[comment:body] to represent data that will be different each time "
"message is sent. Not all placeholders will be available in all "
"contexts."
msgstr ""
"ההודעה שיש לשלוח. ניתן לכלול מחליפים "
"כגון [node:title], [user:account-name], [user:display-name] "
"ו-[comment:body] כדי לייצג נתונים שישתנו בכל "
"פעם שההודעה תישלח. לא כל המחליפים יהיו "
"זמינים בכל ההקשרים."

msgid ""
"The message to be displayed to the current user. You may include "
"placeholders like [node:title], [user:account-name], "
"[user:display-name] and [comment:body] to represent data that will be "
"different each time message is sent. Not all placeholders will be "
"available in all contexts."
msgstr ""
"ההודעה שתוצג למשתמש הנוכחי. ניתן לכלול "
"מחליפים כגון [node:title], [user:account-name], "
"[user:display-name] ו-[comment:body] כדי לייצג נתונים "
"שישתנו בכל פעם שההודעה תישלח. לא כל "
"המחליפים יהיו זמינים בכל ההקשרים."

msgid ""
"The Ban module allows administrators to ban visits to their site from "
"individual IP addresses. For more information, see the <a "
"href=\":url\">online documentation for the Ban module</a>."
msgstr ""
"מודול Ban מאפשר למנהלים לחסום ביקורים "
"באתר שלהם מכתובות IP בודדות. למידע נוסף, "
"ראה <a href=\":url\">תיעוד מקוון למודול Ban</a>."

msgid ""
"Administrators can enter IP addresses to ban on the <a "
"href=\":bans\">IP address bans</a> page."
msgstr ""
"מנהלי האתר יכולים להזין כתובות IP "
"שתיאסר גישה מהן בעמוד<a href=\":bans\">כתובות "
"IP חסומות</a> ."

msgid ""
"The HTTP Basic Authentication module supplies an <a "
"href=\"http://en.wikipedia.org/wiki/Basic_access_authentication\">HTTP "
"Basic authentication</a> provider for web service requests. This "
"authentication provider authenticates requests using the HTTP Basic "
"Authentication username and password, as an alternative to using "
"Drupal's standard cookie-based authentication system. It is only "
"useful if your site provides web services configured to use this type "
"of authentication (for instance, the <a href=\":rest_help\">RESTful "
"Web Services module</a>). For more information, see the <a "
"href=\":hba_do\">online documentation for the HTTP Basic "
"Authentication module</a>."
msgstr ""
"מודול האימות הבסיסי HTTP מספק ספק <a "
"href=\"http://en.wikipedia.org/wiki/Basic_access_authentication\">אימות "
"בסיסי HTTP</a> לבקשות שירות אינטרנט. ספק "
"אימות זה מאמת בקשות באמצעות שם המשתמש "
"והסיסמה של האימות הבסיסי HTTP, כחלופה "
"לשימוש במערכת האימות הסטנדרטית של Drupal "
"המבוססת על קובצי Cookie. הוא שימושי רק אם "
"האתר שלך מספק שירותי אינטרנט המוגדרים "
"לשימוש בסוג זה של אימות (לדוגמה, <a "
"href=\":rest_help\">מודול RESTful Web Services</a>). למידע "
"נוסף, ראה <a href=\":hba_do\">תיעוד מקוון "
"למודול אימות בסיסי HTTP</a>."

msgid ""
"The Block module allows you to place blocks in regions of your "
"installed themes, and configure block settings. For more information, "
"see the <a href=\":blocks-documentation\">online documentation for the "
"Block module</a>."
msgstr ""
"מודול ה-Block מאפשר לך למקם בלוקים "
"באזורים של ערכות הנושא המותקנות שלך, "
"ולהגדיר את הגדרות הבלוק. למידע נוסף, "
"ראה <a href=\":blocks-documentation\">תיעוד מקוון "
"למודול Block</a>."

msgid ""
"You can see where the regions are for the current theme by clicking "
"the <em>Demonstrate block regions</em> link on the <a "
"href=\":blocks\">Block layout page</a>. Regions are specific to each "
"theme."
msgstr ""
"ניתן לראות היכן נמצאים האזורים של "
"העיצוב הנוכחי על ידי לחיצה על הקישור "
"<em>הדגמת אזורי בלוקים</em> בדף <a "
"href=\":blocks\">פריסת בלוקים</a>. האזורים "
"ספציפיים לכל עיצוב."

msgid ""
"To change the settings of an individual block click on the "
"<em>Configure</em> link on the <a href=\":blocks\">Block layout "
"page</a>. The available options vary depending on the module that "
"provides the block. For all blocks you can change the block title and "
"toggle whether to display it."
msgstr ""
"כדי לשנות את ההגדרות של בלוק בודד, לחץ "
"על הקישור <em>Configure</em> (הגדר) בדף <a "
"href=\":blocks\">Block layout page</a> (פריסת בלוקים). "
"האפשרויות הזמינות משתנות בהתאם למודול "
"המספק את הבלוק. עבור כל הבלוקים, ניתן "
"לשנות את כותרת הבלוק ולהחליט אם להציג "
"אותו."

msgid ""
"The Breakpoint module keeps track of the height, width, and resolution "
"breakpoints where a responsive design needs to change in order to "
"respond to different devices being used to view the site. This module "
"does not have a user interface. For more information, see the <a "
"href=\":docs\">online documentation for the Breakpoint module</a>."
msgstr ""
"מודול Breakpoint עוקב אחר נקודות השבר "
"בגובה, רוחב ורזולוציה שבהן עיצוב "
"רספונסיבי צריך להשתנות כדי להגיב "
"למכשירים שונים המשמשים לצפייה באתר. "
"למודול זה אין ממשק משתמש. למידע נוסף, "
"ראה <a href=\":docs\">תיעוד מקוון למודול "
"Breakpoint</a>."

msgid ""
"<a href=\":w3\">Media  queries</a> are a formal way to encode "
"breakpoints. For instance, a width breakpoint at 40em would be written "
"as the media query \"(min-width: 40em)\". Breakpoints are really just "
"media queries with some additional meta-data, such as a name and "
"multiplier information."
msgstr ""
"<a href=\":w3\">שאילתות מדיה</a> הן דרך פורמלית "
"לקודד נקודות עצירה. לדוגמה, נקודת "
"עצירה ברוחב 40em תכתב כשאילתת מדיה "
"\"(min-width: 40em)\". נקודות עצירה הן למעשה "
"שאילתות מדיה עם כמה מטא-נתונים נוספים, "
"כגון שם ומידע על מכפיל."

msgid ""
"The Comment module allows users to comment on site content, set "
"commenting defaults and permissions, and moderate comments. For more "
"information, see the <a href=\":comment\">online documentation for the "
"Comment module</a>."
msgstr ""
"מודול התגובות מאפשר למשתמשים להגיב על "
"תוכן האתר, להגדיר ברירות מחדל והרשאות "
"לתגובות ולנהל את התגובות. למידע נוסף, "
"ראה <a href=\":comment\">התיעוד המקוון של מודול "
"התגובות</a>."

msgid "Enabling commenting"
msgstr "הפעלת אפשרות להגיב"

msgid "Configuring commenting settings"
msgstr "הגדרת הגדרות התגובות"

msgid ""
"Users with the appropriate permissions can override the default "
"commenting settings of an entity type when they create an item of that "
"type."
msgstr ""
"משתמשים בעלי ההרשאות המתאימות יכולים "
"לעקוף את הגדרות ברירת המחדל של הערות "
"עבור סוג ישות כאשר הם יוצרים פריט מסוג "
"זה."

msgid ""
"Comments from users who have the <em>Skip comment approval</em> "
"permission are published immediately. All other comments are placed in "
"the <a href=\":comment-approval\">Unapproved comments</a> queue, until "
"a user who has permission to <em>Administer comments and comment "
"settings</em> publishes or deletes them. Published comments can be "
"bulk managed on the <a href=\":admin-comment\">Published comments</a> "
"administration page. When a comment has no replies, it remains "
"editable by its author, as long as the author has <em>Edit own "
"comments</em> permission."
msgstr ""
"תגובות ממשתמשים בעלי הרשאת <em>לדלג על "
"אישור תגובות</em> מתפרסמות באופן מיידי. "
"כל שאר התגובות מועברות לתור <a "
"href=\":comment-approval\">תגובות לא מאושרות</a>, עד "
"שמשתמש בעל הרשאת <em>לנהל תגובות "
"והגדרות תגובות</em> מפרסם או מוחק אותן. "
"ניתן לנהל הערות שפורסמו באופן מרוכז "
"בדף הניהול <a href=\":admin-comment\">הערות "
"שפורסמו</a>. כאשר להערות אין תגובות, הן "
"נותרות ניתנות לעריכה על ידי מחברן, כל "
"עוד למחבר יש הרשאה <em>לערוך הערות "
"משלו</em>."

msgid "In reply to @parent_title by @parent_username"
msgstr "בתגובה ל-@parent_title מאת @parent_username"

msgid "Name for @anonymous"
msgstr "שם עבור @anonymous"

msgid ""
"<a href=\":login\">Log in</a> or <a href=\":register\">register</a> to "
"post comments"
msgstr ""
"<a href=\":login\">התחבר</a> או <a "
"href=\":register\">הירשם</a> כדי לפרסם תגובות"

msgid "<a href=\":login\">Log in</a> to post comments"
msgstr "<a href=\":login\">התחבר</a> כדי לפרסם תגובות"

msgid ""
"Select the Comment type to use for this comment field. Manage the "
"comment types from the <a href=\":url\">administration overview "
"page</a>."
msgstr ""
"בחר את סוג ההערה שברצונך להשתמש בו "
"עבור שדה הערה זה. נהל את סוגי ההערות "
"מדף <a href=\":url\">סקירת הניהול</a>."

msgid ""
"The Configuration Manager module provides a user interface for "
"importing and exporting configuration changes between installations of "
"your website in different environments. Configuration is stored in "
"YAML format. For more information, see the <a href=\":url\">online "
"documentation for the Configuration Manager module</a>."
msgstr ""
"מודול מנהל התצורה מספק ממשק משתמש "
"לייבוא וייצוא של שינויי תצורה בין "
"התקנות של אתר האינטרנט שלך בסביבות "
"שונות. התצורה מאוחסנת בפורמט YAML. לקבלת "
"מידע נוסף, ראה את <a href=\":url\">התיעוד "
"המקוון של מודול מנהל התצורה</a>."

msgid ""
"You can create and download an archive consisting of all your site's "
"configuration exported as <em>*.yml</em> files on the <a "
"href=\":url\">Export</a> page."
msgstr ""
"ניתן ליצור ולהוריד ארכיון המכיל את כל "
"תצורת האתר שלך, המיוצאת כקובצי <em>*.yml</em> "
"בדף <a href=\":url\">ייצוא</a>."

msgid ""
"You can upload a full site configuration from an archive file on the "
"<a href=\":url\">Import</a> page. When importing data from a different "
"environment, the site and import files must have matching "
"configuration values for UUID in the <em>system.site</em> "
"configuration item. That means that your other environments should "
"initially be set up as clones of the target site. Migrations are not "
"supported."
msgstr ""
"ניתן להעלות תצורה מלאה של האתר מקובץ "
"ארכיון בדף <a href=\":url\">ייבוא</a>. בעת ייבוא "
"נתונים מסביבה אחרת, על האתר וקובצי "
"הייבוא להיות בעלי ערכי תצורה תואמים "
"עבור UUID בפריט התצורה <em>system.site</em>. "
"משמעות הדבר היא שסביבות אחרות צריכות "
"להיות מוגדרות בתחילה כשיבוטים של האתר "
"היעד. העברות אינן נתמכות."

msgid ""
"You can review differences between the active configuration and an "
"imported configuration archive on the <a "
"href=\":synchronize\">Synchronize</a> page to ensure that the changes "
"are as expected, before finalizing the import. The Synchronize page "
"also shows configuration items that would be added or removed."
msgstr ""
"ניתן לבדוק את ההבדלים בין התצורה "
"הפעילה לבין ארכיון התצורה המיובא בדף <a "
"href=\":synchronize\">סנכרון</a> כדי לוודא "
"שהשינויים תואמים לציפיות, לפני סיום "
"הייבוא. בדף סנכרון מוצגים גם פריטי "
"תצורה שייתווספו או יוסרו."

msgid ""
"You can export a single configuration item by selecting a "
"<em>Configuration type</em> and <em>Configuration name</em> on the <a "
"href=\":single-export\">Single export</a> page. The configuration and "
"its corresponding <em>*.yml file name</em> are then displayed on the "
"page for you to copy."
msgstr ""
"ניתן לייצא פריט תצורה בודד על ידי "
"בחירת <em>סוג תצורה</em> ו-<em>שם תצורה</em> "
"בדף <a href=\":single-export\">ייצוא בודד</a>. "
"התצורה ושם קובץ ה-<em>*.yml</em> המתאים לה "
"מוצגים בדף, כדי שתוכל להעתיק אותם."

msgid ""
"You can import a single configuration item by pasting it in YAML "
"format into the form on the <a href=\":single-import\">Single "
"import</a> page."
msgstr ""
"ניתן לייבא פריט תצורה בודד על ידי "
"הדבקתו בפורמט YAML בטופס שבדף <a "
"href=\":single-import\">ייבוא בודד</a>."

msgid ""
"Export and download the full configuration of this site as a gzipped "
"tar file."
msgstr ""
"יצוא והורדה של כל הגדרות האתר בקובץ "
"יחיד דחוס בפורמט gzip."

msgid "Choose a configuration item to display its YAML structure."
msgstr ""
"בחרו פריט תצורה כדי להציג את מבנה הYAML "
"שלו."

msgid ""
"Import a single configuration item by pasting its YAML structure into "
"the text field."
msgstr ""
"ייבוא תצורה של פריט יחיד באמצעות הדבקת "
"תוכן קובץ הYML שלו לתוך השדה."

msgid "Full archive"
msgstr "ארכיון שלם"

msgid "Single item"
msgstr "פריט יחיד"

msgid ""
"The following items in your active configuration have changes since "
"the last import that may be lost on the next import."
msgstr ""
"בפריטים הבאים בתצורה הפעילה יש "
"שינויים מאז הייבוא האחרון, שינויים אלו "
"עלולים להידרס במהלך הייבוא הבא."

msgid ""
"The Configuration Translation module allows you to translate "
"configuration text; for example, the site name, vocabularies, menus, "
"or date formats. Together with the modules <a "
"href=\":language\">Language</a>, <a "
"href=\":content-translation\">Content Translation</a>, and <a "
"href=\":locale\">Interface Translation</a>, it allows you to build "
"multilingual websites. For more information, see the <a "
"href=\":doc_url\">online documentation for the Configuration "
"Translation module</a>."
msgstr ""
"מודול תרגום התצורה מאפשר לך לתרגם טקסט "
"תצורה; לדוגמה, שם האתר, אוצר מילים, "
"תפריטים או פורמטים של תאריכים. יחד עם "
"המודולים <a href=\":language\">שפה</a>, <a "
"href=\":content-translation\">תרגום תוכן</a> ו- <a "
"href=\":locale\">תרגום ממשק</a>, הוא מאפשר לך "
"לבנות אתרי אינטרנט רב-לשוניים. למידע "
"נוסף, ראה <a href=\":doc_url\">תיעוד מקוון "
"למודול תרגום תצורה</a>."

msgid ""
"In order to translate configuration, the website must have at least "
"two <a href=\":url\">languages</a>."
msgstr ""
"על מנת לתרגם את התצורה, על האתר להכיל "
"לפחות שני <a href=\":url\">שפות</a>."

msgid ""
"Users with the <em>Translate user edited configuration</em> permission "
"can access the configuration translation overview, and manage "
"translations for specific languages. The <a "
"href=\":translation-page\">Configuration translation</a> page shows a "
"list of all configuration text that can be translated, either as "
"individual items or as lists. After you click on <em>Translate</em>, "
"you are provided with a list of all languages. You can <em>add</em> or "
"<em>edit</em> a translation for a specific language. Users with "
"specific configuration permissions can also <em>edit</em> the text for "
"the site's default language. For some configuration text items (for "
"example for the site information), the specific translation pages can "
"also be accessed directly from their configuration pages."
msgstr ""
"משתמשים בעלי ההרשאה <em>תרגום תצורה "
"שערכה המשתמש</em> יכולים לגשת לסקירת "
"תרגום התצורה ולנהל תרגומים לשפות "
"ספציפיות. הדף <a href=\":translation-page\">תרגום "
"תצורה</a> מציג רשימה של כל טקסט התצורה "
"שניתן לתרגם, כפריטים בודדים או "
"כרשימות. לאחר לחיצה על <em>תרגם</em>, תוצג "
"רשימה של כל השפות. ניתן <em>להוסיף</em> או "
"<em>לערוך</em> תרגום לשפה ספציפית. משתמשים "
"בעלי הרשאות תצורה ספציפיות יכולים גם "
"<em>לערוך</em> את הטקסט בשפת ברירת המחדל "
"של האתר. עבור פריטי טקסט תצורה מסוימים "
"(לדוגמה, מידע על האתר), ניתן לגשת לדפי "
"התרגום הספציפיים גם ישירות מדפי "
"התצורה שלהם."

msgid ""
"You can choose to translate date formats on the <a "
"href=\":translation-page\">Configuration translation</a> page. This "
"allows you not only to translate the label text, but also to set a "
"language-specific <em>PHP date format</em>."
msgstr ""
"ניתן לבחור לתרגם פורמטים של תאריכים "
"בדף <a href=\":translation-page\">תרגום תצורה</a>. כך "
"ניתן לא רק לתרגם את טקסט התווית, אלא גם "
"להגדיר <em>פורמט תאריך PHP</em> ספציפי לשפה."

msgid "@label <span class=\"visually-hidden\">(@source_language)</span>"
msgstr "@label <span class=\"visually-hidden\">(@source_language)</span>"

msgid ""
"The Contact module allows visitors to contact registered users on your "
"site, using the personal contact form, and also allows you to set up "
"site-wide contact forms. For more information, see the <a "
"href=\":contact\">online documentation for the Contact module</a>."
msgstr ""
"מודול 'צור קשר' מאפשר למבקרים ליצור קשר "
"עם משתמשים רשומים באתר שלך באמצעות "
"טופס יצירת קשר אישי, ומאפשר לך גם "
"להגדיר טפסי יצירת קשר לכל האתר. למידע "
"נוסף, עיין ב<a href=\":contact\">תיעוד מקוון "
"למודול 'צור קשר'</a>."

msgid ""
"On the <a href=\":contact_admin\">Contact forms page</a>, you can "
"configure the fields and display of the personal contact form, and you "
"can set up one or more site-wide contact forms. Each site-wide contact "
"form has a machine name, a label, and one or more defined recipients; "
"when a site visitor submits the form, the field values are sent to "
"those recipients."
msgstr ""
"בדף <a href=\":contact_admin\">טפסי יצירת קשר</a>, "
"תוכל להגדיר את השדות ואת התצוגה של "
"טופס יצירת הקשר האישי, וכן להגדיר טופס "
"יצירת קשר אחד או יותר לכל האתר. לכל "
"טופס יצירת קשר לכל האתר יש שם מכונה, "
"תווית ואחד או יותר נמענים מוגדרים; "
"כאשר מבקר באתר שולח את הטופס, ערכי "
"השדות נשלחים לנמענים אלה."

msgid ""
"One site-wide contact form can be designated as the default contact "
"form. If you choose to designate a default form, the <em>Contact</em> "
"menu link in the <em>Footer</em> menu will link to it. You can modify "
"this link from the <a href=\":menu-settings\">Menus page</a> if you "
"have the Menu UI module installed. You can also create links to other "
"contact forms; the URL for each form you have set up has format "
"<em>contact/machine_name_of_form</em>."
msgstr ""
"ניתן להגדיר טופס יצירת קשר אחד לכל "
"האתר כטופס יצירת הקשר המוגדר כברירת "
"מחדל. אם תבחר להגדיר טופס כברירת מחדל, "
"קישור התפריט <em>צור קשר</em> בתפריט "
"<em>כותרת תחתונה</em> יקשר אליו. ניתן "
"לשנות קישור זה מדף <a "
"href=\":menu-settings\">תפריטים</a> אם התקנת את "
"מודול ממשק המשתמש של התפריטים. ניתן גם "
"ליצור קישורים לטפסי יצירת קשר אחרים; "
"כתובת ה-URL של כל טופס שהגדרת היא בפורמט "
"<em>contact/machine_name_of_form</em>."

msgid ""
"From the <a href=\":contact_admin\">Contact forms page</a>, you can "
"configure the fields to be shown on contact forms, including their "
"labels and help text. If you would like other content (such as text or "
"images) to appear on a contact form, use a block. You can create and "
"edit blocks on the <a href=\":blocks\">Block layout page</a>, if the "
"Block module is installed."
msgstr ""
"מדף <a href=\":contact_admin\">טפסי יצירת קשר</a>, "
"ניתן להגדיר את השדות שיוצגו בטפסי "
"יצירת הקשר, כולל התוויות שלהם וטקסט "
"העזרה. אם ברצונך להציג תוכן אחר (כגון "
"טקסט או תמונות) בטופס יצירת הקשר, השתמש "
"בבלוק. ניתן ליצור ולערוך בלוקים בדף <a "
"href=\":blocks\">פריסת בלוקים</a>, אם מודול "
"הבלוקים מותקן."

msgid "[@form] @subject"
msgstr "[@form] @subject"

msgid ""
"@sender-name (@sender-url) sent a message using the contact form at "
"@form-url."
msgstr ""
"ההודעה נשלחה על ידי @sender-name ( @sender-url )  "
"באמצעות טופס הקשר ב @form-url."

msgid "[@site-name] @subject"
msgstr "[@שם האתר] @נושא"

msgid "Hello @recipient-name,"
msgstr "שלום @recipient-name,"

msgid ""
"@sender-name (@sender-url) has sent you a message via your contact "
"form at @site-name."
msgstr ""
"ההודעה נשלחה על ידי @sender-name ( @sender-url )  "
"באמצעות טופס הקשר ב @site-name."

msgid "@name (not verified)"
msgstr "@name (לא מאומת)"

msgid ""
"The contact form has not been configured. <a href=\":add\">Add one or "
"more forms</a> ."
msgstr ""
"טופס יצירת הקשר לא הוגדר. <a "
"href=\":add\">הוסף טופס אחד או יותר</a> ."

msgid ""
"In order to translate content, the website must have at least two <a "
"href=\":url\">languages</a>. When that is the case, you can enable "
"translation for the desired content entities on the <a "
"href=\":translation-entity\">Content language</a> page. When enabling "
"translation you can choose the default language for content and decide "
"whether to show the language selection field on the content editing "
"forms."
msgstr ""
"על מנת לתרגם תוכן, על האתר להכיל לפחות "
"שתי <a href=\":url\">שפות</a>. כאשר זה המצב, ניתן "
"להפעיל תרגום עבור ישויות התוכן "
"הרצויות בדף <a href=\":translation-entity\">שפת "
"תוכן</a>. בעת הפעלת התרגום, ניתן לבחור את "
"שפת ברירת המחדל עבור התוכן ולהחליט אם "
"להציג את שדה בחירת השפה בטפסי עריכת "
"התוכן."

msgid ""
"Before you can translate content, there must be at least two languages "
"added on the <a href=\":url\">languages administration</a> page."
msgstr ""
"לפני שתוכל לתרגם תוכן, יש להוסיף לפחות "
"שתי שפות בדף <a href=\":url\">ניהול שפות</a>."

msgid ""
"To configure translation for this field, <a "
"href=\":language-settings-url\">enable language support</a> for this "
"type."
msgstr ""
"כדי להגדיר תרגום לשדה זה, <a "
"href=\":language-settings-url\">הפעל תמיכה בשפה</a> "
"עבור סוג זה."

msgid ""
"<a href=\":settings_url\">Enable translation</a> for <em>content "
"types</em>, <em>taxonomy vocabularies</em>, <em>accounts</em>, or any "
"other element you wish to translate."
msgstr ""
"<a href=\":settings_url\">הפעל תרגום</a> עבור "
"<em>סוגי תוכן</em>, <em>אוצר מילים "
"טקסונומי</em>, <em>חשבונות</em> או כל אלמנט "
"אחר שברצונך לתרגם."

msgid ""
"The Contextual links module gives users with the <em>Use contextual "
"links</em> permission quick access to tasks associated with certain "
"areas of pages on your site. For example, a menu displayed as a block "
"has links to edit the menu and configure the block. For more "
"information, see the <a href=\":contextual\">online documentation for "
"the Contextual Links module</a>."
msgstr ""
"מודול הקישורים הקונטקסטואליים מעניק "
"למשתמשים בעלי ההרשאה <em>השתמש בקישורים "
"קונטקסטואליים</em> גישה מהירה למשימות "
"הקשורות לאזורים מסוימים בדפים באתר "
"שלך. לדוגמה, תפריט המוצג כבלוק כולל "
"קישורים לעריכת התפריט ולהגדרת הבלוק. "
"למידע נוסף, ראה <a href=\":contextual\">התיעוד "
"המקוון של מודול הקישורים "
"הקונטקסטואליים</a>."

msgid ""
"Hovering over the area of interest will temporarily make the "
"contextual links button visible (which looks like a pencil in most "
"themes, and is normally displayed in the upper right corner of the "
"area). The icon typically looks like this: @picture"
msgstr ""
"העברת העכבר מעל האזור הרלוונטי תציג "
"באופן זמני את כפתור הקישורים "
"ההקשרתיים (שנראה כמו עיפרון ברוב "
"העיצובים, ומוצג בדרך כלל בפינה הימנית "
"העליונה של האזור). הסמל נראה בדרך כלל "
"כך: @picture"

msgid ""
"The Datetime module provides a Date field that stores dates and times. "
"It also provides the Form API elements <em>datetime</em> and "
"<em>datelist</em> for use in programming modules. See the <a "
"href=\":field\">Field module help</a> and the <a "
"href=\":field_ui\">Field UI module help</a> pages for general "
"information on fields and how to create and manage them. For more "
"information, see the <a href=\":datetime_do\">online documentation for "
"the Datetime module</a>."
msgstr ""
"מודול Datetime מספק שדה Date המאחסן תאריכים "
"ושעות. הוא מספק גם את רכיבי ה-API של "
"הטופס <em>datetime</em> ו-<em>datelist</em> לשימוש "
"במודולי תכנות. ראה את דפי העזרה של <a "
"href=\":field\">מודול השדות</a> ו-<a "
"href=\":field_ui\">מודול ממשק המשתמש של "
"השדות</a> לקבלת מידע כללי על שדות וכיצד "
"ליצור ולנהל אותם. למידע נוסף, ראה את <a "
"href=\":datetime_do\">התיעוד המקוון של מודול "
"Datetime</a>."

msgid ""
"The <em>settings</em> and the <em>display</em> of the Date field can "
"be configured separately. See the <a href=\":field_ui\">Field UI "
"help</a> for more information on how to manage fields and their "
"display."
msgstr ""
"ניתן להגדיר את <em>ההגדרות</em> ואת "
"<em>התצוגה</em> של שדה התאריך בנפרד. ראה <a "
"href=\":field_ui\">עזרה לממשק המשתמש של השדה</a> "
"לקבלת מידע נוסף על אופן הניהול של שדות "
"ותצוגתם."

msgid ""
"Dates can be displayed using the <em>Plain</em> or the "
"<em>Default</em> formatter. The <em>Plain</em> formatter displays the "
"date in the <a href=\"http://en.wikipedia.org/wiki/ISO_8601\">ISO "
"8601</a> format. If you choose the <em>Default</em> formatter, you can "
"choose a format from a predefined list that can be managed on the <a "
"href=\":date_format_list\">Date and time formats</a> page."
msgstr ""
"תאריכים יכולים להופיע באמצעות מעצב "
"<em>Plain</em> או <em>Default</em>. מעצב <em>Plain</em> מציג "
"את התאריך בפורמט <a "
"href=\"http://en.wikipedia.org/wiki/ISO_8601\">ISO 8601</a>. אם "
"תבחר במתכונת <em>Default</em>, תוכל לבחור "
"מתכונת מרשימה מוגדרת מראש שניתן לנהל "
"בדף <a href=\":date_format_list\">תבניות תאריך "
"ושעה</a>."

msgid "Date part order: @order"
msgstr "סדר תאריך: @order"

msgid "Time type: @time_type"
msgstr "סוג זמן: @time_type"

msgid "Time increments: @increment"
msgstr "מרווחי זמן: @increment"

msgid ""
"The Database Logging module logs system events in the Drupal database. "
"For more information, see the <a href=\":dblog\">online documentation "
"for the Database Logging module</a>."
msgstr ""
"מודול רישום מסד הנתונים רושם אירועי "
"מערכת במסד הנתונים של Drupal. למידע נוסף, "
"ראה את <a href=\":dblog\">התיעוד המקוון של "
"מודול רישום מסד הנתונים</a>."

msgid ""
"The Database Logging module allows you to view an event log on the <a "
"href=\":dblog\">Recent log messages</a> page. The log is a "
"chronological list of recorded events containing usage data, "
"performance data, errors, warnings and operational information. "
"Administrators should check the log on a regular basis to ensure their "
"site is working properly."
msgstr ""
"מודול רישום הנתונים מאפשר לך להציג "
"יומן אירועים בדף <a href=\":dblog\">הודעות "
"יומן אחרונות</a>. היומן הוא רשימה "
"כרונולוגית של אירועים מוקלטים המכילה "
"נתוני שימוש, נתוני ביצועים, שגיאות, "
"אזהרות ומידע תפעולי. על מנהלים לבדוק "
"את היומן באופן קבוע כדי לוודא שהאתר "
"שלהם פועל כראוי."

msgid ""
"In case of errors or problems with the site, the <a "
"href=\":dblog\">Recent log messages</a> page can be useful for "
"debugging, since it shows the sequence of events. The log messages "
"include usage information, warnings, and errors."
msgstr ""
"במקרה של שגיאות או בעיות באתר, הדף <a "
"href=\":dblog\">הודעות יומן אחרונות</a> יכול "
"להיות שימושי לאיתור באגים, מכיוון שהוא "
"מציג את רצף האירועים. הודעות היומן "
"כוללות מידע על השימוש, אזהרות ושגיאות."

msgid ""
"Pages which are suitable for caching are cached the first time they "
"are requested, then the cached version is served for all later "
"requests. Dynamic content is handled automatically so that both cache "
"correctness and hit ratio is maintained."
msgstr ""
"דפים המתאימים לאחסון במטמון מאוחסנים "
"במטמון בפעם הראשונה שהם מתבקשים, ולאחר "
"מכן הגרסה המאוחסנת במטמון מוצגת בכל "
"הבקשות הבאות. תוכן דינמי מטופל באופן "
"אוטומטי, כך שנשמרים הן נכונות המטמון "
"והן יחס הפגיעות."

msgid "Internal Dynamic Page Cache"
msgstr "מטמון דפים דינמי פנימי"

msgid ""
"On the <a href=\":formats\">Text formats and editors page</a> you can "
"see which text editor is associated with each text format. You can "
"change this by clicking on the <em>Configure</em> link, and then "
"choosing a text editor or <em>none</em> from the <em>Text editor</em> "
"drop-down list. The text editor will then be displayed with any text "
"field for which this text format is chosen."
msgstr ""
"בדף <a href=\":formats\">פורמטים ועורכי טקסט</a> "
"תוכל לראות איזה עורך טקסט משויך לכל "
"פורמט טקסט. ניתן לשנות זאת על ידי לחיצה "
"על הקישור <em>הגדר</em> ולאחר מכן בחירה "
"בעורך טקסט או <em>אף אחד</em> מהרשימה "
"הנפתחת <em>עורך טקסט</em>. עורך הטקסט יוצג "
"אז עם כל שדה טקסט שבחר בפורמט טקסט זה."

msgid ""
"The <em>settings</em> and the <em>display</em> of the entity reference "
"field can be configured separately. See the <a "
"href=\":field_ui\">Field UI help</a> for more information on how to "
"manage fields and their display."
msgstr ""
"ניתן להגדיר בנפרד את <em>ההגדרות</em> ואת "
"<em>התצוגה</em> של שדה הפניה לישות. ראה <a "
"href=\":field_ui\">עזרה לממשק המשתמש של השדה</a> "
"לקבלת מידע נוסף על אופן הניהול של שדות "
"ותצוגתם."

msgid ""
"No eligible views were found. <a href=\":create\">Create a view</a> "
"with an <em>Entity Reference</em> display, or add such a display to an "
"<a href=\":existing\">existing view</a>."
msgstr ""
"לא נמצאו תצוגות מתאימות. <a "
"href=\":create\">צור תצוגה</a> עם תצוגת <em>הפניה "
"לישות</em>, או הוסף תצוגה כזו לתצוגה <a "
"href=\":existing\">קיימת</a>."

msgid ""
"The Field module allows custom data fields to be defined for "
"<em>entity</em> types (see below). The Field module takes care of "
"storing, loading, editing, and rendering field data. Most users will "
"not interact with the Field module directly, but will instead use the "
"<a href=\":field-ui-help\">Field UI module</a> user interface. Module "
"developers can use the Field API to make new entity types "
"\"fieldable\" and thus allow fields to be attached to them. For more "
"information, see the <a href=\":field\">online documentation for the "
"Field module</a>."
msgstr ""
"מודול Field מאפשר להגדיר שדות נתונים "
"מותאמים אישית עבור סוגי <em>entity</em> (ראו "
"להלן). מודול Field אחראי על אחסון, טעינה, "
"עריכה והצגת נתוני השדה. רוב המשתמשים "
"לא יפעלו ישירות עם מודול Field, אלא "
"ישתמשו בממשק המשתמש של <a "
"href=\":field-ui-help\">מודול Field UI</a>. מפתחי "
"מודולים יכולים להשתמש ב-API של Field כדי "
"להפוך סוגי ישויות חדשים ל\"שמישים "
"לשדות\" וכך לאפשר לצרף אליהם שדות. "
"למידע נוסף, ראה <a href=\":field\">תיעוד מקוון "
"למודול Field</a>."

msgid ""
"You can add, edit, and delete view modes for entities on the <a "
"href=\":view_modes\">View modes page</a>, and you can add, edit, and "
"delete form modes for entities on the <a href=\":form_modes\">Form "
"modes page</a>. Once you have defined a view mode or form mode for an "
"entity type, it will be available on the Manage display or Manage form "
"display page for each sub-type of that entity."
msgstr ""
"ניתן להוסיף, לערוך ולמחוק מצבי תצוגה "
"עבור ישויות בדף <a href=\":view_modes\">מצבי "
"תצוגה</a>, וניתן להוסיף, לערוך ולמחוק "
"מצבי טופס עבור ישויות בדף <a "
"href=\":form_modes\">מצבי טופס</a>. לאחר שהגדרת "
"מצב תצוגה או מצב טופס עבור סוג ישות, "
"הוא יהיה זמין בדף 'ניהול תצוגה' או "
"'ניהול טופס' עבור כל תת-סוג של אותה "
"ישות."

msgid ""
"There are no fields yet added. You can add new fields on the <a "
"href=\":link\">Manage fields</a> page."
msgstr ""
"עדיין לא נוצרו שדות. ניתן להוסיף שדות "
"באמצעות הדף<a href=\":link\">ניהול שדות</a> page."

msgid ""
"The %display_mode mode now uses custom display settings. You might "
"want to <a href=\":url\">configure them</a>."
msgstr ""
"מצב %display_mode משתמש כעת בהגדרות תצוגה "
"מותאמות אישית. ייתכן שתרצה <a "
"href=\":url\">להגדיר אותן</a>."

msgid "@size limit."
msgstr "מוגבל ל @size."

msgid "file from @field_name"
msgstr "קובץ מ-@field_name"

msgid ""
"The File module allows you to create fields that contain files. See "
"the <a href=\":field\">Field module help</a> and the <a "
"href=\":field_ui\">Field UI help</a> pages for general information on "
"fields and how to create and manage them. For more information, see "
"the <a href=\":file_documentation\">online documentation for the File "
"module</a>."
msgstr ""
"מודול הקבצים מאפשר לך ליצור שדות "
"המכילים קבצים. ראה את דפי העזרה של "
"מודול השדות ושל ממשק המשתמש של השדות "
"לקבלת מידע כללי על שדות וכיצד ליצור "
"ולנהל אותם. לקבלת מידע נוסף, ראה את "
"התיעוד המקוון של מודול הקבצים."

msgid ""
"The <em>settings</em> and the <em>display</em> of the file field can "
"be configured separately. See the <a href=\":field_ui\">Field UI "
"help</a> for more information on how to manage fields and their "
"display."
msgstr ""
"ניתן להגדיר את <em>ההגדרות</em> ואת "
"<em>התצוגה</em> של שדה הקובץ בנפרד. ראה <a "
"href=\":field_ui\">עזרה לממשק המשתמש של השדה</a> "
"לקבלת מידע נוסף על אופן הניהול של שדות "
"ותצוגתם."

msgid ""
"Uploaded files can either be stored as <em>public</em> or "
"<em>private</em>, depending on the <a href=\":file-system\">File "
"system settings</a>. For more information, see the <a "
"href=\":system-help\">System module help page</a>."
msgstr ""
"קבצים שהועלו יכולים להיות מאוחסנים "
"כ<em>ציבוריים</em> או <em>פרטיים</em>, בהתאם "
"ל<a href=\":file-system\">הגדרות מערכת הקבצים</a>. "
"למידע נוסף, ראה <a href=\":system-help\">דף העזרה "
"של מודול המערכת</a>."

msgid "The file used in the @name field may not be referenced."
msgstr "לא ניתן להתייחס לקובץ המשמש בשדה @name."

msgid "The file referenced by the @name field does not exist."
msgstr "הקובץ המוזכר בשדה @name אינו קיים."

msgid "Use the <a href=\":url\">@label</a> text format"
msgstr "השתמש בפורמט הטקסט <a href=\":url\">@label</a>"

msgid ""
"If you do encounter problems, try using HTML character entities. A "
"common example looks like &amp;amp; for an ampersand &amp; character. "
"For a full list of entities see HTML's <a "
"href=\":html-entities\">entities</a> page. Some of the available "
"characters include:"
msgstr ""
"אם אתה נתקל בבעיות, נסה להשתמש ביחידות "
"תווים HTML. דוגמה נפוצה היא &amp;amp; עבור "
"התו &amp;. לרשימה המלאה של היחידות, ראה דף "
"היחידות של HTML <a href=\":html-entities\">entities</a>. "
"חלק מהתווים הזמינים כוללים:"

msgid "Limit allowed HTML tags and correct faulty HTML"
msgstr "הגבל תגי HTML מותרים ותקן HTML שגוי"

msgid ""
"<strong>Configure your website</strong> Once logged in, visit the <a "
"href=\":admin\">Administration page</a>, where you may <a "
"href=\":config\">customize and configure</a> all aspects of your "
"website."
msgstr ""
"<strong>הגדר את אתר האינטרנט שלך</strong> לאחר "
"הכניסה, בקר ב-<a href=\":admin\">דף הניהול</a>, "
"שבו תוכל <a href=\":config\">להתאים אישית "
"ולהגדיר</a> את כל ההיבטים של אתר "
"האינטרנט שלך."

msgid ""
"<strong>Customize your website design</strong> To change the \"look "
"and feel\" of your website, visit the <a href=\":themes\">Appearance "
"page</a>. You may choose from one of the included themes or download "
"additional themes from the <a href=\":download_themes\">Drupal.org "
"themes page</a>."
msgstr ""
"<strong>התאם אישית את עיצוב האתר שלך</strong> "
"כדי לשנות את המראה והתחושה של האתר שלך, "
"בקר ב<a href=\":themes\">דף המראה</a>. תוכל לבחור "
"מבין אחד מהערכות הנושא הכלולות או "
"להוריד ערכות נושא נוספות מ<a "
"href=\":download_themes\">דף ערכות הנושא של "
"Drupal.org</a>."

msgid ""
"<strong>Start posting content</strong> Finally, you may <a "
"href=\":content\">add new content</a> to your website."
msgstr ""
"<strong>התחל לפרסם תוכן</strong> לבסוף, תוכל <a "
"href=\":content\">להוסיף תוכן חדש</a> לאתר שלך."

msgid ""
"The Help module displays explanations for using each module listed on "
"the main <a href=\":help\">Help reference page</a>."
msgstr ""
"מודול העזרה מציג הסברים לשימוש בכל אחד "
"מהמודולים המפורטים בדף העזרה הראשי <a "
"href=\":help\">דף העזרה</a>."

msgid ""
"Page-specific help text provided by modules is displayed in the Help "
"block. This block can be placed and configured on the <a "
"href=\":blocks\">Block layout page</a>."
msgstr ""
"טקסט העזרה הספציפי לדף המסופק על ידי "
"מודולים מוצג בבלוק העזרה. ניתן למקם "
"ולהגדיר בלוק זה בדף <a href=\":blocks\">פריסת "
"בלוקים</a>."

msgid ""
"The History module keeps track of which content a user has read. It "
"marks content as <em>new</em> or <em>updated</em> depending on the "
"last time the user viewed it. History records that are older than one "
"month are removed during cron, which means that content older than one "
"month is always considered <em>read</em>. The History module does not "
"have a user interface but it provides a filter to <a "
"href=\":views-help\">Views</a> to show new or updated content. For "
"more information, see the <a href=\":url\">online documentation for "
"the History module</a>."
msgstr ""
"מודול ההיסטוריה עוקב אחר התוכן "
"שהמשתמש קרא. הוא מסמן תוכן כ<em>חדש</em> או "
"<em>מעודכן</em> בהתאם לפעם האחרונה "
"שהמשתמש צפה בו. רשומות היסטוריה שגילן "
"עולה על חודש מוסרות במהלך cron, כלומר "
"תוכן שגילו עולה על חודש נחשב תמיד "
"כ<em>נקרא</em>. למודול ההיסטוריה אין ממשק "
"משתמש, אך הוא מספק מסנן ל-<a "
"href=\":views-help\">Views</a> כדי להציג תוכן חדש או "
"מעודכן. למידע נוסף, ראה <a "
"href=\":url\">התיעוד המקוון של מודול "
"ההיסטוריה</a>."

msgid "image from @field_name"
msgstr "תמונה מ-@field_name"

msgid ""
"The Image module allows you to create fields that contain image files "
"and to configure <a href=\":image_styles\">Image styles</a> that can "
"be used to manipulate the display of images. See the <a "
"href=\":field\">Field module help</a> and the <a "
"href=\":field_ui\">Field UI help</a> pages for terminology and general "
"information on entities, fields, and how to create and manage fields. "
"For more information, see the <a href=\":image_documentation\">online "
"documentation for the Image module</a>."
msgstr ""
"מודול התמונה מאפשר לך ליצור שדות "
"המכילים קבצי תמונה ולהגדיר <a "
"href=\":image_styles\">סגנונות תמונה</a> שניתן "
"להשתמש בהם כדי לשלוט בתצוגת התמונות. "
"עיין בעזרה של מודול השדות <a "
"href=\":field\">Field module help</a> ובעזרה של ממשק "
"המשתמש של השדות <a href=\":field_ui\">Field UI help</a> "
"לקבלת מידע כללי על ישויות, שדות וכיצד "
"ליצור ולנהל שדות. למידע נוסף, ראה <a "
"href=\":image_documentation\">תיעוד מקוון למודול "
"התמונה</a>."

msgid ""
"The concept of image styles is that you can upload a single image but "
"display it in several ways; each display variation, or <em>image "
"style</em>, is the result of applying one or more <em>effects</em> to "
"the original image. As an example, you might upload a high-resolution "
"image with a 4:3 aspect ratio, and display it scaled down, square "
"cropped, or black-and-white (or any combination of these effects). The "
"Image module provides a way to do this efficiently: you configure an "
"image style with the desired effects on the <a href=\":image\">Image "
"styles page</a>, and the first time a particular image is requested in "
"that style, the effects are applied. The resulting image is saved, and "
"the next time that same style is requested, the saved image is "
"retrieved without the need to recalculate the effects. Drupal core "
"provides several effects that you can use to define styles; others may "
"be provided by contributed modules."
msgstr ""
"הרעיון של סגנונות תמונה הוא שאתה יכול "
"להעלות תמונה אחת, אך להציג אותה בכמה "
"דרכים שונות; כל וריאציה של תצוגה, או "
"<em>סגנון תמונה</em>, היא תוצאה של החלת "
"אפקט אחד או יותר על התמונה המקורית. "
"לדוגמה, ניתן להעלות תמונה ברזולוציה "
"גבוהה ביחס רוחב-גובה של 4:3, ולהציג אותה "
"בקנה מידה מוקטן, חתוכה למלבן או "
"בשחור-לבן (או כל שילוב של אפקטים אלה). "
"מודול התמונה מספק דרך יעילה לעשות זאת: "
"אתה מגדיר סגנון תמונה עם האפקטים "
"הרצויים בדף <a href=\":image\">סגנונות "
"תמונה</a>, ובפעם הראשונה שתמונה מסוימת "
"מתבקשת בסגנון זה, האפקטים מוחלים. "
"התמונה המתקבלת נשמרת, ובפעם הבאה שאותו "
"סגנון מתבקש, התמונה השמורה נשלפת ללא "
"צורך בחישוב מחדש של האפקטים. ליבת Drupal "
"מספקת מספר אפקטים שניתן להשתמש בהם "
"להגדרת סגנונות; אפקטים אחרים עשויים "
"להיות מסופקים על ידי מודולים שנוספו."

msgid ""
"When you create an image field, you will need to choose whether the "
"uploaded images will be stored in the public or private file directory "
"defined in your settings.php file and shown on the <a "
"href=\":file-system\">File system page</a>. This choice cannot be "
"changed later. You can also configure your field to store files in a "
"subdirectory of the public or private directory; this setting can be "
"changed later and can be different for each entity sub-type using the "
"field. For more information on file storage, see the <a "
"href=\":system-help\">System module help page</a>."
msgstr ""
"בעת יצירת שדה תמונה, עליך לבחור אם "
"התמונות שהועלו יאוחסנו בספריית הקבצים "
"הציבורית או הפרטית המוגדרת בקובץ "
"settings.php שלך ומוצגת בדף <a "
"href=\":file-system\">מערכת הקבצים</a>. בחירה זו "
"לא ניתנת לשינוי בהמשך. ניתן גם להגדיר "
"את השדה לאחסון קבצים בספריית משנה של "
"הספרייה הציבורית או הפרטית; הגדרה זו "
"ניתנת לשינוי מאוחר יותר וניתן לשנות "
"אותה עבור כל תת-סוג ישות המשתמש בשדה. "
"למידע נוסף על אחסון קבצים, ראה <a "
"href=\":system-help\">דף העזרה של מודול "
"המערכת</a>."

msgid "There are currently no styles. <a href=\":url\">Add a new one</a>."
msgstr ""
"כרגע אין סגנונות. <a href=\":url\">הוסף סגנון "
"חדש</a>."

msgid "Both a height and width value must be specified in the @name field."
msgstr "יש לציין את ערכי הגובה והרוחב בשדה @name."

msgid "The primary identifier for an image style."
msgstr "המזהה העיקרי של סגנון תמונה."

msgid "The style machine name."
msgstr "שם מכונת הסגנון."

msgid "The style administrative name."
msgstr "שם הסגנון לצורך ניהול"

msgid ""
"By default, content is created in the site's default language and no "
"language selector is displayed on content creation pages. On the <a "
"href=\":content_language\">Content language</a> page you can customize "
"the language configuration for any supported content entity on your "
"site (for example for content types or menu links). After choosing an "
"entity, you are provided with a drop-down menu to set the default "
"language and a check-box to display language selectors."
msgstr ""
"כברירת מחדל, התוכן נוצר בשפת ברירת "
"המחדל של האתר ולא מוצג בורר שפה בדפי "
"יצירת התוכן. בדף <a href=\":content_language\">שפת "
"תוכן</a> תוכל להתאים אישית את תצורת השפה "
"עבור כל ישות תוכן נתמכת באתר שלך "
"(לדוגמה, עבור סוגי תוכן או קישורי "
"תפריט). לאחר בחירת ישות, תוצג בפניך "
"תפריט נפתח להגדרת שפת ברירת המחדל "
"ותיבת סימון להצגת בוררי שפה."

msgid ""
"The <a href=\":detection\">Detection and selection</a> page provides "
"several methods for deciding which language is used for displaying "
"interface text. When a method detects and selects an interface "
"language, then the following methods in the list are not applied. You "
"can order them by importance, with your preferred method at the top of "
"the list, followed by one or several fall-back methods."
msgstr ""
"הדף <a href=\":detection\">זיהוי ובחירה</a> מציע "
"מספר שיטות להחלטה איזו שפה תציג את "
"טקסט הממשק. כאשר שיטה מסוימת מזהה "
"ובוחרת שפת ממשק, השיטות הבאות ברשימה "
"אינן מיושמות. ניתן לסדר אותן לפי "
"חשיבות, כאשר השיטה המועדפת נמצאת בראש "
"הרשימה, ואחריה אחת או מספר שיטות "
"חלופיות."

msgid ""
"<em>Browser</em> sets the interface language based on the browser's "
"language settings. Since browsers use different language codes to "
"refer to the same languages, you can add and edit languages codes to "
"map the browser language codes to the <a "
"href=\":language_list\">language codes</a> used on your site."
msgstr ""
"<em>דפדפן</em> קובע את שפת הממשק על סמך "
"הגדרות השפה של הדפדפן. מכיוון שדפדפנים "
"משתמשים בקודי שפה שונים כדי להתייחס "
"לאותן שפות, ניתן להוסיף ולערוך קודי "
"שפה כדי להתאים את קודי השפה של הדפדפן "
"לקודי השפה <a href=\":language_list\">המשמשים באתר "
"שלך."

msgid ""
"Reorder the configured languages to set their order in the language "
"switcher block and, when editing content, in the list of selectable "
"languages. This ordering does not impact <a "
"href=\":detection\">detection and selection</a>."
msgstr ""
"סדרו מחדש את השפות המוגדרות כדי לשנות "
"את הסדר שבו יופיעו בבלוק החלפת השפה, "
"ובעת עריכת תכנים, גם ברשימת השפות "
"שניתן לבחור מהן. סידור זה לא ישפיע על <a "
"href=\":detection\">זיהוי ובחירה</a>."

msgid ""
"The site default language can also be set. It is not recommended to "
"change the default language on a working site. <a "
"href=\":language-detection\">Configure the Selected language</a> "
"setting on the detection and selection page to change the fallback "
"language for language selection."
msgstr ""
"ניתן גם להגדיר את שפת ברירת המחדל של "
"האתר. לא מומלץ לשנות את שפת ברירת המחדל "
"באתר פעיל. <a href=\":language-detection\">הגדר את "
"השפה הנבחרת</a> בהגדרות בדף הזיהוי "
"והבחירה כדי לשנות את שפת הגיבוי לבחירת "
"השפה."

msgid ""
"Define how to decide which language is used to display page elements "
"(primarily text provided by modules, such as field labels and help "
"text). This decision is made by evaluating a series of detection "
"methods for languages; the first detection method that gets a result "
"will determine which language is used for that type of text. Be aware "
"that some language detection methods are unreliable under certain "
"conditions, such as browser detection when page-caching is enabled and "
"a user is not currently logged in. Define the order of evaluation of "
"language detection methods on this page. The default language can be "
"changed in the <a href=\":admin-change-language\">list of "
"languages</a>."
msgstr ""
"הגדר כיצד להחליט איזו שפה תציג את "
"רכיבי הדף (בעיקר טקסט המסופק על ידי "
"מודולים, כגון תוויות שדה וטקסט עזרה). "
"החלטה זו מתקבלת על ידי הערכת סדרה של "
"שיטות זיהוי שפות; שיטת הזיהוי הראשונה "
"שתקבל תוצאה תקבע איזו שפה תציג את סוג "
"הטקסט הזה. יש לשים לב כי שיטות זיהוי "
"שפה מסוימות אינן אמינות בתנאים "
"מסוימים, כגון זיהוי דפדפן כאשר מטמון "
"הדף מופעל והמשתמש אינו מחובר כרגע. "
"הגדר את סדר הערכת שיטות זיהוי השפה בדף "
"זה. ניתן לשנות את שפת ברירת המחדל ב<a "
"href=\":admin-change-language\">רשימת השפות</a>."

msgid ""
"Browsers use different language codes to refer to the same languages. "
"Internally, a best effort is made to determine the correct language "
"based on the code that the browser sends. You can add and edit "
"additional mappings from browser language codes to <a "
"href=\":configure-languages\">site languages</a>."
msgstr ""
"דפדפנים משתמשים בקודי שפה שונים כדי "
"להתייחס לאותן שפות. באופן פנימי, נעשה "
"מאמץ רב כדי לקבוע את השפה הנכונה על סמך "
"הקוד שהדפדפן שולח. ניתן להוסיף ולערוך "
"מיפויים נוספים מקודי שפת הדפדפן לשפות "
"האתר."

msgid ""
"Changing the selected language here (and leaving this option as the "
"last among the detection and selection options) is the easiest way to "
"change the fallback language for the website, if you need to change "
"how your site works by default (e.g., when using an empty path prefix "
"or using the default domain). <a "
"href=\":admin-change-language\">Changing the site's default "
"language</a> itself might have other undesired side effects."
msgstr ""
"שינוי השפה הנבחרת כאן (והשארת אפשרות "
"זו כאחרונה מבין אפשרויות הזיהוי "
"והבחירה) היא הדרך הקלה ביותר לשנות את "
"שפת הגיבוי של האתר, אם אתה צריך לשנות "
"את אופן הפעולה של האתר כברירת מחדל "
"(למשל, כאשר אתה משתמש בקידומת נתיב ריקה "
"או משתמש בדומיין ברירת המחדל). <a "
"href=\":admin-change-language\">שינוי שפת ברירת "
"המחדל של האתר</a> עצמו עלול לגרום "
"לתופעות לוואי לא רצויות אחרות."

msgid ""
"Explanation of the language options is found on the <a "
"href=\":languages_list_page\">languages list page</a>."
msgstr ""
"הסבר על אפשרויות שפה ניתן למצוא ב <a "
"href=\":languages_list_page\">דף רשימת השפות</a>."

msgid "Site's default language (@language)"
msgstr "שפת ברירת המחדל של האתר (@language)"

msgid ""
"Use one of the language switcher blocks to allow site visitors to "
"switch between languages. You can enable these blocks on the <a "
"href=\":block-admin\">block administration page</a>."
msgstr ""
"השתמש באחד מבלוקי החלפת השפה כדי לאפשר "
"למבקרים באתר לעבור בין שפות. ניתן "
"להפעיל בלוקים אלה בדף <a "
"href=\":block-admin\">ניהול הבלוקים</a>."

msgid ""
"Use language codes as <a href=\":w3ctags\">defined by the W3C</a> for "
"interoperability. <em>Examples: \"en\", \"en-gb\" and "
"\"zh-hant\".</em>"
msgstr ""
"השתמש בקודי שפה כפי ש<a "
"href=\":w3ctags\">הוגדרו על ידי W3C</a> לצורך "
"תאימות. <em>דוגמאות: \"en\", \"en-gb\" "
"ו-\"zh-hant\".</em>"

msgid ""
"%field must be a valid language tag as <a href=\":url\">defined by the "
"W3C</a>."
msgstr ""
"%field חייב להיות תג שפה תקף כפי <a "
"href=\":url\">שהוגדר על ידי W3C</a>."

msgid ""
"The prefix may only be left blank for the <a href=\":url\">selected "
"detection fallback language.</a>"
msgstr ""
"ניתן להשאיר את הקידומת ריקה רק עבור <a "
"href=\":url\">שפת הגיבוי שנבחרה לזיהוי.</a>"

msgid ""
"The Link module allows you to create fields that contain internal or "
"external URLs and optional link text. See the <a href=\":field\">Field "
"module help</a> and the <a href=\":field_ui\">Field UI help</a> pages "
"for general information on fields and how to create and manage them. "
"For more information, see the <a href=\":link_documentation\">online "
"documentation for the Link module</a>."
msgstr ""
"מודול Link מאפשר לך ליצור שדות המכילים "
"כתובות URL פנימיות או חיצוניות וטקסט "
"קישור אופציונלי. עיין בעמודי <a "
"href=\":field\">עזרה למודול Field</a> ו- <a "
"href=\":field_ui\">עזרה לממשק המשתמש של Field</a> "
"לקבלת מידע כללי על שדות וכיצד ליצור "
"ולנהל אותם. לקבלת מידע נוסף, עיין ב- <a "
"href=\":link_documentation\">תיעוד מקוון למודול "
"Link</a>."

msgid ""
"The <em>settings</em> and the <em>display</em> of the link field can "
"be configured separately. See the <a href=\":field_ui\">Field UI "
"help</a> for more information on how to manage fields and their "
"display."
msgstr ""
"ניתן להגדיר את <em>ההגדרות</em> ואת "
"<em>התצוגה</em> של שדה הקישור בנפרד. ראה <a "
"href=\":field_ui\">עזרה לממשק המשתמש של השדה</a> "
"לקבלת מידע נוסף על אופן הניהול של שדות "
"ותצוגתם."

msgid ""
"One translation file could not be checked. <a href=\":url\">See the "
"log</a> for details."
msgid_plural ""
"@count translation files could not be checked. <a href=\":url\">See "
"the log</a> for details."
msgstr[0] ""
"לא ניתן לבדוק קובץ תרגום אחד.  <a "
"href=\":url\"> ברשומות היומן פרטים</a>."
msgstr[1] ""
"לא ניתן לבדוק @count קבצי תרגום.  <a "
"href=\":url\"> ברשומות היומן פרטים</a>."

msgid "@message (@percent%)."
msgstr "@message (@percent%)."

msgid ""
"One translation file could not be imported. <a href=\":url\">See the "
"log</a> for details."
msgid_plural ""
"@count translation files could not be imported. <a href=\":url\">See "
"the log</a> for details."
msgstr[0] ""
"לא ניתן היה לייבא קובץ תרגום אחד. <a "
"href=\":url\">לפרטים נוספים, עיין ביומן</a>."

msgid ""
"One translation string was skipped because of disallowed or malformed "
"HTML. <a href=\":url\">See the log</a> for details."
msgid_plural ""
"@count translation strings were skipped because of disallowed or "
"malformed HTML. <a href=\":url\">See the log</a> for details."
msgstr[0] ""
"מחרוזת טקסט אחת דולגה מכיוון שהיא "
"מכילה HTML לא מורשה או פגום. ראו <a "
"href=\":url\"> פרטים נוספים בLog</a>."
msgstr[1] ""
"@count מחרוזות טקסט דולגו מכיוון שהן "
"מכילות HTML לא מורשה או פגום. ראו <a "
"href=\":url\"> פרטים נוספים בLog</a>."

msgid ""
"The Interface Translation module allows you to translate interface "
"text (<em>strings</em>) into different languages, and to switch "
"between them for the display of interface text. It uses the "
"functionality provided by the <a href=\":language\">Language "
"module</a>. For more information, see the <a href=\":doc-url\">online "
"documentation for the Interface Translation module</a>."
msgstr ""
"מודול תרגום הממשק מאפשר לך לתרגם טקסט "
"ממשק (<em>מחרוזות</em>) לשפות שונות, ולעבור "
"ביניהן לצורך הצגת טקסט הממשק. הוא "
"משתמש בפונקציונליות שמספק <a "
"href=\":language\">מודול השפה</a>. למידע נוסף, "
"ראה <a href=\":doc-url\">תיעוד מקוון למודול "
"תרגום הממשק</a>."

msgid ""
"You can check how much of the interface on your site is translated "
"into which language on the <a href=\":languages\">Languages</a> page. "
"On the <a href=\":translation-updates\">Available translation "
"updates</a> page, you can check whether interface translation updates "
"are available on the <a href=\":server\">Drupal translation "
"server</a>."
msgstr ""
"ניתן לבדוק כמה מהממשק באתר שלך תורגם "
"לאיזו שפה בדף <a href=\":languages\">שפות</a>. בדף "
"<a href=\":translation-updates\">עדכוני תרגום "
"זמינים</a>, ניתן לבדוק אם עדכוני תרגום "
"לממשק זמינים בשרת התרגום של Drupal."

msgid ""
"You can translate individual strings directly on the <a "
"href=\":translate\">User interface translation</a> page, or download "
"the currently-used translation file for a specific language on the <a "
"href=\":export\">Interface translation export</a> page. Once you have "
"edited the translation file, you can then import it again on the <a "
"href=\":import\">Interface translation import</a> page."
msgstr ""
"ניתן לתרגם מחרוזות בודדות ישירות בדף <a "
"href=\":translate\">תרגום ממשק המשתמש</a>, או "
"להוריד את קובץ התרגום המשמש כרגע לשפה "
"ספציפית בדף <a href=\":export\">ייצוא תרגום "
"ממשק</a>. לאחר עריכת קובץ התרגום, ניתן "
"לייבא אותו שוב בדף <a href=\":import\">ייבוא "
"תרגום ממשק</a>."

msgid ""
"This page allows a translator to search for specific translated and "
"untranslated strings, and is used when creating or editing "
"translations. (Note: Because translation tasks involve many strings, "
"it may be more convenient to <a title=\"User interface translation "
"export\" href=\":export\">export</a> strings for offline editing in a "
"desktop Gettext translation editor.) Searches may be limited to "
"strings in a specific language."
msgstr ""
"דף זה מאפשר למתרגמים לחפש מחרוזות טקסט "
"לצורך תרגומן. הערה: מכיוון שמשימות "
"תרגום עשויה לכלול מחרוזות טקסט מרובות, "
"ייתכן שיהיה נוח יותר <a title=\"User interface "
"interface export\" href=\":export\"> לייצא </a> מחרוזות "
"לצורך עריכה בתוכנה ייעודית לתרגומי  "
"Gettext. ניתן להגביל את החיפושים לשפה "
"ספציפית."

msgid ""
"This page allows translators to manually import translated strings "
"contained in a Gettext Portable Object (.po) file. Manual import may "
"be used for customized translations or for the translation of custom "
"modules and themes. To customize translations you can download a "
"translation file from the <a href=\":url\">Drupal translation "
"server</a> or <a title=\"User interface translation export\" "
"href=\":export\">export</a> translations from the site, customize the "
"translations using a Gettext translation editor, and import the result "
"using this page."
msgstr ""
"דף זה מאפשר למתרגמים לייבא באופן ידני "
"אוסף של מחרוזות מתורגמות הכלולות "
"בקובץ תרגום מסוג  Gettext Portable Object, בסיומת "
"po. יבוא כזה מאפשר לכם לדרוס את התרגומים "
"שיובאו אוטומטית משרת התרגומים של "
"דרופל באמצעות ביטויים שהותאמו במיוחד "
"לצרכי האתר שלכם. באותו אופן ניתן לייבא "
"תרגומים עבור מודולים ועיצובים שנוצרו "
"במיוחד עבור האתר ומטבע הדברים התרגום "
"עבורם אינו זמין להורדה משרת התרגומים "
"של דרופל. באשר מתעורר הצורך להתאים "
"תרגומים קיימים ניתן להוריד, לצורך "
"עריכה, את קבצי התרגום המקוריים מ <a "
"href=\":url\"> שרת התרגומים של דרופל </a>. "
"לחילופין ניתן להשיג קובץ תרגום לצורך "
"עריכה באמצעות<a title=\"יצוא תרגום הממשק\" "
"href=\":export\"> יצוא </a>התרגומים מהאתר. מומלץ "
"לבצע עריכת קבצי תרגום באמצעות תכנת "
"עריכה ייעודית לתרגמומים מסוג  Gettext, ואז "
"לייבא את התוצאה באמצעות דף זה."

msgid ""
"Updates available for: @languages. See the <a "
"href=\":updates\">Available translation updates</a> page for more "
"information."
msgstr ""
"עדכונים זמינים עבור: @languages. ראה את הדף "
"<a href=\":updates\">עדכוני תרגום זמינים</a> "
"לקבלת מידע נוסף."

msgid ""
"Missing translations for: @languages. See the <a "
"href=\":updates\">Available translation updates</a> page for more "
"information."
msgstr ""
"חסרים תרגומים עבור: @languages. ראו מידע "
"נוסף בדף <a href=\":updates\"> עדכונים זמינים "
"</a>."

msgid ""
"No translation status is available. See the <a "
"href=\":updates\">Available translation updates</a> page for more "
"information."
msgstr ""
"אין סטטוס תרגום זמין. ראה את הדף <a "
"href=\":updates\">עדכוני תרגום זמינים</a> לקבלת "
"מידע נוסף."

msgid "Interface translation settings"
msgstr "הגדרות תרגום הממשק"

msgid "Interface translation import"
msgstr "ייבוא תרגומי ממשק"

msgid "Interface translation export"
msgstr "יצוא תרגומי ממשק"

msgid ""
"Select how frequently you want to check for new interface translations "
"for your currently installed modules and themes. <a "
"href=\":url\">Check updates now</a>."
msgstr ""
"בחרו באיזו תדירות לבדוק אם קיימים "
"תרגומים חדשים עבור מודולים וערכות "
"עיצוב שמותקנים באתר <a href=\":url\">בדיקת "
"עדכונים כעת</a>."

msgid ""
"Translation files are stored locally in the  %path directory. You can "
"change this directory on the <a href=\":url\">File system</a> "
"configuration page."
msgstr ""
"קבצי תרגום מאוכסנים מקומית בתיקיה %path. "
"ניתן לשנות זאת בדף ההגדרות של <a "
"href=\":url\">מערכת הקבצים</a>"

msgid ""
"Translation files will not be stored locally. Change the Interface "
"translation directory on the <a href=\":url\">File system "
"configuration</a> page."
msgstr ""
"קובצי התרגום לא יאוחסנו באופן מקומי. "
"שנה את ספריית התרגום של הממשק בדף <a "
"href=\":url\">תצורת מערכת הקבצים</a>."

msgid ""
"You have selected local translation source, but no <a "
"href=\":url\">Interface translation directory</a> was configured."
msgstr ""
"בחרת מקור תרגום מקומי, אך לא הוגדר <a "
"href=\":url\">ספריית תרגום ממשק</a>."

msgid ""
"No translatable languages available. <a href=\":add_language\">Add a "
"language</a> first."
msgstr ""
"אין שפות ניתנות לתרגום. <a "
"href=\":add_language\">הוסף שפה</a> תחילה."

msgid ""
"No translation status available. <a href=\":check\">Check "
"manually</a>."
msgstr ""
"אין סטטוס תרגום זמין. <a href=\":check\">בדוק "
"ידנית</a>."

msgid ""
"It is required by the Menu UI module, which provides an interface for "
"managing menus and menu links. For more information, see the <a "
"href=\":menu-help\">Menu UI module help page</a> and the <a "
"href=\":drupal-org-help\">online documentation for the Custom Menu "
"Links module</a>."
msgstr ""
"זה נדרש על ידי מודול ממשק המשתמש של "
"התפריט, המספק ממשק לניהול תפריטים "
"וקישורי תפריט. למידע נוסף, ראה <a "
"href=\":menu-help\">דף העזרה של מודול ממשק "
"המשתמש של התפריט</a> ו-<a "
"href=\":drupal-org-help\">התיעוד המקוון של מודול "
"קישורי תפריט מותאמים אישית</a>."

msgid ""
"The Menu UI module provides an interface for managing menus. A menu is "
"a hierarchical collection of links, which can be within or external to "
"the site, generally used for navigation. For more information, see the "
"<a href=\":menu\">online documentation for the Menu UI module</a>."
msgstr ""
"מודול ממשק המשתמש של התפריט מספק ממשק "
"לניהול תפריטים. תפריט הוא אוסף היררכי "
"של קישורים, שיכולים להיות בתוך האתר או "
"מחוצה לו, ומשמשים בדרך כלל לניווט. "
"למידע נוסף, ראה <a href=\":menu\">התיעוד "
"המקוון של מודול ממשק המשתמש של "
"התפריט</a>."

msgid ""
"You can enable the newly-created block for this menu on the <a "
"href=\":blocks\">Block layout page</a>."
msgstr ""
"ניתן להפעיל את הבלוק החדש שנוצר עבור "
"תפריט זה בדף <a href=\":blocks\">Block layout page</a>."

msgid ""
"Each menu has a corresponding block that is managed on the <a "
"href=\":blocks\">Block layout page</a>."
msgstr ""
"עבור כל אחד מהתפריטים קיים בלוק "
"ייעודי. כך שניתן להגדיר איך והיכן יוצג "
"ב<a href=\":blocks\">דף ניהול הבלוקים</a>."

msgid "There are no menu links yet. <a href=\":url\">Add link</a>."
msgstr ""
"לא נוצרו עדיין קישורי תפריט. <a "
"href=\":url\">יצירת קישור</a>."

msgid ""
"The Migrate module provides a framework for migrating data, usually "
"from an external source into your site. It does not provide a user "
"interface. For more information, see the <a href=\":migrate\">online "
"documentation for the Migrate module</a>."
msgstr ""
"מודול Migrate מספק מסגרת להעברת נתונים, "
"בדרך כלל ממקור חיצוני לאתר שלך. הוא "
"אינו מספק ממשק משתמש. למידע נוסף, ראה <a "
"href=\":migrate\">התיעוד המקוון של מודול "
"Migrate</a>."

msgid ""
"The Migrate Drupal module provides a framework based on the <a "
"href=\":migrate\">Migrate module</a> to facilitate migration from a "
"Drupal (6, 7, or 8) site to your website. It does not provide a user "
"interface. For more information, see the <a "
"href=\":migrate_drupal\">online documentation for the Migrate Drupal "
"module</a>."
msgstr ""
"מודול Migrate Drupal מספק מסגרת המבוססת על <a "
"href=\":migrate\">מודול Migrate</a> כדי להקל על "
"המעבר מאתר Drupal (6, 7 או 8) לאתר שלך. הוא "
"אינו מספק ממשק משתמש. למידע נוסף, עיין "
"ב<a href=\":migrate_drupal\">תיעוד מקוון למודול "
"Migrate Drupal</a>."

msgid ""
"The content access permissions need to be rebuilt. <a "
"href=\":node_access_rebuild\">Rebuild permissions</a>."
msgstr ""
"יש לבנות מחדש את הרשאות הגישה לתוכן. <a "
"href=\":node_access_rebuild\">בנה מחדש את ההרשאות</a>."

msgid ""
"The Node module manages the creation, editing, deletion, settings, and "
"display of the main site content. Content items managed by the Node "
"module are typically displayed as pages on your site, and include a "
"title, some meta-data (author, creation time, content type, etc.), and "
"optional fields containing text or other data (fields are managed by "
"the <a href=\":field\">Field module</a>). For more information, see "
"the <a href=\":node\">online documentation for the Node module</a>."
msgstr ""
"מודול Node מנהל את יצירת, עריכת, מחיקת, "
"הגדרות ותצוגת תוכן האתר הראשי. פריטי "
"תוכן המנוהלים על ידי מודול Node מוצגים "
"בדרך כלל כדפים באתר שלך, וכוללים כותרת, "
"כמה מטא-נתונים (מחבר, זמן יצירה, סוג "
"תוכן וכו') ושדות אופציונליים המכילים "
"טקסט או נתונים אחרים (השדות מנוהלים על "
"ידי <a href=\":field\">מודול Field</a>). למידע נוסף, "
"ראה <a href=\":node\">תיעוד מקוון למודול Node</a>."

msgid ""
"When new content is created, the Node module records basic information "
"about the content, including the author, date of creation, and the <a "
"href=\":content-type\">Content type</a>. It also manages the "
"<em>publishing options</em>, which define whether or not the content "
"is published, promoted to the front page of the site, and/or sticky at "
"the top of content lists. Default settings can be configured for each "
"<a href=\":content-type\">type of content</a> on your site."
msgstr ""
"כאשר נוצר תוכן חדש, מודול Node רושם מידע "
"בסיסי אודות התוכן, כולל המחבר, תאריך "
"היצירה ו<a href=\":content-type\">סוג התוכן</a>. הוא "
"גם מנהל את <em>אפשרויות הפרסום</em>, "
"הקובעות אם התוכן יפורסם, יקודם לעמוד "
"הראשי של האתר ו/או יופיע בראש רשימות "
"התוכן. ניתן להגדיר הגדרות ברירת מחדל "
"עבור כל <a href=\":content-type\">סוג תוכן</a> באתר "
"שלך."

msgid ""
"The Node module gives users with the <em>Administer content types</em> "
"permission the ability to <a href=\":content-new\">create new content "
"types</a> in addition to the default ones already configured. Creating "
"custom content types gives you the flexibility to add <a "
"href=\":field\">fields</a> and configure default settings that suit "
"the differing needs of various site content."
msgstr ""
"מודול Node מעניק למשתמשים בעלי הרשאת "
"<em>ניהול סוגי תוכן</em> את היכולת <a "
"href=\":content-new\">ליצור סוגי תוכן חדשים</a> "
"בנוסף לסוגי התוכן המוגדרים כברירת "
"מחדל. יצירת סוגי תוכן מותאמים אישית "
"מעניקה לך את הגמישות להוסיף <a "
"href=\":field\">שדות</a> ולהגדיר הגדרות ברירת "
"מחדל המתאימות לצרכים השונים של תוכן "
"האתר."

msgid ""
"The <a href=\":content\">Content</a> page lists your content, allowing "
"you add new content, filter, edit or delete existing content, or "
"perform bulk operations on existing content."
msgstr ""
"הדף <a href=\":content\">תוכן</a> מפרט את התוכן "
"שלך, ומאפשר לך להוסיף תוכן חדש, לסנן, "
"לערוך או למחוק תוכן קיים, או לבצע "
"פעולות מרובות על תוכן קיים."

msgid ""
"The Node module makes a number of permissions available for each "
"content type, which can be set by role on the <a "
"href=\":permissions\">permissions page</a>."
msgstr ""
"מודול Node מספק מספר הרשאות עבור כל סוג "
"תוכן, שניתן להגדיר לפי תפקיד בדף "
"ההרשאות."

msgid ""
"If the site is experiencing problems with permissions to content, you "
"may have to rebuild the permissions cache. Rebuilding will remove all "
"privileges to content and replace them with permissions based on the "
"current modules and settings. Rebuilding may take some time if there "
"is a lot of content or complex permission settings. After rebuilding "
"has completed, content will automatically use the new permissions. <a "
"href=\":rebuild\">Rebuild permissions</a>"
msgstr ""
"אם האתר נתקל בבעיות בהרשאות לתוכן, "
"ייתכן שתצטרך לבנות מחדש את מטמון "
"ההרשאות. בנייה מחדש תסיר את כל ההרשאות "
"לתוכן ותחליף אותן בהרשאות המבוססות על "
"המודולים וההגדרות הנוכחיים. בנייה "
"מחדש עשויה לארוך זמן מה אם יש תוכן רב "
"או הגדרות הרשאה מורכבות. לאחר השלמת "
"הבנייה מחדש, התוכן ישתמש באופן אוטומטי "
"בהרשאות החדשות. <a href=\":rebuild\">בנה מחדש "
"הרשאות</a>"

msgid ""
"Maintain the types of content available and the fields that are "
"associated with those types."
msgstr ""
"שמור על סוגי התוכן הזמינים ועל השדות "
"הקשורים לסוגים אלה."

msgid "No content types available. <a href=\":link\">Add content type</a>."
msgstr ""
"אין סוגי תוכן זמינים. <a href=\":link\">הוסף "
"סוג תוכן</a>."

msgid "Node from URL"
msgstr "צומת מ-URL"

msgid ""
"The Options module allows you to create fields where data values are "
"selected from a fixed list of options. Usually these items are entered "
"through a select list, checkboxes, or radio buttons. See the <a "
"href=\":field\">Field module help</a> and the <a "
"href=\":field_ui\">Field UI help</a> pages for general information on "
"fields and how to create and manage them. For more information, see "
"the <a href=\":options_do\">online documentation for the Options "
"module</a>."
msgstr ""
"מודול האפשרויות מאפשר לך ליצור שדות "
"שבהם ערכי הנתונים נבחרים מרשימה קבועה "
"של אפשרויות. בדרך כלל פריטים אלה "
"מוזנים באמצעות רשימה נבחרת, תיבות "
"סימון או כפתורי בחירה. ראה את העזרה של "
"מודול השדות ואת העזרה של ממשק המשתמש "
"של השדות לקבלת מידע כללי על שדות וכיצד "
"ליצור ולנהל אותם. למידע נוסף, ראה <a "
"href=\":options_do\">תיעוד מקוון למודול "
"אפשרויות</a>."

msgid ""
"The <em>settings</em> and the <em>display</em> of the list fields can "
"be configured separately. See the <a href=\":field_ui\">Field UI "
"help</a> for more information on how to manage fields and their "
"display."
msgstr ""
"ניתן להגדיר את <em>ההגדרות</em> ואת "
"<em>התצוגה</em> של שדות הרשימה בנפרד. ראה <a "
"href=\":field_ui\">עזרה לממשק המשתמש של השדה</a> "
"לקבלת מידע נוסף על אופן הניהול של שדות "
"ותצוגתם."

msgid ""
"The Internal Page Cache module caches pages for anonymous users in the "
"database. For more information, see the <a "
"href=\":pagecache-documentation\">online documentation for the "
"Internal Page Cache module</a>."
msgstr ""
"מודול המטמון הפנימי של הדף מאחסן דפים "
"עבור משתמשים אנונימיים בבסיס הנתונים. "
"למידע נוסף, ראה <a "
"href=\":pagecache-documentation\">תיעוד מקוון למודול "
"המטמון הפנימי של הדף</a>."

msgid ""
"Pages are usually identical for all anonymous users, while they can be "
"personalized for each authenticated user. This is why entire pages can "
"be cached for anonymous users, whereas they will have to be rebuilt "
"for every authenticated user."
msgstr ""
"הדפים זהים בדרך כלל לכל המשתמשים "
"האנונימיים, אך ניתן להתאים אותם אישית "
"לכל משתמש מאומת. לכן ניתן לאחסן דפים "
"שלמים במטמון עבור משתמשים אנונימיים, "
"בעוד שעבור כל משתמש מאומת יש לבנות "
"אותם מחדש."

msgid ""
"To speed up your site for authenticated users, see the <a "
"href=\":dynamic_page_cache-help\">Dynamic Page Cache module</a>."
msgstr ""
"כדי להאיץ את האתר עבור משתמשים "
"מאומתים, ראה את <a "
"href=\":dynamic_page_cache-help\">מודול המטמון הדינמי "
"של הדף</a>."

msgid ""
"The Path module allows you to specify an alias, or custom URL, for any "
"existing internal system path. Aliases should not be confused with URL "
"redirects, which allow you to forward a changed or inactive URL to a "
"new URL. In addition to making URLs more readable, aliases also help "
"search engines index content more effectively. Multiple aliases may be "
"used for a single internal system path. To automate the aliasing of "
"paths, you can install the contributed module <a "
"href=\":pathauto\">Pathauto</a>. For more information, see the <a "
"href=\":path\">online documentation for the Path module</a>."
msgstr ""
"מודול Path מאפשר לך לציין כינוי, או URL "
"מותאם אישית, לכל נתיב מערכת פנימי קיים. "
"אין לבלבל בין כינויים לבין הפניות URL, "
"המאפשרות לך להעביר URL שונה או לא פעיל "
"ל-URL חדש. בנוסף להפיכת ה-URL לקריאים יותר, "
"כינויים גם עוזרים למנועי חיפוש לאנדקס "
"תוכן בצורה יעילה יותר. ניתן להשתמש "
"בכמה כינויים עבור נתיב מערכת פנימי "
"אחד. כדי להפוך את יצירת הכינויים "
"לנתיבים לאוטומטית, ניתן להתקין את "
"המודול <a href=\":pathauto\">Pathauto</a>. למידע נוסף, "
"ראה <a href=\":path\">התיעוד המקוון של מודול "
"Path</a>."

msgid ""
"If you create or edit a taxonomy term you can add an alias (for "
"example <em>music/jazz</em>) in the field \"URL alias\". When creating "
"or editing content you can add an alias (for example "
"<em>about-us/team</em>) under the section \"URL path settings\" in the "
"field \"URL alias\". Aliases for any other path can be added through "
"the page <a href=\":aliases\">URL aliases</a>. To add aliases a user "
"needs the permission <a href=\":permissions\">Create and edit URL "
"aliases</a>."
msgstr ""
"אם אתה יוצר או עורך מונח טקסונומי, אתה "
"יכול להוסיף כינוי (לדוגמה <em>music/jazz</em>) "
"בשדה \"כינוי URL\". בעת יצירת או עריכת "
"תוכן, ניתן להוסיף כינוי (לדוגמה, "
"<em>about-us/team</em>) תחת הקטע \"הגדרות נתיב URL\" "
"בשדה \"כינוי URL\". ניתן להוסיף כינויים "
"לכל נתיב אחר דרך הדף <a href=\":aliases\">כינויי "
"URL</a>. כדי להוסיף כינויים, המשתמש זקוק "
"להרשאה <a href=\":permissions\">יצירת ועריכת "
"כינויי URL</a>."

msgid ""
"The Path module provides a way to search and view a <a "
"href=\":aliases\">list of all aliases</a> that are in use on your "
"website. Aliases can be added, edited and deleted through this list."
msgstr ""
"מודול Path מאפשר לחפש ולהציג <a "
"href=\":aliases\">רשימה של כל הכינויים</a> "
"הנמצאים בשימוש באתר האינטרנט שלך. ניתן "
"להוסיף, לערוך ולמחוק כינויים באמצעות "
"רשימה זו."

msgid "The internal system path."
msgstr "נתיב המערכת הפנימי."

msgid "The path alias."
msgstr "כינוי הנתיב."

msgid ""
"The Responsive Image module provides an image formatter that allows "
"browsers to select which image file to display based on media queries "
"or which image file types the browser supports, using the HTML 5 "
"picture and source elements and/or the sizes, srcset and type "
"attributes. For more information, see the <a "
"href=\":responsive_image\">online documentation for the Responsive "
"Image module</a>."
msgstr ""
"מודול Responsive Image מספק מעצב תמונות "
"המאפשר לדפדפנים לבחור איזה קובץ תמונה "
"להציג על סמך שאילתות מדיה או אילו סוגי "
"קבצי תמונה הדפדפן תומך, באמצעות "
"אלמנטים HTML 5 picture ו-source ו/או תכונות sizes, "
"srcset ו-type. למידע נוסף, ראה <a "
"href=\":responsive_image\">תיעוד מקוון למודול "
"Responsive Image</a>."

msgid ""
"By creating responsive image styles you define which options the "
"browser has in selecting which image file to display. In most cases "
"this means providing different image sizes based on the viewport size. "
"On the <a href=\":responsive_image_style\">Responsive image styles</a> "
"page, click <em>Add responsive image style</em> to create a new style. "
"First choose a label, a fallback image style and a breakpoint group "
"and click Save."
msgstr ""
"על ידי יצירת סגנונות תמונה מגיבים, אתה "
"מגדיר אילו אפשרויות יש לדפדפן בבחירת "
"קובץ התמונה שיוצג. ברוב המקרים, משמעות "
"הדבר היא מתן גדלים שונים של תמונות "
"בהתאם לגודל חלון התצוגה. בדף <a "
"href=\":responsive_image_style\">סגנונות תמונה "
"מגיבים</a>, לחץ על <em>הוסף סגנון תמונה "
"מגיב</em> כדי ליצור סגנון חדש. תחילה בחר "
"תווית, סגנון תמונה חלופי וקבוצת נקודות "
"עצירה, ולאחר מכן לחץ על שמור."

msgid ""
"Below the Sizes field you can choose multiple image styles so the "
"browser can choose the best image file size to fill the space defined "
"in the Sizes field. Typically you will want to use image styles that "
"resize your image to have options that range from the smallest px "
"width possible for the space the image will appear in to the largest "
"px width possible, with a variety of widths in between. You may want "
"to provide image styles with widths that are 1.5x to 2x the space "
"available in the layout to account for high resolution screens. Image "
"styles can be defined on the <a href=\":image_styles\">Image styles "
"page</a> that is provided by the <a href=\":image_help\">Image "
"module</a>."
msgstr ""
"מתחת לשדה Sizes (גדלים) תוכל לבחור מספר "
"סגנונות תמונה, כך שהדפדפן יוכל לבחור "
"את גודל קובץ התמונה הטוב ביותר למילוי "
"השטח המוגדר בשדה Sizes (גדלים). בדרך כלל, "
"תרצה להשתמש בסגנונות תמונה המשנים את "
"גודל התמונה שלך, כך שתהיה לך אפשרות "
"לבחור בין רוחב px הקטן ביותר האפשרי "
"עבור השטח שבו תופיע התמונה, לבין רוחב px "
"הגדול ביותר האפשרי, עם מגוון רוחבים "
"ביניהם. ייתכן שתרצו לספק סגנונות תמונה "
"עם רוחבים שגודלם פי 1.5 עד פי 2 מהשטח "
"הזמין בפריסה, כדי להתחשב במסכים "
"ברזולוציה גבוהה. ניתן להגדיר סגנונות "
"תמונה בדף <a href=\":image_styles\">סגנונות "
"תמונה</a> המסופק על ידי <a "
"href=\":image_help\">מודול התמונה</a>."

msgid ""
"After defining responsive image styles, you can use them in the "
"display settings for your Image fields, so that the site displays "
"responsive images using the HTML5 picture tag. Open the Manage display "
"page for the entity type (content type, taxonomy vocabulary, etc.) "
"that the Image field is attached to. Choose the format <em>Responsive "
"image</em>, click the Edit icon, and select one of the responsive "
"image styles that you have created. For general information on how to "
"manage fields and their display see the <a href=\":field_ui\">Field UI "
"module help page</a>. For background information about entities and "
"fields see the <a href=\":field_help\">Field module help page</a>."
msgstr ""
"לאחר הגדרת סגנונות תמונה מגיבים, תוכל "
"להשתמש בהם בהגדרות התצוגה של שדות "
"התמונה שלך, כך שהאתר יציג תמונות "
"מגיבות באמצעות תגית התמונה HTML5. פתח את "
"דף ניהול התצוגה עבור סוג הישות (סוג "
"תוכן, אוצר מילים טקסונומי וכו') שאליו "
"מחובר שדה התמונה. בחר את הפורמט "
"<em>תמונה רספונסיבית</em>, לחץ על סמל "
"העריכה ובחר אחד מסגנונות התמונה "
"הרספונסיבית שיצרת. למידע כללי על אופן "
"ניהול השדות ותצוגתם, ראה <a "
"href=\":field_ui\">דף העזרה של מודול ממשק "
"המשתמש של השדה</a>. למידע רקע על ישויות "
"ושדות, ראה <a href=\":field_help\">דף העזרה של "
"מודול השדה</a>."

msgid ""
"See the <a href=\":responsive_image_help\">Responsive Image help "
"page</a> for information on the sizes attribute."
msgstr ""
"עיין בדף העזרה <a "
"href=\":responsive_image_help\">תמונות "
"רספונסיביות</a> לקבלת מידע על תכונת "
"הגדלים."

msgid ""
"The Search module provides the ability to set up search pages based on "
"plugins provided by other modules. In Drupal core, there are two "
"page-type plugins: the Content page type provides keyword searching "
"for content managed by the Node module, and the Users page type "
"provides keyword searching for registered users. Contributed modules "
"may provide other page-type plugins. For more information, see the <a "
"href=\":search-module\">online documentation for the Search "
"module</a>."
msgstr ""
"מודול החיפוש מאפשר להגדיר דפי חיפוש "
"המבוססים על תוספים המסופקים על ידי "
"מודולים אחרים. בליבת Drupal ישנם שני "
"תוספים מסוג דף: סוג הדף Content מספק חיפוש "
"מילות מפתח לתוכן המנוהל על ידי מודול "
"Node, וסוג הדף Users מספק חיפוש מילות מפתח "
"למשתמשים רשומים. מודולים שנוספו על ידי "
"משתמשים עשויים לספק תוספים מסוג דף "
"אחרים. למידע נוסף, ראה את <a "
"href=\":search-module\">התיעוד המקוון של מודול "
"החיפוש</a>."

msgid ""
"To configure search pages, visit the <a "
"href=\":search-settings\">Search pages page</a>. In the Search pages "
"section, you can add a new search page, edit the configuration of "
"existing search pages, enable and disable search pages, and choose the "
"default search page. Each enabled search page has a URL path starting "
"with <em>search</em>, and each will appear as a tab or local task link "
"on the <a href=\":search-url\">search page</a>; you can configure the "
"text that is shown in the tab. In addition, some search page plugins "
"have additional settings that you can configure for each search page."
msgstr ""
"כדי להגדיר דפי חיפוש, בקר בדף <a "
"href=\":search-settings\">דפי חיפוש</a>. בקטע דפי "
"חיפוש, באפשרותך להוסיף דף חיפוש חדש, "
"לערוך את התצורה של דפי חיפוש קיימים, "
"להפעיל ולהשבית דפי חיפוש ולבחור את דף "
"החיפוש המוגדר כברירת מחדל. לכל דף "
"חיפוש מופעל יש נתיב URL המתחיל "
"ב-<em>search</em>, וכל אחד מהם יופיע ככרטיסייה "
"או כקישור למשימה מקומית בדף <a "
"href=\":search-url\">דף החיפוש</a>; ניתן להגדיר את "
"הטקסט המוצג בכרטיסייה. בנוסף, לחלק "
"מתוספי דפי החיפוש יש הגדרות נוספות "
"שניתן להגדיר עבור כל דף חיפוש."

msgid ""
"Some search page plugins, such as the core Content search page, index "
"searchable text using the Drupal core search index, and will not work "
"unless content is indexed. Indexing is done during <em>cron</em> runs, "
"so it requires a <a href=\":cron\">cron maintenance task</a> to be set "
"up. There are also several settings affecting indexing that can be "
"configured on the <a href=\":search-settings\">Search pages page</a>: "
"the number of items to index per cron run, the minimum word length to "
"index, and how to handle Chinese, Japanese, and Korean characters."
msgstr ""
"תוספים מסוימים לדפי חיפוש, כגון דף "
"החיפוש המרכזי בתוכן, מאינדקסים טקסט "
"שניתן לחפש באמצעות אינדקס החיפוש "
"המרכזי של Drupal, ולא יפעלו אלא אם התוכן "
"מאונדקס. האינדוקס מתבצע במהלך ריצות "
"<em>cron</em>, ולכן נדרשת הגדרת <a "
"href=\":cron\">משימת תחזוקת cron</a>. ישנן גם "
"מספר הגדרות המשפיעות על האינדקס שניתן "
"להגדיר בדף <a href=\":search-settings\">דפי "
"חיפוש</a>: מספר הפריטים לאינדקס בכל "
"הפעלת cron, אורך המילה המינימלי לאינדקס, "
"ואופן הטיפול בתווים סיניים, יפניים "
"וקוריאניים."

msgid ""
"Users with <a href=\":search_permission\">Use search</a> permission "
"can use the Search block and <a href=\":search\">Search page</a>. "
"Users with the <a href=\":node_permission\">View published content</a> "
"permission can use configured search pages of type <em>Content</em> to "
"search for content containing exact keywords; in addition, users with "
"<a href=\":search_permission\">Use advanced search</a> permission can "
"use more complex search filtering. Users with the <a "
"href=\":user_permission\">View user information</a> permission can use "
"configured search pages of type <em>Users</em> to search for active "
"users containing the keyword anywhere in the username, and users with "
"the <a href=\":user_permission\">Administer users</a> permission can "
"search for active and blocked users, by email address or username "
"keyword."
msgstr ""
"משתמשים בעלי הרשאת <a "
"href=\":search_permission\">שימוש בחיפוש</a> יכולים "
"להשתמש בבלוק החיפוש ובדף <a "
"href=\":search\">חיפוש</a>. משתמשים בעלי הרשאה <a "
"href=\":node_permission\">הצגת תוכן שפורסם</a> "
"יכולים להשתמש בדפי חיפוש מוגדרים מסוג "
"<em>תוכן</em> כדי לחפש תוכן המכיל מילות "
"מפתח מדויקות; בנוסף, משתמשים בעלי "
"הרשאה <a href=\":search_permission\">שימוש בחיפוש "
"מתקדם</a> יכולים להשתמש בסינון חיפוש "
"מורכב יותר. משתמשים בעלי הרשאה <a "
"href=\":user_permission\">הצגת מידע על משתמשים</a> "
"יכולים להשתמש בדפי חיפוש מוגדרים מסוג "
"<em>משתמשים</em> כדי לחפש משתמשים פעילים "
"המכילים את מילת המפתח בכל מקום בשם "
"המשתמש, ומשתמשים בעלי הרשאה <a "
"href=\":user_permission\">ניהול משתמשים</a> יכולים "
"לחפש משתמשים פעילים וחסומים, לפי כתובת "
"דוא\"ל או מילת מפתח בשם המשתמש."

msgid ""
"By default, the Search module only supports exact keyword matching in "
"content searches. You can modify this behavior by installing a "
"language-specific stemming module for your language (such as <a "
"href=\":porterstemmer_url\">Porter Stemmer</a> for American English), "
"which allows words such as walk, walking, and walked to be matched in "
"the Search module. Another approach is to use a third-party search "
"technology with stemming or partial word matching features built in, "
"such as <a href=\":solr_url\">Apache Solr</a> or <a "
"href=\":sphinx_url\">Sphinx</a>. There are also contributed modules "
"that provide additional search pages. These and other <a "
"href=\":contrib-search\">search-related contributed modules</a> can be "
"downloaded by visiting Drupal.org."
msgstr ""
"כברירת מחדל, מודול החיפוש תומך רק "
"בהתאמה מדויקת של מילות מפתח בחיפושים "
"בתוכן. ניתן לשנות התנהגות זו על ידי "
"התקנת מודול גזירה ספציפי לשפה שלך "
"(כגון <a href=\":porterstemmer_url\">Porter Stemmer</a> "
"לאנגלית אמריקאית), המאפשר התאמה של "
"מילים כגון walk, walking ו-walked במודול החיפוש. "
"גישה אחרת היא להשתמש בטכנולוגיית "
"חיפוש של צד שלישי עם תכונות מובנות של "
"גזירה או התאמת מילים חלקיות, כגון <a "
"href=\":solr_url\">Apache Solr</a> או <a "
"href=\":sphinx_url\">Sphinx</a>. ישנם גם מודולים "
"שתרמו המציעים דפי חיפוש נוספים. "
"מודולים אלה ומודולים אחרים <a "
"href=\":contrib-search\">הקשורים לחיפוש</a> ניתנים "
"להורדה בכתובת Drupal.org."

msgid "… @excerpt … @excerpt …"
msgstr "… @excerpt … @excerpt …"

msgid ""
"This module does not have a user interface. It is used by other "
"modules which need to serialize data, such as <a "
"href=\":rest\">REST</a>."
msgstr ""
"למודול זה אין ממשק משתמש. הוא משמש "
"מודולים אחרים הזקוקים לסידור נתונים "
"בסדר סדרתי, כגון <a href=\":rest\">REST</a>."

msgid ""
"For more information, see the <a href=\":doc_url\">online "
"documentation for the Serialization module</a>."
msgstr ""
"למידע נוסף, ראה את <a href=\":doc_url\">התיעוד "
"המקוון של מודול הסריאליזציה</a>."

msgid ""
"The Shortcut module allows users to create sets of <em>shortcut</em> "
"links to commonly-visited pages of the site. Shortcuts are contained "
"within <em>sets</em>. Each user with <em>Select any shortcut set</em> "
"permission can select a shortcut set created by anyone at the site. "
"For more information, see the <a href=\":shortcut\">online "
"documentation for the Shortcut module</a>."
msgstr ""
"מודול הקיצורים מאפשר למשתמשים ליצור "
"קבוצות של קישורי <em>קיצור</em> לדפים "
"הנצפים ביותר באתר. הקיצורים כלולים "
"בתוך <em>קבוצות</em>. כל משתמש בעל הרשאת "
"<em>בחר כל קבוצת קיצורים</em> יכול לבחור "
"קבוצת קיצורים שנוצרה על ידי כל אחד "
"באתר. למידע נוסף, ראה <a href=\":shortcut\">תיעוד "
"מקוון למודול הקיצורים</a>."

msgid ""
"Users with the <em>Administer shortcuts</em> permission can manage "
"shortcut sets and edit the shortcuts within sets from the <a "
"href=\":shortcuts\">Shortcuts administration page</a>."
msgstr ""
"משתמשים בעלי הרשאת <em>ניהול קיצורי "
"דרך</em> יכולים לנהל קבוצות קיצורי דרך "
"ולערוך את קיצורי הדרך בתוך הקבוצות מדף "
"הניהול <a href=\":shortcuts\">ניהול קיצורי "
"דרך</a>."

msgid ""
"Define which shortcut set you are using on the <a "
"href=\":shortcut-link\">Shortcuts tab</a> of your account page."
msgstr ""
"הגדר איזה סט קיצורי דרך אתה משתמש בו "
"בלשונית <a href=\":shortcut-link\">קיצורי דרך</a> "
"בדף החשבון שלך."

msgid "No shortcuts available. <a href=\":link\">Add a shortcut</a>"
msgstr ""
"אין קיצורי דרך זמינים. <a href=\":link\">הוסף "
"קיצור דרך</a>"

msgid ""
"You are now using the new %set_name shortcut set. You can edit it from "
"this page or <a href=\":switch-url\">switch back to a different "
"one.</a>"
msgstr ""
"כעת אתה משתמש בקיצור הדרך החדש %set_name. "
"אתה יכול לערוך אותו מדף זה או <a "
"href=\":switch-url\">לעבור לקיצור דרך אחר.</a>"

msgid "The link for this shortcut."
msgstr "הקישור לקיצור הדרך הזה."

msgid "The title for this shortcut."
msgstr "הכותרת של קיצור הדרך הזה."

msgid "The weight for this shortcut"
msgstr "המשקל של קיצור הדרך הזה"

msgid "The name under which the set's links are stored."
msgstr "השם שבו מאוחסנים הקישורים של הסט."

msgid "The title of the set."
msgstr "שם הסט."

msgid "The users.uid for this set."
msgstr "ה-users.uid עבור קבוצה זו."

msgid "The shortcut_set.set_name that will be displayed for this user."
msgstr "ה-shortcut_set.set_name שיוצג עבור משתמש זה."

msgid "Version: @module-version"
msgstr "גרסה: @module-version"

msgid "Requires: @module-list"
msgstr "נדרש: @module-list"

msgid "Required by: @module-list"
msgstr "נדרש על ידי: @module-list"

msgid ""
"This theme requires PHP version @php_required and is incompatible with "
"PHP version @php_version."
msgstr ""
"נושא זה דורש גרסת PHP @php_required ואינו תואם "
"לגרסת PHP @php_version."

msgid ""
"The System module is integral to the site: it provides user interfaces "
"for many core systems and settings, as well as the basic "
"administrative menu structure. For more information, see the <a "
"href=\":system\">online documentation for the System module</a>."
msgstr ""
"מודול המערכת הוא חלק בלתי נפרד מהאתר: "
"הוא מספק ממשקי משתמש עבור מערכות "
"והגדרות ליבה רבות, כמו גם את מבנה "
"התפריט הניהולי הבסיסי. למידע נוסף, ראה "
"<a href=\":system\">תיעוד מקוון עבור מודול "
"המערכת</a>."

msgid ""
"Users with appropriate permission can install and uninstall modules "
"from the <a href=\":modules\">Extend page</a>. Depending on which "
"distribution or installation profile you choose when you install your "
"site, several modules are installed and others are provided but not "
"installed. Each module provides a discrete set of features; modules "
"may be installed or uninstalled depending on the needs of the site. "
"Many additional modules contributed by members of the Drupal community "
"are available for download from the <a "
"href=\":drupal-modules\">Drupal.org module page</a>. Note that "
"uninstalling a module is a destructive action: when you uninstall a "
"module, you will permanently lose all data connected to the module."
msgstr ""
"משתמשים בעלי הרשאה מתאימה יכולים "
"להתקין ולהסיר מודולים מדף <a "
"href=\":modules\">הרחבה</a>. בהתאם לפרופיל ההפצה "
"או ההתקנה שתבחרו בעת התקנת האתר, מספר "
"מודולים יותקנו ואחרים יסופקו אך לא "
"יותקנו. כל מודול מספק מערך תכונות נפרד; "
"ניתן להתקין או להסיר מודולים בהתאם "
"לצרכי האתר. מודולים נוספים רבים שתרמו "
"חברי קהילת Drupal זמינים להורדה מדף "
"המודולים של Drupal.org. שימו לב שהסרת מודול "
"היא פעולה הרסנית: כאשר אתם מסירים "
"מודול, אתם מאבדים לצמיתות את כל "
"הנתונים הקשורים למודול."

msgid ""
"Users with appropriate permission can install and uninstall themes on "
"the <a href=\":themes\">Appearance page</a>. Themes determine the "
"design and presentation of your site. Depending on which distribution "
"or installation profile you choose when you install your site, a "
"default theme is installed, and possibly a different theme for "
"administration pages. Other themes are provided but not installed, and "
"additional contributed themes are available at the <a "
"href=\":drupal-themes\">Drupal.org theme page</a>."
msgstr ""
"משתמשים בעלי הרשאה מתאימה יכולים "
"להתקין ולהסיר ערכות נושא בדף <a "
"href=\":themes\">מראה</a>. ערכות הנושא קובעות את "
"העיצוב וההצגה של האתר שלך. בהתאם "
"לפרופיל ההפצה או ההתקנה שתבחר בעת "
"התקנת האתר, תותקן ערכת נושא ברירת מחדל, "
"ואולי ערכת נושא שונה עבור דפי הניהול. "
"ערכות נושא אחרות מסופקות אך אינן "
"מותקנות, וערכות נושא נוספות שתרמו "
"משתמשים אחרים זמינות בדף <a "
"href=\":drupal-themes\">ערכות הנושא של Drupal.org</a>."

msgid ""
"When you are performing site maintenance, you can prevent "
"non-administrative users (including anonymous visitors) from viewing "
"your site by putting it in <a href=\":maintenance-mode\">Maintenance "
"mode</a>. This will prevent unauthorized users from making changes to "
"the site while you are performing maintenance, or from seeing a broken "
"site while updates are in progress."
msgstr ""
"בעת ביצוע תחזוקת אתר, ניתן למנוע "
"ממשתמשים שאינם מנהלים (כולל מבקרים "
"אנונימיים) לצפות באתר על ידי העברתו "
"למצב תחזוקה <a href=\":maintenance-mode\">Maintenance "
"mode</a>. פעולה זו תמנע ממשתמשים לא מורשים "
"לבצע שינויים באתר בזמן ביצוע התחזוקה, "
"או לראות אתר מקולקל בזמן ביצוע "
"העדכונים."

msgid ""
"On the <a href=\":performance-page\">Performance page</a>, the site "
"can be configured to aggregate CSS and JavaScript files, making the "
"total request size smaller. Note that, for small- to medium-sized "
"websites, the <a href=\":page-cache\">Internal Page Cache module</a> "
"should be installed so that pages are efficiently cached and reused "
"for anonymous users. Finally, for websites of all sizes, the <a "
"href=\":dynamic-page-cache\">Dynamic Page Cache module</a> should also "
"be installed so that the non-personalized parts of pages are "
"efficiently cached (for all users)."
msgstr ""
"בדף <a href=\":performance-page\">ביצועים</a>, ניתן "
"להגדיר את האתר כך שיאגד קבצי CSS ו-JavaScript, "
"ובכך יקטין את גודל הבקשה הכולל. שימו "
"לב, עבור אתרים קטנים עד בינוניים, יש "
"להתקין את <a href=\":page-cache\">מודול המטמון "
"הפנימי של הדף</a> כדי שהדפים יאוחסנו "
"במטמון ביעילות וייעשה בהם שימוש חוזר "
"עבור משתמשים אנונימיים. לבסוף, עבור "
"אתרים בכל הגדלים, יש להתקין גם את <a "
"href=\":dynamic-page-cache\">מודול המטמון הדינמי של "
"הדף</a>, כך שהחלקים הלא מותאמים אישית של "
"הדפים יאוחסנו במטמון ביעילות (עבור כל "
"המשתמשים)."

msgid ""
"Your site has several file directories, which are used to store and "
"process uploaded and generated files. The <em>public</em> file "
"directory, which is configured in your settings.php file, is the "
"default place for storing uploaded files. Links to files in this "
"directory contain the direct file URL, so when the files are "
"requested, the web server will send them directly without invoking "
"your site code. This means that the files can be downloaded by anyone "
"with the file URL, so requests are not access-controlled but they are "
"efficient. The <em>private</em> file directory, also configured in "
"your settings.php file and ideally located outside the site web root, "
"is access controlled. Links to files in this directory are not direct, "
"so requests to these files are mediated by your site code. This means "
"that your site can check file access permission for each file before "
"deciding to fulfill the request, so the requests are more secure, but "
"less efficient. You should only use the private storage for files that "
"need access control, not for files like your site logo and background "
"images used on every page. The <em>temporary</em> file directory is "
"used internally by your site code for various operations, and is "
"configured on the <a href=\":file-system\">File system settings</a> "
"page. You can also see the configured public and private file "
"directories on this page, and choose whether public or private should "
"be the default for uploaded files."
msgstr ""
"באתר שלך יש מספר ספריות קבצים, המשמשות "
"לאחסון ולעיבוד קבצים שהועלו ונוצרו. "
"ספריית הקבצים <em>public</em>, המוגדרת בקובץ "
"settings.php, היא המיקום המוגדר כברירת מחדל "
"לאחסון קבצים שהועלו. קישורים לקבצים "
"בספרייה זו מכילים את כתובת ה-URL הישירה "
"של הקובץ, כך שכאשר הקבצים מתבקשים, שרת "
"האינטרנט ישלח אותם ישירות מבלי להפעיל "
"את קוד האתר שלך. משמעות הדבר היא "
"שהקבצים ניתנים להורדה על ידי כל מי שיש "
"לו את כתובת ה-URL של הקובץ, ולכן הבקשות "
"אינן מבוקרות גישה, אך הן יעילות. ספריית "
"הקבצים <em>private</em>, המוגדרת גם היא בקובץ "
"settings.php שלך וממוקמת באופן אידיאלי מחוץ "
"לשורש האתר, מבוקרת גישה. קישורים "
"לקבצים בספרייה זו אינם ישירים, ולכן "
"בקשות לקבצים אלה מתווכות על ידי קוד "
"האתר שלך. משמעות הדבר היא שהאתר שלך "
"יכול לבדוק את הרשאת הגישה לכל קובץ "
"לפני שהוא מחליט למלא את הבקשה, ולכן "
"הבקשות מאובטחות יותר, אך פחות יעילות. "
"עליך להשתמש באחסון הפרטי רק עבור קבצים "
"הזקוקים לבקרת גישה, ולא עבור קבצים כמו "
"לוגו האתר ותמונות הרקע המשמשות בכל דף. "
"ספריית הקבצים <em>הזמנית</em> משמשת באופן "
"פנימי על ידי קוד האתר שלך למבצעים "
"שונים, והיא מוגדרת בדף <a "
"href=\":file-system\">הגדרות מערכת הקבצים</a>. בדף "
"זה תוכל גם לראות את ספריות הקבצים "
"הציבוריות והפרטיות שהוגדרו, ולבחור אם "
"הציבוריות או הפרטיות יהיו ברירת המחדל "
"עבור קבצים שהועלו."

msgid ""
"On the <a href=\":toolkit\">Image toolkit page</a>, you can select and "
"configure the PHP toolkit used to manipulate images. Depending on "
"which distribution or installation profile you choose when you install "
"your site, the GD2 toolkit and possibly others are included; other "
"toolkits may be provided by contributed modules."
msgstr ""
"בדף <a href=\":toolkit\">ערכת כלים לתמונות</a>, "
"תוכל לבחור ולהגדיר את ערכת הכלים PHP "
"המשמשת לעיבוד תמונות. בהתאם לפרופיל "
"ההפצה או ההתקנה שתבחר בעת התקנת האתר, "
"ערכת הכלים GD2 ואולי גם אחרות כלולות; "
"ערכות כלים אחרות עשויות להיות מסופקות "
"על ידי מודולים שנוספו."

msgid ""
"Set and configure the default theme for your website.  Alternative <a "
"href=\":themes\">themes</a> are available."
msgstr ""
"הגדירו וקבעו ברירת מחדל לתבנית עבור "
"האתר. ניתן למצוא<a href=\":themes\">תבניות "
"עיצוב</a> נוספות."

msgid ""
"You can place blocks for each theme on the <a href=\":blocks\">block "
"layout</a> page."
msgstr ""
"ניתן למקם בלוקים עבור כל תבנית עיצוב "
"בדף ה<a href=\":blocks\">בלוקים</a>."

msgid ""
"Here you can find a short overview of your site's parameters as well "
"as any problems detected with your installation. It may be useful to "
"copy and paste this information into support requests filed on "
"Drupal.org's support forums and project issue queues. Before filing a "
"support request, ensure that your web server meets the <a "
"href=\":system-requirements\">system requirements.</a>"
msgstr ""
"כאן תוכל למצוא סקירה קצרה של הפרמטרים "
"של האתר שלך, כמו גם כל בעיה שזוהתה "
"בהתקנה שלך. ייתכן שיהיה שימושי להעתיק "
"ולהדביק מידע זה בבקשות תמיכה שהוגשו "
"בפורומי התמיכה של Drupal.org ובתורי הבעיות "
"של הפרויקט. לפני הגשת בקשת תמיכה, ודא "
"ששרת האינטרנט שלך עומד בדרישות המערכת."

msgid "Configure your <a href=\":user-edit\">account time zone setting</a>."
msgstr ""
"הגדר את <a href=\":user-edit\">הגדרת אזור הזמן "
"בחשבון שלך</a>."

msgid ""
"The minimum version of Apache needed to run Drupal without mod_rewrite "
"enabled is 2.2.16. See the <a href=\":link\">enabling clean URLs</a> "
"page for more information on mod_rewrite."
msgstr ""
"הגרסה המינימלית של Apache הדרושה להפעלת "
"Drupal ללא mod_rewrite מופעל היא 2.2.16. ראה את הדף "
"<a href=\":link\">הפעלת כתובות URL נקיות</a> "
"לקבלת מידע נוסף על mod_rewrite."

msgid ""
"Your server is capable of using clean URLs, but it is not enabled. "
"Using clean URLs gives an improved user experience and is recommended. "
"<a href=\":link\">Enable clean URLs</a>"
msgstr ""
"השרת שלך תומך בשימוש בכתובות URL נקיות, "
"אך האפשרות אינה מופעלת. השימוש בכתובות "
"URL נקיות משפר את חוויית המשתמש ומומלץ. "
"<a href=\":link\">הפעל כתובות URL נקיות</a>"

msgid "@phpversion (<a href=\":url\">more information</a>)"
msgstr "@phpversion (<a href=\":url\">מידע נוסף</a>)"

msgid ""
"Drupal requires you to enable the PHP extensions in the following list "
"(see the <a href=\":system_requirements\">system requirements page</a> "
"for more information):"
msgstr ""
"Drupal דורש ממך להפעיל את הרחבות ה-PHP "
"ברשימה הבאה (למידע נוסף, ראה את <a "
"href=\":system_requirements\">דף דרישות המערכת</a>):"

msgid "PHP OPcode caching"
msgstr "אחסון במטמון קוד OPcode של PHP"

msgid ""
"Your web server does not appear to support PDO (PHP Data Objects). Ask "
"your hosting provider if they support the native PDO extension. See "
"the <a href=\":link\">system requirements</a> page for more "
"information."
msgstr ""
"נראה ששרת האינטרנט שלך אינו תומך ב-PDO "
"(PHP Data Objects). שאל את ספק שירותי האחסון "
"שלך אם הוא תומך בהרחבת PDO המקורית. ראה "
"את דף <a href=\":link\">דרישות המערכת</a> לקבלת "
"מידע נוסף."

msgid ""
"Your web server does not appear to support any common PDO database "
"extensions. Check with your hosting provider to see if they support "
"PDO (PHP Data Objects) and offer any databases that <a "
"href=\":drupal-databases\">Drupal supports</a>."
msgstr ""
"נראה ששרת האינטרנט שלך אינו תומך בשום "
"הרחבות מסד נתונים PDO נפוצות. בדוק עם "
"ספק האחסון שלך אם הוא תומך ב-PDO (PHP Data "
"Objects) ומציע מסדי נתונים ש-<a "
"href=\":drupal-databases\">Drupal תומך בהם</a>."

msgid ""
"Your web server seems to have the wrong version of PDO installed. "
"Drupal requires the PDO extension from PHP core. This system has the "
"older PECL version. See the <a href=\":link\">system requirements</a> "
"page for more information."
msgstr ""
"נראה כי בשרת האינטרנט שלך מותקנת גרסה "
"שגויה של PDO. Drupal דורש את הרחבת PDO מליבת "
"PHP. במערכת זו מותקנת הגרסה הישנה יותר "
"של PECL. למידע נוסף, עיין בדף <a "
"href=\":link\">דרישות המערכת</a>."

msgid ""
"For more information, see the online handbook entry for <a "
"href=\":memory-limit\">increasing the PHP memory limit</a>."
msgstr ""
"למידע נוסף, עיין בערך המקוון במדריך <a "
"href=\":memory-limit\">הגדלת מגבלת הזיכרון של "
"PHP</a>."

msgid ""
"See <a href=\":url\">@url</a> for information about the recommended "
".htaccess file which should be added to the %directory directory to "
"help protect against arbitrary code execution."
msgstr ""
"ראה <a href=\":url\">@url</a> לקבלת מידע אודות "
"קובץ ה-.htaccess המומלץ שיש להוסיף לספריית "
"%directory כדי לסייע בהגנה מפני ביצוע קוד "
"שרירותי."

msgid "Last run @time ago"
msgstr "ריצה אחרונה לפני @time"

msgid ""
"For more information, see the online handbook entry for <a "
"href=\":cron-handbook\">configuring cron jobs</a>."
msgstr ""
"למידע נוסף, עיין בערך המקוון במדריך <a "
"href=\":cron-handbook\">הגדרת משימות cron</a>."

msgid ""
"You may need to set the correct directory at the <a "
"href=\":admin-file-system\">file system settings page</a> or change "
"the current directory's permissions so that it is writable."
msgstr ""
"ייתכן שתצטרך להגדיר את הספרייה הנכונה "
"בדף <a href=\":admin-file-system\">הגדרות מערכת "
"הקבצים</a> או לשנות את ההרשאות של "
"הספרייה הנוכחית כך שתהיה ניתנת לכתיבה."

msgid ""
"An automated attempt to create this directory failed, possibly due to "
"a permissions problem. To proceed with the installation, either create "
"the directory and modify its permissions manually or ensure that the "
"installer has the permissions to create it automatically. For more "
"information, see INSTALL.txt or the <a href=\":handbook_url\">online "
"handbook</a>."
msgstr ""
"ניסיון אוטומטי ליצור ספרייה זו נכשל, "
"ככל הנראה עקב בעיה בהרשאות. כדי להמשיך "
"בהתקנה, צור את הספרייה ושנה את "
"הרשאותיה באופן ידני, או ודא שלמתקין יש "
"הרשאות ליצור אותה באופן אוטומטי. למידע "
"נוסף, עיין בקובץ INSTALL.txt או ב-<a "
"href=\":handbook_url\">המדריך המקוון</a>."

msgid ""
"Some modules have database schema updates to install. You should run "
"the <a href=\":update\">database update script</a> immediately."
msgstr ""
"בחלק מהמודולים יש עדכונים של סכימת מסד "
"הנתונים שצריך להתקין. עליך להפעיל את <a "
"href=\":update\">סקריפט העדכון של מסד "
"הנתונים</a> באופן מיידי."

msgid ""
"The trusted_host_patterns setting is not configured in settings.php. "
"This can lead to security vulnerabilities. It is <strong>highly "
"recommended</strong> that you configure this. See <a "
"href=\":url\">Protecting against HTTP HOST Header attacks</a> for more "
"information."
msgstr ""
"ההגדרה trusted_host_patterns אינה מוגדרת בקובץ "
"settings.php. הדבר עלול להוביל לפגיעות "
"אבטחה. <strong>מומלץ מאוד</strong> להגדיר "
"הגדרה זו. למידע נוסף, ראה <a href=\":url\">הגנה "
"מפני התקפות HTTP HOST Header</a>."

msgid "Put your site into <a href=\":url\">maintenance mode</a>."
msgstr ""
"העבר את האתר שלך ל<a href=\":url\">מצב "
"תחזוקה</a>."

msgid "All errors have been <a href=\":url\">logged</a>."
msgstr "כל השגיאות נרשמו <a href=\":url\">ביומן</a>."

msgid ""
"Updates were attempted. If you see no failures below, you may proceed "
"happily back to your <a href=\":url\">site</a>. Otherwise, you may "
"need to update your database manually."
msgstr ""
"ניסינו לבצע עדכונים. אם אינך רואה "
"תקלות להלן, תוכל לחזור בשמחה לאתר שלך <a "
"href=\":url\">site</a>. אחרת, ייתכן שתצטרך לעדכן "
"את מסד הנתונים שלך באופן ידני."

msgid ""
"One or more problems were detected with your Drupal installation. "
"Check the <a href=\":status\">status report</a> for more information."
msgstr ""
"זוהתה בעיה אחת או יותר בהתקנה זו של "
"דרופל. למידע נוסף בדקו את <a "
"href=\":status\">דוח המצב</a>."

msgid "Screenshot for @theme theme"
msgstr "צילום מסך עבור ערכת הנושא @theme"

msgid "Settings for @theme theme"
msgstr "הגדרות עבור ערכת העיצוב  @theme"

msgid "Uninstall @theme theme"
msgstr "הסר את התקנת ערכת הנושא @theme"

msgid "Set @theme as default theme"
msgstr "הגדר @theme כנושא ברירת מחדל"

msgid "Install @theme theme"
msgstr "התקן את ערכת הנושא @theme"

msgid "Install @theme as default theme"
msgstr "התקן את @theme כנושא ברירת המחדל"

msgid ""
"More information about setting up scheduled tasks can be found by <a "
"href=\":url\">reading the cron tutorial on drupal.org</a>."
msgstr ""
"מידע נוסף על הגדרת משימות מתוזמנות "
"ניתן למצוא ב-<a href=\":url\">מדריך cron "
"ב-drupal.org</a>."

msgid ""
"This version is not compatible with Drupal @core_version and should be "
"replaced."
msgstr ""
"גרסה זו אינה תואמת ל-Drupal @core_version ויש "
"להחליפה."

msgid ""
"This module requires PHP version @php_required and is incompatible "
"with PHP version @php_version."
msgstr ""
"מודול זה דורש גרסת PHP @php_required ואינו "
"תואם לגרסת PHP @php_version."

msgid "Defined on the <a href=\":information\">Site Information</a> page."
msgstr "מוגדר בדף <a href=\":information\">מידע על האתר</a>."

msgid "Powered by <a href=\":poweredby\">Drupal</a>"
msgstr "מונע באמצעות <a href=\":poweredby\">דרופל</a>"

msgid "Installation tasks"
msgstr "משימות התקנה"

msgid ""
"The Taxonomy module allows users who have permission to create and "
"edit content to categorize (tag) content of that type. Users who have "
"the <em>Administer vocabularies and terms</em> <a "
"href=\":permissions\" title=\"Taxonomy module "
"permissions\">permission</a> can add <em>vocabularies</em> that "
"contain a set of related <em>terms</em>. The terms in a vocabulary can "
"either be pre-set by an administrator or built gradually as content is "
"added and edited. Terms may be organized hierarchically if desired."
msgstr ""
"מודול הטקסונומיה מאפשר למשתמשים בעלי "
"הרשאה ליצור ולערוך תוכן לסווג (לתייג) "
"תוכן מסוג זה. משתמשים בעלי <em>ניהול "
"אוצר מילים ומונחים</em> <a href=\":permissions\" "
"title=\"הרשאות מודול טקסונומיה\">הרשאה</a> "
"יכולים להוסיף <em>אוצר מילים</em> המכיל "
"קבוצה של <em>מונחים</em> קשורים. המונחים "
"באוצר המילים יכולים להיות מוגדרים "
"מראש על ידי מנהל או להיבנות בהדרגה עם "
"הוספת ועריכת תוכן. ניתן לארגן את "
"המונחים בהיררכיה, אם רוצים."

msgid ""
"For more information, see the <a href=\":taxonomy\">online "
"documentation for the Taxonomy module</a>."
msgstr ""
"למידע נוסף, ראה את <a href=\":taxonomy\">התיעוד "
"המקוון של מודול הטקסונומיה</a>."

msgid ""
"Users who have the <em>Administer vocabularies and terms</em> "
"permission can add and edit vocabularies from the <a "
"href=\":taxonomy_admin\">Taxonomy administration page</a>. "
"Vocabularies can be deleted from their <em>Edit vocabulary</em> page. "
"Users with the <em>Taxonomy term: Administer fields</em> permission "
"may add additional fields for terms in that vocabulary using the <a "
"href=\":field_ui\">Field UI module</a>."
msgstr ""
"משתמשים בעלי הרשאת <em>ניהול אוצר מילים "
"ומונחים</em> יכולים להוסיף ולערוך אוצר "
"מילים מדף <a href=\":taxonomy_admin\">ניהול "
"טקסונומיה</a>. ניתן למחוק אוצר מילים מדף "
"<em>עריכת אוצר מילים</em>. משתמשים בעלי "
"הרשאה <em>מונח טקסונומיה: ניהול שדות</em> "
"יכולים להוסיף שדות נוספים למונחים "
"באוצר המילים באמצעות <a "
"href=\":field_ui\">מודול ממשק המשתמש של "
"השדות</a>."

msgid ""
"Users who have the <em>Administer vocabularies and terms</em> "
"permission or the <em>Edit terms</em> permission for a particular "
"vocabulary can add, edit, and organize the terms in a vocabulary from "
"a vocabulary's term listing page, which can be accessed by going to "
"the <a href=\":taxonomy_admin\">Taxonomy administration page</a> and "
"clicking <em>List terms</em> in the <em>Operations</em> column. Users "
"must have the <em>Administer vocabularies and terms</em> permission or "
"the <em>Delete terms</em> permission for a particular vocabulary to "
"delete terms."
msgstr ""
"משתמשים בעלי הרשאת <em>ניהול אוצר מילים "
"ומונחים</em> או הרשאת <em>עריכת מונחים</em> "
"עבור אוצר מילים מסוים יכולים להוסיף, "
"לערוך ולארגן את המונחים באוצר מילים "
"מדף רשימת המונחים של אוצר המילים, אליו "
"ניתן לגשת על ידי מעבר ל-<a "
"href=\":taxonomy_admin\">דף ניהול טקסונומיה</a> "
"וללחוץ על <em>רשימת מונחים</em> בעמודה "
"<em>פעולות</em>. על מנת למחוק מונחים, על "
"המשתמשים להיות בעלי הרשאת <em>ניהול "
"אוצר מילים ומונחים</em> או הרשאת <em>מחיקת "
"מונחים</em> עבור אוצר מילים מסוים."

msgid ""
"A user with the <em>Administer fields</em> permission for a certain "
"entity type may add <em>Taxonomy term</em> reference fields to the "
"entity type, which will allow entities to be classified using taxonomy "
"terms. See the <a href=\":entity_reference\">Entity Reference help</a> "
"for more information about reference fields. See the <a "
"href=\":field\">Field module help</a> and the <a "
"href=\":field_ui\">Field UI help</a> pages for general information on "
"fields and how to create and manage them."
msgstr ""
"משתמש בעל הרשאת <em>ניהול שדות</em> עבור "
"סוג ישות מסוים יכול להוסיף שדות "
"התייחסות <em>מונח טקסונומיה</em> לסוג "
"הישות, מה שיאפשר לסווג ישויות באמצעות "
"מונחי טקסונומיה. למידע נוסף על שדות "
"הפניה, ראה <a href=\":entity_reference\">עזרה בנושא "
"הפניות לישויות</a>. למידע כללי על שדות "
"וכיצד ליצור ולנהל אותם, ראה את הדפים <a "
"href=\":field\">עזרה בנושא מודול שדות</a> ו-<a "
"href=\":field_ui\">עזרה בנושא ממשק המשתמש של "
"שדות</a>."

msgid ""
"See the <a href=\":entity_reference\">Entity Reference help</a> page "
"for the field widgets and formatters that can be configured for any "
"reference field on the <em>Manage display</em> and <em>Manage form "
"display</em> pages. Taxonomy additionally provides an <em>RSS "
"category</em> formatter that displays nothing when the entity item is "
"displayed as HTML, but displays an RSS category instead of a list when "
"the entity item is displayed in an RSS feed."
msgstr ""
"עיין בדף <a href=\":entity_reference\">עזרה בנושא "
"הפניות לישויות</a> לקבלת מידע על "
"יישומונים ומבנים שניתן להגדיר עבור כל "
"שדה הפניה בדפים <em>ניהול תצוגה</em> "
"ו-<em>ניהול תצוגת טופס</em>. טקסונומיה "
"מספקת בנוסף מעצב <em>RSS category</em> שאינו "
"מציג דבר כאשר פריט הישות מוצג כ-HTML, אך "
"מציג קטגוריית RSS במקום רשימה כאשר פריט "
"הישות מוצג ב-RSS feed."

msgid "No vocabularies available. <a href=\":link\">Add vocabulary</a>."
msgstr ""
"אין אוצר מילים זמין. <a href=\":link\">הוסף "
"אוצר מילים</a>."

msgid "No terms available. <a href=\":link\">Add term</a>."
msgstr ""
"לא נמצאו סיווגים. <a href=\":link\">הוספת "
"סיווג</a>."

msgid "Format of the term description."
msgstr "פורמט תיאור המונח."

msgid "Module responsible for the vocabulary."
msgstr "מודול האחראי על אוצר המילים."

msgid ""
"The Telephone module allows you to create fields that contain "
"telephone numbers. See the <a href=\":field\">Field module help</a> "
"and the <a href=\":field_ui\">Field UI help</a> pages for general "
"information on fields and how to create and manage them. For more "
"information, see the <a href=\":telephone_documentation\">online "
"documentation for the Telephone module</a>."
msgstr ""
"מודול הטלפון מאפשר לך ליצור שדות "
"המכילים מספרי טלפון. עיין בעזרה של "
"מודול השדות ובדפי העזרה של ממשק המשתמש "
"של השדות לקבלת מידע כללי על שדות וכיצד "
"ליצור ולנהל אותם. לקבלת מידע נוסף, עיין "
"בתיעוד המקוון של מודול הטלפון."

msgid ""
"The <em>settings</em> and the <em>display</em> of the telephone field "
"can be configured separately. See the <a href=\":field_ui\">Field UI "
"help</a> for more information on how to manage fields and their "
"display."
msgstr ""
"ניתן להגדיר את <em>ההגדרות</em> ואת "
"<em>התצוגה</em> של שדה הטלפון בנפרד. ראה <a "
"href=\":field_ui\">עזרה לממשק המשתמש של השדה</a> "
"לקבלת מידע נוסף על אופן הניהול של שדות "
"ותצוגתם."

msgid ""
"The Text module allows you to create short and long text fields with "
"optional summaries. See the <a href=\":field\">Field module help</a> "
"and the <a href=\":field_ui\">Field UI help</a> pages for general "
"information on fields and how to create and manage them. For more "
"information, see the <a href=\":text_documentation\">online "
"documentation for the Text module</a>."
msgstr ""
"מודול הטקסט מאפשר לך ליצור שדות טקסט "
"קצרים וארוכים עם סיכומים אופציונליים. "
"ראה את דפי העזרה של מודול השדות ושל "
"ממשק המשתמש של השדות לקבלת מידע כללי "
"על שדות וכיצד ליצור ולנהל אותם. לקבלת "
"מידע נוסף, ראה את התיעוד המקוון של "
"מודול הטקסט."

msgid ""
"The <em>settings</em> and <em>display</em> of the text field can be "
"configured separately. See the <a href=\":field_ui\">Field UI help</a> "
"for more information on how to manage fields and their display."
msgstr ""
"ניתן להגדיר את <em>ההגדרות</em> ואת "
"<em>התצוגה</em> של שדה הטקסט בנפרד. ראה <a "
"href=\":field_ui\">עזרה לממשק המשתמש של השדה</a> "
"לקבלת מידע נוסף על אופן הניהול של שדות "
"ותצוגתם."

msgid ""
"If you choose <em>Text (plain)</em> or <em>Text (plain, long)</em> you "
"restrict the input to <em>Plain text</em> only. If you choose <em>Text "
"(formatted)</em>, <em>Text (formatted, long)</em>, or <em>Text "
"(formatted, long with summary)</em> you allow users to write formatted "
"text. Which options are available to individual users depends on the "
"settings on the <a href=\":formats\">Text formats and editors "
"page</a>."
msgstr ""
"אם תבחר ב-<em>טקסט (רגיל)</em> או ב-<em>טקסט "
"(רגיל, ארוך)</em>, תוגבל הקלדה ל-<em>טקסט "
"רגיל</em> בלבד. אם תבחר ב-<em>טקסט "
"(מעוצב)</em>, <em>טקסט (מעוצב, ארוך)</em> או "
"<em>טקסט (מעוצב, ארוך עם סיכום)</em>, תאפשר "
"למשתמשים לכתוב טקסט מעוצב. האפשרויות "
"הזמינות למשתמשים בודדים תלויות "
"בהגדרות בדף <a href=\":formats\">פורמטים ועורכי "
"טקסט</a>."

msgid "Number of summary rows: @rows"
msgstr "מספר שורות הסיכום: @rows"

msgid ""
"The Toolbar module provides a toolbar for site administrators, which "
"displays tabs and trays provided by the Toolbar module itself and "
"other modules. For more information, see the <a "
"href=\":toolbar_docs\">online documentation for the Toolbar "
"module</a>."
msgstr ""
"מודול סרגל הכלים מספק סרגל כלים למנהלי "
"אתרים, המציג כרטיסיות ומגשים המסופקים "
"על ידי מודול סרגל הכלים עצמו ומודולים "
"אחרים. למידע נוסף, ראה <a "
"href=\":toolbar_docs\">תיעוד מקוון למודול סרגל "
"הכלים</a>."

msgid "Uninstalled modules"
msgstr "מודולים שאינם מותקנים"

msgid "Uninstalled themes"
msgstr "תבניות עיצוב מושבתות"

msgid ""
"No update information available. <a href=\":run_cron\">Run cron</a> or "
"<a href=\":check_manually\">check manually</a>."
msgstr ""
"המידע לגבי עדכונים אפשריים אינו זמין. "
"<a href=\":run_cron\">הריצו cron</a> או <a "
"href=\":check_manually\">בידקו ידנית</a>."

msgid "New release(s) available for @site_name"
msgstr "מהדורות חדשות זמינות עבור @site_name"

msgid ""
"Your site is currently configured to send these emails when any "
"updates are available. To get notified only for security updates, "
"@url."
msgstr ""
"האתר מוגדר כעת לשלוח באימייל הודעות "
"אלו כאשר יש עדכונים זמינים. כדי להגדיר "
"שיתקבלו הודעות רק עבור עדכוני אבטחה, "
"@url."

msgid ""
"Your site is currently configured to send these emails only when "
"security updates are available. To get notified for any available "
"updates, @url."
msgstr ""
"האתר שלך מוגדר כרגע לשלוח מיילים אלה "
"רק כאשר יש עדכוני אבטחה זמינים. כדי "
"לקבל התראות על כל עדכון זמין, @url."

msgid ""
"There was a problem checking <a href=\":update-report\">available "
"updates</a> for Drupal."
msgstr ""
"בדיקת <a href=\":update-report\">העדכונים הזמינים "
"</a> עבור דרופל נתקלה בבעיה."

msgid ""
"There was a problem checking <a href=\":update-report\">available "
"updates</a> for your modules or themes."
msgstr ""
"בדיקת <a href=\":update-report\">העדכונים "
"הזמינים</a> עבור מודולים או עיצובים "
"באתר כשלה בשל בעיה."

msgid ""
"%archive_file contains a version of %names that is not compatible with "
"Drupal @version."
msgid_plural ""
"%archive_file contains versions of modules or themes that are not "
"compatible with Drupal @version: %names"
msgstr[0] ""
"%archive_file מכיל גרסה של %names שאינה תואמת "
"ל-Drupal @version.%archive_file מכיל גרסאות של "
"מודולים או ערכות נושא שאינן תואמות "
"ל-Drupal @version: %names"

msgid ""
"See the <a href=\":available_updates\">available updates</a> page for "
"more information."
msgstr ""
"למידע נוסף, עיין בדף <a "
"href=\":available_updates\">עדכונים זמינים</a>."

msgid "Check for updates of uninstalled modules and themes"
msgstr ""
"בדיקת עדכונים עבור מודולים ותבניות "
"עיצוב שלא הופעלו"

msgid "Deprecated: User Name"
msgstr "מיושן: שם משתמש"

msgid "The display name of the user account."
msgstr "שם התצוגה של חשבון המשתמש."

msgid ""
"The User module allows users to register, log in, and log out. It also "
"allows users with proper permissions to manage user roles and "
"permissions. For more information, see the <a "
"href=\":user_docs\">online documentation for the User module</a>."
msgstr ""
"מודול המשתמש מאפשר למשתמשים להירשם, "
"להתחבר ולצאת. הוא גם מאפשר למשתמשים "
"בעלי הרשאות מתאימות לנהל תפקידים "
"והרשאות של משתמשים. למידע נוסף, ראה <a "
"href=\":user_docs\">תיעוד מקוון למודול "
"המשתמש</a>."

msgid ""
"Through the <a href=\":people\">People administration page</a> you can "
"add and cancel user accounts and assign users to roles. By editing one "
"particular user you can change their username, email address, "
"password, and information in other fields."
msgstr ""
"באמצעות <a href=\":people\">דף ניהול "
"המשתמשים</a> תוכל להוסיף ולבטל חשבונות "
"משתמשים ולהקצות תפקידים למשתמשים. על "
"ידי עריכת משתמש מסוים תוכל לשנות את שם "
"המשתמש, כתובת הדוא\"ל, הסיסמה והמידע "
"בשדות אחרים."

msgid ""
"After creating roles, you can set permissions for each role on the <a "
"href=\":permissions_user\">Permissions page</a>. Granting a permission "
"allows users who have been assigned a particular role to perform an "
"action on the site, such as viewing content, editing or creating  a "
"particular type of content, administering settings for a particular "
"module, or using a particular function of the site (such as search)."
msgstr ""
"לאחר יצירת תפקידים, ניתן להגדיר הרשאות "
"לכל תפקיד בדף <a "
"href=\":permissions_user\">הרשאות</a>. מתן הרשאה "
"מאפשר למשתמשים שהוקצו לתפקיד מסוים "
"לבצע פעולה באתר, כגון צפייה בתוכן, "
"עריכה או יצירה של סוג תוכן מסוים, ניהול "
"הגדרות עבור מודול מסוים או שימוש "
"בפונקציה מסוימת באתר (כגון חיפוש)."

msgid ""
"Because User accounts are an entity type, you can extend them by "
"adding fields through the Manage fields tab on the <a "
"href=\":accounts\">Account settings page</a>. By adding fields for "
"e.g., a picture, a biography, or address, you can a create a custom "
"profile for the users of the website. For background information on "
"entities and fields, see the <a href=\":field_help\">Field module help "
"page</a>."
msgstr ""
"מכיוון שחשבונות משתמשים הם סוג ישות, "
"ניתן להרחיב אותם על ידי הוספת שדות דרך "
"הכרטיסייה 'ניהול שדות' בדף 'הגדרות "
"חשבון'. על ידי הוספת שדות, כגון תמונה, "
"ביוגרפיה או כתובת, ניתן ליצור פרופיל "
"מותאם אישית עבור המשתמשים באתר. למידע "
"רקע על ישויות ושדות, ראה דף העזרה של "
"מודול השדות."

msgid ""
"A role defines a group of users that have certain privileges. These "
"privileges are defined on the <a href=\":permissions\">Permissions "
"page</a>. Here, you can define the names and the display sort order of "
"the roles on your site. It is recommended to order roles from least "
"permissive (for example, Anonymous user) to most permissive (for "
"example, Administrator user). Users who are not logged in have the "
"Anonymous user role. Users who are logged in have the Authenticated "
"user role, plus any other roles granted to their user account."
msgstr ""
"תפקיד מגדיר קבוצת משתמשים בעלי הרשאות "
"מסוימות. הרשאות אלה מוגדרות בדף <a "
"href=\":permissions\">הרשאות</a>. כאן תוכל להגדיר "
"את שמות התפקידים ואת סדר התצוגה שלהם "
"באתר שלך. מומלץ לסדר את התפקידים "
"מהפחות מתירני (לדוגמה, משתמש אנונימי) "
"ועד המתירני ביותר (לדוגמה, משתמש מנהל). "
"למשתמשים שאינם מחוברים יש תפקיד של "
"משתמש אנונימי. למשתמשים מחוברים יש "
"תפקיד של משתמש מאומת, בנוסף לכל תפקיד "
"אחר שהוענק לחשבון המשתמש שלהם."

msgid "Make it at least 12 characters"
msgstr "היא תהיה באורך שלא יפחת מ12 תוים."

msgid ""
"Configure site-wide settings and behavior for user accounts and "
"registration. This includes account cancellation methods, the content "
"of user emails and fields attached to users."
msgstr ""
"קבע את ההגדרות וההתנהגות של חשבונות "
"המשתמשים והרישום בכל האתר. זה כולל "
"שיטות ביטול חשבונות, תוכן הודעות "
"הדוא\"ל של המשתמשים ושדות המצורפים "
"למשתמשים."

msgid ""
"Manage all user accounts. This includes editing all user information, "
"changes of email addresses and passwords, issuing emails to users and "
"blocking and deleting user accounts."
msgstr ""
"נהל את כל חשבונות המשתמשים. זה כולל "
"עריכת כל פרטי המשתמשים, שינויים "
"בכתובות דוא\"ל ובסיסמאות, שליחת דוא\"ל "
"למשתמשים וחסימת ומחיקת חשבונות "
"משתמשים."

msgid ""
"Users with the %select-cancel-method or %administer-users <a "
"href=\":permissions-url\">permissions</a> can override this default "
"method."
msgstr ""
"משתמשים בעלי הרשאות %select-cancel-method או "
"%administer-users <a href=\":permissions-url\">permissions</a> "
"יכולים לעקוף את השיטה המוגדרת כברירת "
"מחדל."

msgid ""
"Available variables are: [site:name], [site:url], [user:display-name], "
"[user:account-name], [user:mail], [site:login-url], [site:url-brief], "
"[user:edit-url], [user:one-time-login-url], [user:cancel-url]."
msgstr ""
"המשתנים הזמינים הם: [site:name], [site:url], "
"[user:display-name], [user:account-name], [user:mail], "
"[site:login-url], [site:url-brief], [user:edit-url], "
"[user:one-time-login-url], [user:cancel-url]."

msgid ""
"Created a new user account for <a href=\":url\">%name</a>. No email "
"has been sent."
msgstr ""
"נוצר חשבון משתמש חדש עבור <a "
"href=\":url\">%name</a>. לא נשלחה הודעת דוא\"ל."

msgid ""
"The new user <a href=\":url\">%name</a> was created without an email "
"address, so no welcome message was sent."
msgstr ""
"המשתמש החדש <a href=\":url\">%name</a> נוצר ללא "
"כתובת דוא\"ל, ולכן לא נשלחה הודעת ברכה."

msgid ""
"A welcome message with further instructions has been emailed to the "
"new user <a href=\":url\">%name</a>."
msgstr ""
"הודעת ברכה עם הוראות נוספות נשלחה "
"בדוא\"ל למשתמש החדש <a href=\":url\">%name</a>."

msgid ""
"Password reset instructions will be sent to your registered email "
"address."
msgstr ""
"הוראות לאיפוס סיסמה יישלחו לכתובת "
"הדוא\"ל המשוייכת לחשבון שלך."

msgid "Send password reset instructions via email."
msgstr "שלח הוראות לאיפוס סיסמה באמצעות דוא\"ל."

msgid "Also known as:"
msgstr "ידוע גם כ:"

msgid "@label (@name:@column)"
msgstr "@label (@name:@column)"

msgid "@label:@column"
msgstr "@label:@column"

msgid "@label (@name:delta)"
msgstr "@label (@name:delta)"

msgid ""
"For more information, see the <a href=\":views\">online documentation "
"for the Views module</a>."
msgstr ""
"למידע נוסף, ראה את <a href=\":views\">התיעוד "
"המקוון של מודול Views</a>."

msgid ""
"Contributed projects that support the Views module can be found in the "
"<a href=\":node\">online documentation for Views-related contributed "
"modules</a>."
msgstr ""
"פרויקטים שתרמו לתמיכה במודול Views ניתן "
"למצוא ב<a href=\":node\">תיעוד מקוון למודולים "
"שתרמו הקשורים ל-Views</a>."

msgid ""
"Changing the title here means it cannot be dynamically altered "
"anymore. (Try changing it directly in <a href=\":url\">@name</a>.)"
msgstr ""
"שינוי הכותרת כאן פירושו שלא ניתן לשנות "
"אותה באופן דינמי יותר. (נסה לשנות אותה "
"ישירות ב-<a href=\":url\">@name</a>.)"

msgid ""
"This link is provided by the Views module. The path can be changed by "
"editing the view <a href=\":url\">@label</a>"
msgstr ""
"קישור זה מסופק על ידי מודול Views. ניתן "
"לשנות את הנתיב על ידי עריכת התצוגה <a "
"href=\":url\">@label</a>"

msgid "@type language selected for page"
msgstr "@type שפה שנבחרה עבור הדף"

msgid "@code (@title)"
msgstr "@code (@title)"

msgid ""
"The following tokens are available. You may use Twig syntax in this "
"field."
msgstr ""
"האסימונים הבאים זמינים. ניתן להשתמש "
"בסינטקס Twig בשדה זה."

msgid ""
"Override the view and other argument titles. You may use Twig syntax "
"in this field as well as the \"arguments\" and \"raw_arguments\" "
"arrays."
msgstr ""
"עקוף את התצוגה וכותרות הטיעונים "
"האחרים. ניתן להשתמש בסינטקס Twig בשדה זה, "
"כמו גם במערך \"arguments\" ו-\"raw_arguments\"."

msgid ""
"Override the view and other argument titles. You may use Twig syntax "
"in this field."
msgstr ""
"עקוף את התצוגה ואת כותרות הטיעונים "
"האחרים. ניתן להשתמש בסינטקס Twig בשדה זה."

msgid "The following replacement tokens are available for this argument."
msgstr ""
"האסימונים הבאים זמינים להחלפה עבור "
"טיעון זה."

msgid ""
"The category this block will appear under on the <a "
"href=\":href\">blocks placement page</a>."
msgstr ""
"הקטגוריה שבה יופיע בלוק זה בדף <a "
"href=\":href\">מיקום בלוקים</a>."

msgid "Separate multiple classes by spaces."
msgstr "הפרד בין מספר מחלקות באמצעות רווחים."

msgid ""
"You may also adjust the @settings for the currently selected access "
"restriction."
msgstr ""
"ניתן גם להתאים את ה@settings עבור סוג זה של "
"הגבלת גישה."

msgid ""
"You may also adjust the @settings for the currently selected cache "
"mechanism."
msgstr ""
"ניתן גם להתאים את ה@settings עבור מכניזם "
"המטמון שנבחר."

msgid "You may also adjust the @settings for the currently selected style."
msgstr "ניתן גם להתאים את ה@settings עבור סגנון זה."

msgid ""
"You may also adjust the @settings for the currently selected row "
"style."
msgstr ""
"ניתן גם להתאים את ה@settings עבור סגנון "
"השורה הנוכחי."

msgid ""
"The following tokens are available for this link. You may use Twig "
"syntax in this field."
msgstr ""
"האסימונים הבאים זמינים עבור קישור זה. "
"ניתן להשתמש בסינטקס Twig בשדה זה."

msgid "You may also adjust the @settings for the currently selected pager."
msgstr ""
"ניתן גם להתאים את ה@settings עבור הפייג'ר "
"הנוכחי."

msgid "An offset from the current time such as \"@example1\" or \"@example2\""
msgstr ""
"קיזוז מהזמן הנוכחי, כגון \"@example1\" או "
"\"@example2\""

msgid ""
"The Views UI module provides an interface for managing views for the "
"<a href=\":views\">Views module</a>. For more information, see the <a "
"href=\":handbook\">online documentation for the Views UI module</a>."
msgstr ""
"מודול ממשק המשתמש של Views מספק ממשק "
"לניהול תצוגות עבור <a href=\":views\">מודול "
"Views</a>. למידע נוסף, ראה <a "
"href=\":handbook\">התיעוד המקוון של מודול ממשק "
"המשתמש של Views</a>."

msgid ""
"Views can be enabled or disabled from the <a href=\":list\">Views list "
"page</a>. To enable a view, find the view within the \"Disabled\" list "
"and select the \"Enable\" operation. To disable a view find the view "
"within the \"Enabled\" list and select the \"Disable\" operation."
msgstr ""
"ניתן להפעיל או להשבית תצוגות מדף <a "
"href=\":list\">רשימת התצוגות</a>. כדי להפעיל "
"תצוגה, חפש את התצוגה ברשימת \"מושבת\" "
"ובחר בפעולה \"הפעל\". כדי להשבית תצוגה, "
"חפש את התצוגה ברשימת \"מופעל\" ובחר "
"בפעולה \"השבית\"."

msgid ""
"Views can be exported and imported as configuration files by using the "
"<a href=\":config\">Configuration Manager module</a>."
msgstr ""
"ניתן לייצא ולייבא תצוגות כקובצי תצורה "
"באמצעות <a href=\":config\">מודול מנהל "
"התצורה</a>."

msgid "Advanced Views settings"
msgstr "הגדרות תצוגה מתקדמות"

msgid "View @display_title"
msgstr "הצג @display_title"

msgid "Duplicate as @type"
msgstr "שכפול כ@type"

msgid "Add @display"
msgstr "הוספת @display"

msgid "By breaking this lock, any unsaved changes made by @user will be lost."
msgstr ""
"על ידי פריצת מנעול זה, כל השינויים שלא "
"נשמרו על ידי @user יאבדו."

msgid "Account cancellation request for [user:display-name] at [site:name]"
msgstr ""
"בקשה לביטול חשבון עבור [user:display-name] "
"ב-[site:name]"

msgid "Replacement login information for [user:display-name] at [site:name]"
msgstr ""
"פרטי כניסה חלופיים עבור [user:display-name] "
"ב-[site:name]"

msgid "Account details for [user:display-name] at [site:name]"
msgstr "פרטי החשבון של [user:display-name] ב-[site:name]"

msgid ""
"Account details for [user:display-name] at [site:name] (pending admin "
"approval)"
msgstr ""
"פרטי החשבון של [user:display-name] ב-[site:name] "
"(ממתין לאישור מנהל)"

msgid ""
"[user:display-name] has applied for an account.\n"
"\n"
"[user:edit-url]"
msgstr ""
"[user:display-name] הגיש בקשה לפתיחת חשבון. "
"[user:edit-url]"

msgid ""
"[user:display-name],\n"
"\n"
"Your account at [site:name] has been "
"activated.\n"
"\n"
"You may now log in by clicking this link or copying "
"and pasting it into your "
"browser:\n"
"\n"
"[user:one-time-login-url]\n"
"\n"
"This link can only be "
"used once to log in and will lead you to a page where you can set your "
"password.\n"
"\n"
"After setting your password, you will be able to log in "
"at [site:login-url] in the future using:\n"
"\n"
"username: "
"[user:account-name]\n"
"password: Your password\n"
"\n"
"--  [site:name] "
"team"
msgstr ""
"[user:display-name], חשבונך ב-[site:name] הופעל. כעת "
"תוכל להתחבר על ידי לחיצה על קישור זה או "
"העתקתו והדבקתו בדפדפן שלך: "
"[user:one-time-login-url]\n"
"\n"
"קישור זה ניתן לשימוש "
"חד-פעמי בלבד לצורך כניסה, והוא יוביל "
"אותך לדף שבו תוכל להגדיר את הסיסמה שלך. "
"לאחר הגדרת הסיסמה, תוכל להתחבר בעתיד "
"לכתובת [אתר:כתובת-כניסה] באמצעות: שם "
"משתמש: [משתמש:שם-חשבון] סיסמה: הסיסמה "
"שלך -- צוות [אתר:שם]"

msgid "Account details for [user:display-name] at [site:name] (approved)"
msgstr ""
"פרטי החשבון של [user:display-name] ב-[site:name] "
"(אושר)"

msgid "Account details for [user:display-name] at [site:name] (blocked)"
msgstr ""
"פרטי החשבון של [user:display-name] ב-[site:name] "
"(חסום)"

msgid ""
"[user:display-name],\n"
"\n"
"Your account on [site:name] has been "
"canceled.\n"
"\n"
"--  [site:name] team"
msgstr ""
"[user:display-name], חשבונך ב-[site:name] בוטל. -- צוות "
"[site:name]"

msgid "Account details for [user:display-name] at [site:name] (canceled)"
msgstr ""
"פרטי החשבון של [user:display-name] ב-[site:name] "
"(בוטל)"

msgid "Hide logo"
msgstr "הסתר לוגו"

msgid ""
"@display '@id': Component '@name' was disabled because its settings "
"depend on removed dependencies."
msgstr ""
"@display '@id': הרכיב '@name' הושבת מכיוון "
"שהגדרותיו תלויות בתלות שהוסרו."

msgid "No widget available for: %type."
msgstr "אין ווידג'ט זמין עבור: %type."

msgid ""
"Several special characters are allowed, including space, period (.), "
"hyphen (-), apostrophe ('), underscore (_), and the @ sign."
msgstr ""
"ניתן להשתמש במספר תווים מיוחדים, כולל "
"רווח, נקודה (.), מקף (-), גרש ('), קו תחתון (_) "
"וסימן @."

msgid ""
"The URL to which the user should be redirected. This can be an "
"internal URL like /node/1234 or an external URL like @url."
msgstr ""
"כתובת ה-URL אליה יש להפנות את המשתמש. זו "
"יכולה להיות כתובת URL פנימית כמו /node/1234 "
"או כתובת URL חיצונית כמו @url."

msgid ""
"The Automated Cron module runs cron operations for your site using "
"normal browser/page requests instead of having to set up a separate "
"cron job. The Automated Cron module checks at the end of each server "
"response when cron operation was last ran and, if it has been too long "
"since last run, it executes the cron tasks after sending a server "
"response. For more information, see the <a "
"href=\":automated_cron-documentation\">online documentation for the "
"Automated Cron module</a>."
msgstr ""
"מודול Automated Cron מפעיל פעולות cron עבור "
"האתר שלך באמצעות בקשות דפדפן/דף "
"רגילות, במקום להגדיר משימת cron נפרדת. "
"מודול Automated Cron בודק בסוף כל תגובה של "
"השרת מתי הופעלה פעולת cron לאחרונה, ואם "
"עבר זמן רב מדי מאז ההפעלה האחרונה, הוא "
"מבצע את משימות cron לאחר שליחת תגובה "
"מהשרת. למידע נוסף, ראה את <a "
"href=\":automated_cron-documentation\">התיעוד המקוון של "
"מודול Cron האוטומטי</a>."

msgid "Configuring Automated Cron"
msgstr "הגדרת Cron אוטומטי"

msgid ""
"On the <a href=\":cron-settings\">Cron page</a>, you can set the "
"frequency (time interval) for running cron jobs."
msgstr ""
"בדף <a href=\":cron-settings\">Cron</a>, ניתן להגדיר את "
"התדירות (מרווח הזמן) להפעלת משימות cron."

msgid "Disabling Automated Cron"
msgstr "השבתת Cron אוטומטי"

msgid ""
"To disable automated cron, the recommended method is to uninstall the "
"module, to reduce site overhead. If you only want to disable it "
"temporarily, you can set the frequency to Never on the Cron page, and "
"then change the frequency back when you want to start it up again."
msgstr ""
"כדי להשבית את cron האוטומטי, השיטה "
"המומלצת היא להסיר את ההתקן, כדי להפחית "
"את העומס על האתר. אם ברצונך להשבית אותו "
"באופן זמני בלבד, תוכל להגדיר את "
"התדירות ל-Never (לעולם) בדף Cron, ולאחר מכן "
"לשנות את התדירות בחזרה כאשר תרצה "
"להפעיל אותו שוב."

msgid "Automated Cron"
msgstr "Cron אוטומטי"

msgid ""
"Provides an automated way to run cron jobs, by executing them at the "
"end of a server response."
msgstr ""
"מספק דרך אוטומטית להפעלת משימות cron, על "
"ידי ביצוען בסוף תגובת השרת."

msgid "Automated cron settings"
msgstr "הגדרות cron אוטומטיות"

msgid "Ban visits from specific IP addresses."
msgstr "חסימת ביקורים מכתובות IP ספציפיות."

msgid ""
"You can place a new block in a region by selecting <em>Place "
"block</em> on the <a href=\":blocks\">Block layout page</a>. Once a "
"block is placed, it can be moved to a different region by "
"drag-and-drop or by using the <em>Region</em> drop-down list, and then "
"clicking <em>Save blocks</em>."
msgstr ""
"ניתן למקם בלוק חדש באזור על ידי בחירת "
"<em>Place block</em> (מקם בלוק) בדף <a "
"href=\":blocks\">Block layout</a> (פריסת בלוקים). לאחר "
"מיקום הבלוק, ניתן להעבירו לאזור אחר "
"באמצעות גרירה ושחרור או באמצעות "
"הרשימה הנפתחת <em>Region</em> (אזור) ולאחר מכן "
"לחיצה על <em>Save blocks</em> (שמור בלוקים)."

msgid ""
"Block placement is specific to each theme on your site. Changes will "
"not be saved until you click <em>Save blocks</em> at the bottom of the "
"page."
msgstr ""
"מיקום הבלוקים ספציפי לכל ערכת נושא "
"באתר שלך. השינויים לא יישמרו עד שתלחץ "
"על <em>שמור בלוקים</em> בתחתית העמוד."

msgid "Adding comment types"
msgstr "הוספת סוגי הערות"

msgid ""
"Additional <em>comment types</em> can be created per entity sub-type "
"and added on the <a href=\":field\">Comment types page</a>. If there "
"are multiple comment types available you can select the appropriate "
"one after adding a <em>Comments field</em>."
msgstr ""
"ניתן ליצור <em>סוגי הערות</em> נוספים לכל "
"תת-סוג של ישות ולהוסיף אותם בדף <a "
"href=\":field\">סוגי הערות</a>. אם קיימים מספר "
"סוגי הערות, ניתן לבחור את הסוג המתאים "
"לאחר הוספת <em>שדה הערות</em>."

msgid ""
"Compare the configuration uploaded to your sync directory with the "
"active configuration before completing the import."
msgstr ""
"השוו את התצורה שהועלתה לספריית "
"הסינכרון עם התצורה הפעילה לפני השלמת "
"הייבוא."

msgid ""
"Upload a full site configuration archive to the sync directory. It can "
"then be compared and imported on the Synchronize page."
msgstr ""
"העלת קובץ דחוס עם ארכיון הגדרות מלא "
"לתקיית הסינכרון. לאחר מכן ניתן יהיה "
"לבצע השוואה ולייבא את השינויים "
"באמצעות דף הסינכרון."

msgid ""
"The Database Logging module logs system events in the Drupal database. "
"Monitor your site or debug site problems on this page."
msgstr ""
"מודול רישום מסד הנתונים רושם אירועי "
"מערכת במסד הנתונים של Drupal. עקבו אחר "
"האתר שלכם או פתרו בעיות באתר בעמוד זה."

msgid ""
"The Internal Dynamic Page Cache module caches pages for all users in "
"the database, handling dynamic content correctly. For more "
"information, see the <a "
"href=\":dynamic_page_cache-documentation\">online documentation for "
"the Internal Dynamic Page Cache module</a>."
msgstr ""
"מודול המטמון הדינמי הפנימי של דפים "
"(Internal Dynamic Page Cache) מאחסן במטמון דפים "
"עבור כל המשתמשים בבסיס הנתונים, ומטפל "
"בתוכן דינמי בצורה נכונה. למידע נוסף, "
"ראה <a href=\":dynamic_page_cache-documentation\">תיעוד "
"מקוון למודול המטמון הדינמי הפנימי של "
"דפים</a>."

msgid ""
"The module requires no configuration. Every part of the page contains "
"metadata that allows Internal Dynamic Page Cache to figure this out on "
"its own."
msgstr ""
"המודול אינו דורש תצורה. כל חלק של הדף "
"מכיל מטא-נתונים המאפשרים ל-Internal Dynamic Page "
"Cache להבין זאת בעצמו."

msgid ""
"<strong>Entity Reference</strong> fields allow you to create fields "
"that contain links to other entities (such as content items, taxonomy "
"terms, etc.) within the site. This allows you, for example, to include "
"a link to a user within a content item. For more information, see <a "
"href=\":er_do\">the online documentation for the Entity Reference "
"module</a>."
msgstr ""
"שדות <strong>Entity Reference</strong> מאפשרים לך "
"ליצור שדות המכילים קישורים לישויות "
"אחרות (כגון פריטי תוכן, מונחי "
"טקסונומיה וכו') בתוך האתר. הדבר מאפשר "
"לך, למשל, לכלול קישור למשתמש בתוך פריט "
"תוכן. למידע נוסף, ראה <a href=\":er_do\">התיעוד "
"המקוון של מודול Entity Reference</a>."

msgid "Enable custom storage"
msgstr "אפשר אחסון מותאם אישית"

msgid "An instance-specific widget type"
msgstr "סוג ווידג'ט ספציפי למקרה"

msgid ""
"Widget types @types are used in Drupal 6 field instances: widget type "
"@selected_type applied to the Drupal 8 base field"
msgstr ""
"סוגי ווידג'טים @types משמשים במקרי שדה "
"ב-Drupal 6: סוג ווידג'ט @selected_type המוחל על "
"שדה הבסיס ב-Drupal 8"

msgid ""
"You can define which users will be able to use each text format by "
"selecting roles. To ensure security, anonymous and untrusted users "
"should only have access to text formats that restrict them to either "
"plain text or a safe set of HTML tags. This is because HTML tags can "
"allow embedding malicious links or scripts in text. More trusted "
"registered users may be granted permission to use less restrictive "
"text formats in order to create rich text. <strong>Improper text "
"format configuration is a security risk.</strong>"
msgstr ""
"ניתן להגדיר אילו משתמשים יוכלו להשתמש "
"בכל פורמט טקסט על ידי בחירת תפקידים. "
"כדי להבטיח אבטחה, למשתמשים אנונימיים "
"ולא מהימנים צריכה להיות גישה רק "
"לפורמטים טקסט המגבילים אותם לטקסט "
"רגיל או לקבוצה בטוחה של תגי HTML. הסיבה "
"לכך היא שתגי HTML מאפשרים להטמיע קישורים "
"או סקריפטים זדוניים בטקסט. למשתמשים "
"רשומים מהימנים יותר ניתן להעניק הרשאה "
"להשתמש בפורמטים טקסט פחות מגבילים כדי "
"ליצור טקסט עשיר. <strong>תצורה לא נכונה של "
"פורמט טקסט מהווה סיכון אבטחה.</strong>"

msgid ""
"Each text format uses filters that add, remove, or transform elements "
"within user-entered text. For example, one filter removes unapproved "
"HTML tags, while another transforms URLs into clickable links. Filters "
"are applied in a specific order. They do not change the "
"<em>stored</em> content: they define how it is processed and "
"displayed."
msgstr ""
"כל פורמט טקסט משתמש במסננים המוסיפים, "
"מסירים או משנים אלמנטים בתוך הטקסט "
"שהוזן על ידי המשתמש. לדוגמה, מסנן אחד "
"מסיר תגי HTML לא מאושרים, בעוד מסנן אחר "
"הופך כתובות URL לקישורים שניתן ללחוץ "
"עליהם. המסננים מוחלים בסדר מסוים. הם "
"אינם משנים את התוכן <em>המאוחסן</em>: הם "
"מגדירים כיצד הוא מעובד ומוצג."

msgid ""
"Text formats define how text is filtered for output and how HTML tags "
"and other text is displayed, replaced, or removed. <strong>Improper "
"text format configuration is a security risk.</strong> Learn more on "
"the <a href=\":filter_help\">Filter module help page</a>."
msgstr ""
"פורמטים של טקסט מגדירים כיצד מסננים "
"טקסט לפלט וכיצד תגי HTML וטקסט אחר "
"מוצגים, מוחלפים או מוסרים. <strong>תצורה "
"לא נכונה של פורמט טקסט מהווה סיכון "
"אבטחה.</strong> למידע נוסף, עיינו ב<a "
"href=\":filter_help\">דף העזרה של מודול "
"הסינון</a>."

msgid ""
"A text format contains filters that change the display of user input; "
"for example, stripping out malicious HTML or making URLs clickable. "
"Filters are executed from top to bottom and the order is important, "
"since one filter may prevent another filter from doing its job. For "
"example, when URLs are converted into links before disallowed HTML "
"tags are removed, all links may be removed. When this happens, the "
"order of filters may need to be rearranged."
msgstr ""
"פורמט טקסט מכיל מסננים המשנים את תצוגת "
"הקלט של המשתמש; לדוגמה, הסרת HTML זדוני "
"או הפיכת כתובות URL לניתנות ללחיצה. "
"המסננים מופעלים מלמעלה למטה, והסדר "
"חשוב, שכן מסנן אחד עלול למנוע ממסנן אחר "
"לבצע את תפקידו. לדוגמה, כאשר כתובות URL "
"מומרות לקישורים לפני הסרת תגי HTML "
"אסורים, כל הקישורים עלולים להוסר. כאשר "
"זה קורה, ייתכן שיהיה צורך לשנות את סדר "
"המסננים."

msgid ""
"Configure how content is filtered when displayed, including which HTML "
"tags are rendered, and enable module-provided filters."
msgstr ""
"קבע כיצד לסנן תוכן בעת הצגתו, כולל אילו "
"תגי HTML יועברו, והפעל מסננים המסופקים "
"על ידי המודול."

msgid ""
"A list of HTML tags that can be used. By default only the "
"<em>lang</em> and <em>dir</em> attributes are allowed for all HTML "
"tags. Each HTML tag may have attributes which are treated as allowed "
"attribute names for that HTML tag. Each attribute may allow all "
"values, or only allow specific values. Attribute names or values may "
"be written as a prefix and wildcard like <em>jump-*</em>. JavaScript "
"event attributes, JavaScript URLs, and CSS are always stripped."
msgstr ""
"רשימת תגי HTML שניתן להשתמש בהם. כברירת "
"מחדל, רק התכונות <em>lang</em> ו-<em>dir</em> "
"מותרות בכל תגי HTML. כל תגית HTML עשויה "
"לכלול תכונות המטופלות כשם תכונה מותר "
"עבור אותה תגית HTML. כל תכונה עשויה לאפשר "
"את כל הערכים, או רק ערכים ספציפיים. "
"שמות תכונות או ערכים עשויים להיכתב "
"כקידומת וככרטיסיה כללית, כגון "
"<em>jump-*</em>. תכונות אירוע JavaScript, כתובות URL "
"של JavaScript ו-CSS מוסרים תמיד."

msgid "Configure languages for content, interface, and configuration."
msgstr "הגדר שפות לתוכן, לממשק ולהגדרות."

msgid "Overriding default English strings"
msgstr "עקיפת מחרוזות ברירת המחדל באנגלית"

msgid ""
"If translation is enabled for English, you can <em>override</em> the "
"default English interface text strings in your site with other English "
"text strings on the <a href=\":translate\">User interface "
"translation</a> page. Translation is off by default for English, but "
"you can turn it on by visiting the <em>Edit language</em> page for "
"<em>English</em> from the <a href=\":languages\">Languages</a> page."
msgstr ""
"אם התרגום מופעל עבור אנגלית, תוכל "
"<em>לעקוף</em> את מחרוזות הטקסט המוגדרות "
"כברירת מחדל בממשק האנגלי באתר שלך "
"באמצעות מחרוזות טקסט אחרות באנגלית "
"בדף <a href=\":translate\">תרגום ממשק המשתמש</a>. "
"תרגום כבוי כברירת מחדל עבור אנגלית, אך "
"ניתן להפעיל אותו על ידי מעבר לדף "
"<em>ערוך שפה</em> עבור <em>אנגלית</em> מדף <a "
"href=\":languages\">שפות</a>."

msgid ""
"Configure the import of translation files, and add or customize "
"interface translations."
msgstr ""
"הגדר את ייבוא קבצי התרגום, והוסף או "
"התאם אישית תרגומים לממשק."

msgid "Manage menus and menu links."
msgstr "נהול תפריטים וקישורי תפריט."

msgid "<q>Log in</q> for anonymous users"
msgstr "<q>התחבר</q> עבור משתמשים אנונימיים"

msgid "Revert to earlier revision of a translation"
msgstr "חזרה לגרסה קודמת של תרגום"

msgid ""
"Are you sure you want to revert @language translation to the revision "
"from %revision-date?"
msgstr ""
"האם אתה בטוח שברצונך להחזיר את תרגום "
"@language לגרסה מ-%revision-date?"

msgid "Revert content shared among translations"
msgstr "החזרת תוכן משותף בין תרגומים"

msgid "Add custom URLs to existing paths."
msgstr "הוספת כתובות URL מותאמות לנתיבים קיימים"

msgid "- None (original image) -"
msgstr "- אין (תמונה מקורית) -"

msgid ""
"Only items in the index will appear in search results. To build and "
"maintain the index, a correctly configured <a href=\":cron\">cron "
"maintenance task</a> is required."
msgstr ""
"רק פריטים באינדקס יופיעו בתוצאות "
"החיפוש. כדי לבנות ולתחזק את האינדקס, "
"נדרשת <a href=\":cron\">משימת תחזוקה cron</a> "
"המוגדרת כהלכה."

msgid ""
"The minimum character length for a word to be added to the index. "
"Searches must include a keyword of at least this length."
msgstr ""
"אורך התווים המינימלי של מילה שניתן "
"להוסיף לאינדקס. חיפושים חייבים לכלול "
"מילת מפתח באורך זה לפחות."

msgid "Checking site status"
msgstr "בדיקת מצב האתר"

msgid ""
"The <a href=\":status\">Status report</a> provides an overview of the "
"configuration, status, and health of your site. Review this report to "
"make sure there are not any problems to address, and to find "
"information about the software your site and web server are using."
msgstr ""
"דוח <a href=\":status\">סטטוס</a> מספק סקירה "
"כללית של התצורה, הסטטוס והתקינות של "
"האתר שלך. עיין בדוח זה כדי לוודא שאין "
"בעיות שצריך לטפל בהן, וכדי למצוא מידע "
"על התוכנה שהאתר שלך ושרת האינטרנט שלך "
"משתמשים בה."

msgid ""
"In order for the site and its modules to continue to operate well, a "
"set of routine administrative operations must run on a regular basis; "
"these operations are known as <em>cron</em> tasks. On the <a "
"href=\":cron\">Cron page</a>, you can configure cron to run "
"periodically as part of server responses by installing the "
"<em>Automated Cron</em> module, or you can turn this off and trigger "
"cron from an outside process on your web server. You can verify the "
"status of cron tasks by visiting the <a href=\":status\">Status report "
"page</a>. For more information, see the <a href=\":handbook\">online "
"documentation for configuring cron jobs</a>."
msgstr ""
"על מנת שהאתר והמודולים שלו ימשיכו "
"לפעול כראוי, יש לבצע באופן קבוע סדרה של "
"פעולות ניהול שגרתיות; פעולות אלה "
"מכונות משימות <em>cron</em>. בדף <a "
"href=\":cron\">Cron</a>, ניתן להגדיר את cron כך "
"שיפעל באופן תקופתי כחלק מתגובות השרת "
"על ידי התקנת המודול <em>Automated Cron</em>, או "
"ניתן לבטל הגדרה זו ולהפעיל את cron "
"מתהליך חיצוני בשרת האינטרנט. ניתן לאמת "
"את מצב משימות cron על ידי ביקור ב-<a "
"href=\":status\">דף דוח המצב</a>. למידע נוסף, ראה "
"<a href=\":handbook\">תיעוד מקוון להגדרת משימות "
"cron</a>."

msgid "Public file base URL"
msgstr "כתובת URL של בסיס הקבצים הציבורי"

msgid ""
"The base URL that will be used for public file URLs. This can be "
"changed in settings.php"
msgstr ""
"כתובת ה-URL הבסיסית שתשמש לכתובות URL של "
"קבצים ציבוריים. ניתן לשנות אותה בקובץ "
"settings.php."

msgid ""
"Machine name: <span dir=\"ltr\" "
