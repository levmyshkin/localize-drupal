"        <ul> <li><code>&lt;img src=\"\" "
"data-caption=\"This is a caption\" /&gt;</code></li> "
"<li><code>&lt;video src=\"\" data-caption=\"The Drupal Dance\" "
"/&gt;</code></li>\n"
"            <li><code>&lt;blockquote "
"data-caption=\"Dries Buytaert\"&gt;Drupal הוא "
"מדהים!&lt;/blockquote&gt;</code></li> <li><code>&lt;code "
"data-caption=\"שלום עולם ב-JavaScript.\"&gt;alert(\"שלום "
"עולם!\");&lt;/code&gt;</code></li> </ul>"

