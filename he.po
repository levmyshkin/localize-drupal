msgid "Delete this @item?"
msgid_plural "Delete these @items?"
msgstr[0] "למחוק את הפריט הזה?"

msgid "Archive webform"
msgstr "ארכיון טופס אינטרנט"

msgid "Close webform"
msgstr "סגור טופס מקוון"

msgid "Restore webform"
msgstr "שחזור טופס אינטרנט"

msgid "Star/flag submission"
msgstr "הגשת כוכב/דגל"

msgid ""
"%form: Email not sent for %handler handler because the <em>@type</em> "
"email (%email) is not valid."
msgstr ""
"%form: הדוא\"ל לא נשלח עבור %handler handler "
"מכיוון שכתובת הדוא\"ל <em>@type</em> (%email) "
"אינה חוקית."

