msgid ""
"The below Ajax scroll, effect, and speed settings will also be applied "
"to cards."
msgstr ""
"הגדרות הגלילה, האפקט והמהירות של Ajax "
"המפורטות להלן יחולו גם על כרטיסים."

msgid "Page/card name (?page=contact)"
msgstr "שם הדף/הכרטיס (?page=contact)"

msgid "Page/card index (?page=2)"
msgstr "אינדקס עמודים/כרטיסים (?page=2)"

