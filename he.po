msgid "Translating individual strings"
msgstr "תרגום מחרוזות בודדות"

msgid "Could not save to map table due to missing destination id values"
msgstr ""
"לא ניתן לשמור בטבלת המפה עקב ערכי מזהה "
"יעד חסרים"

msgid "Format ID."
msgstr "פורמט ID."

msgid "(this translation)"
msgstr "(התרגום הזה)"

