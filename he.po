msgstr ""
"ציין מזהה ישות מותאם אישית. פעולה זו "
"תגבר על מזהה הישות בתצורה שלעיל."

msgid "Completed @current step of @total."
msgstr "הושלם שלב @current מתוך @total."

msgid "The configuration synchronization failed validation."
msgstr "הסנכרון של התצורה נכשל באימות."

msgid "The configuration was imported with errors."
msgstr "הקונפיגורציה יובאה עם שגיאות."

msgid ""
"All links are validated after a link field is filled in. They can "
"include anchors or query strings."
msgstr ""
"כל הקישורים מאומתים לאחר מילוי שדה "
"הקישור. הם יכולים לכלול עוגנים או "
"מחרוזות שאילתה."

