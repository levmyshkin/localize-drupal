msgid "Unique redirect"
msgstr "הפניה ייחודית"

msgid "Link count"
msgstr "מספר הקישורים"

msgid "hourly"
msgstr "לפי שעה"

msgid "always"
msgstr "תמיד"

msgid "Initializing..."
msgstr "אתחול..."

