msgstr "קוד השפה של השפה שבה נכתב ההערה."

msgid "The message language code."
msgstr "קוד שפת ההודעה."

msgid "The source language from which this translation was created."
msgstr "שפת המקור שממנה נוצר תרגום זה."

msgid "Translation outdated"
msgstr "תרגום מיושן"

msgid "Translation author"
msgstr "מחבר התרגום"

msgid "The author of this translation."
msgstr "מחבר התרגום."

msgid ""
"A boolean indicating whether the translation is visible to "
"non-translators."
msgstr ""
"ערך בוליאני המציין אם התרגום גלוי "
"למתרגמים שאינם מתרגמים."

msgid "Translation created time"
msgstr "זמן יצירת התרגום"

msgid "The Unix timestamp when the translation was created."
msgstr "חותמת הזמן של Unix בעת יצירת התרגום."

