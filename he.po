msgid "Translations"
msgstr "תרגומים"

msgid "A locally hosted document, such as a PDF file."
msgstr "מסמך שמאוחסן באופן מקומי, כגון קובץ PDF."

msgid "A locally hosted image file."
msgstr "קובץ תמונה שמאוחסן באופן מקומי."

msgid "A video hosted on an external site (for example, YouTube or Vimeo)."
msgstr ""
"סרטון המארח באתר חיצוני (לדוגמה, YouTube "
"או Vimeo)."

