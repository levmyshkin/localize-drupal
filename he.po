msgstr ""
"אפשרויות %title נקבעות על ידי %module_names "
"@module. שינוי של אחת מהאפשרויות שלהלן "
"יגבר על האפשרויות המאוכלסות באופן "
"דינמי."

msgid ""
"The %title options have been customized. Resetting the below options "
"will allow the %module_names @module to dynamically populate these "
"options."
msgstr ""
"אפשרויות %title הותאמו אישית. איפוס "
"האפשרויות שלהלן יאפשר ל-%module_names @module "
