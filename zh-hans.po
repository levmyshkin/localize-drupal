msgstr "Drush 无法加载 Colorbox 库"

msgid ""
"You can find new features in the <a href=\"@url_colorbox_load\" "
"target=\"blank\">Colorbox Load</a> and <a "
"href=\"@url_colorbox_inline\" target=\"blank\">Colorbox Inline</a>"
msgstr ""
"你可以在 <a href=\"@url_colorbox_load\" target=\"blank\">Colorbox "
"Load</a> 和 <a href=\"@url_colorbox_inline\" "
"target=\"blank\">Colorbox Inline</a> 中找到新功能。"

