msgstr "查看 @entity_label"

msgid "View @entity_bundle @entity_id"
msgstr "查看 @entity_bundle @entity_id"

msgid "Maintenance mode enabled."
msgstr "已启用维护模式。"

msgid "Maintenance mode disabled."
msgstr "维护模式已禁用。"

