msgstr "شامل %bundles"

msgid "Single"
msgid_plural "Limited to @count"
msgstr[0] ""
"تکی  \n"
"محدود به @count"

msgid ""
"Updates entity links with <code>data-entity-type</code> and "
"<code>data-entity-uuid</code> attributes to point to the latest entity "
"URL aliases."
msgstr ""
"پیوندهای موجودیت را با ویژگی‌های "
