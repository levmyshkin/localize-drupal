msgstr ""
"اگر انتخاب شود، کاربران قادر خواهند "
"بود ارسال‌های قبلی خود را تکرار کنند."

msgid "Enable inline form errors"
msgstr ""
"فعال‌سازی خطاهای فرم به صورت "
