msgstr ""
"نمایش همه آیتم‌هایی که این نما ممکن "
"است پیدا کند."

msgid "Displays rows as HTML list."
msgstr ""
"ردیف‌ها را به صورت فهرست HTML نمایش "
"می‌دهد."

msgid "Language detection and selection"
msgstr "تشخیص و انتخاب زبان"

msgid "menus"
msgstr "قائمها"

msgid "Toolkit"
msgstr "جعبه‌ابزار"

