"@message"

msgid ""
"Check the <a "
"href=\"https://www.php.net/manual/en/image.installation.php\">PHP GD "
"installation documentation</a> if you want to add support."
msgstr ""
"اگر می‌خواهید پشتیبانی اضافه کنید، "
"مستندات نصب <a "
"href=\"https://www.php.net/manual/en/image.installation.php\">PHP "
"GD</a> را بررسی کنید."

msgid "@unsupported<br>@ref"
msgstr "@پشتیبانی‌نشده<br>@ارجاع"

msgid ""
"The GD Library for PHP is enabled, but was compiled without support "
"for functions used by the rotate and desaturate effects. It was "
"probably compiled using the official GD libraries from the <a "
"href=\"https://libgd.github.io/\">gdLibrary site</a> instead of the GD "
"library bundled with PHP. You should recompile PHP --with-gd using the "
"bundled GD library. See <a "
"href=\"https://www.php.net/manual/book.image.php\">the PHP manual</a>."
msgstr ""
"کتابخانه GD برای PHP فعال است، اما بدون "
"پشتیبانی از توابعی که توسط افکت‌های "
"چرخش و کاهش اشباع استفاده می‌شوند، "
"کامپایل شده است. احتمالاً این کتابخانه "
"با استفاده از کتابخانه‌های رسمی GD از <a "
"href=\"https://libgd.github.io/\">سایت gdLibrary</a> به جای "
"کتابخانه GD که همراه با PHP عرضه می‌شود، "
"کامپایل شده است. شما باید PHP را دوباره "
"با گزینه --with-gd و با استفاده از کتابخانه "
"GD همراه PHP کامپایل کنید. برای اطلاعات "
"بیشتر به <a "
"href=\"https://www.php.net/manual/book.image.php\">راهنمای "
"PHP</a> مراجعه کنید."

msgid "Supported image file format: %formats."
msgid_plural "Supported image file formats: %formats."
msgstr[0] ""
"فرمت‌های فایل تصویر پشتیبانی شده: "
"%formats.  \n"
