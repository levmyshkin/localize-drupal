msgstr ""
"پیکربندی %name وابسته به قالب %owner است که "
"پس از وارد کردن نصب نخواهد شد."

msgid ""
"Configuration %name depends on the %owner extension that will not be "
"installed after import."
msgstr ""
"پیکربندی %name به افزونه %owner بستگی دارد "
"که پس از وارد کردن نصب نخواهد شد."

msgid ""
"Unable to install the %module module since it requires the "
