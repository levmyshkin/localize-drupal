msgstr ""
"اگر انتخاب شود، اقدامات محرک به همه "
"کاربران روی صفحه نمایش داده خواهد شد."

msgid "%key is not valid element key."
msgstr "%key یک کلید عنصر معتبر نیست."

msgid "Flagged/Starred"
msgstr "نشانه‌گذاری شده/ستاره‌دار"

msgid "Unflagged/Unstarred"
msgstr "علامت‌گذاری نشده / نشانه‌گذاری نشده"

msgid "Trigger an action on a submission."
msgstr "راه‌اندازی یک عملیات روی یک ارسال."

msgid "Custom settings (YAML)"
msgstr "تنظیمات سفارشی (YAML)"

msgid "Enter the setting name and value as YAML."
msgstr ""
"نام و مقدار تنظیمات را به صورت YAML وارد "
