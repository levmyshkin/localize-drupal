msgstr ""
"نمی‌توان ماژول %module را حذف کرد زیرا "
"ماژول %dependent_module نصب شده است."

msgid "Unable to install the %theme theme since it does not exist."
msgstr ""
"نمی‌توان قالب %theme را نصب کرد زیرا وجود "
"ندارد."

msgid ""
"Unable to install the %theme theme since it requires the "
"%required_theme theme."
msgstr ""
"نمی‌توان قالب %theme را نصب کرد زیرا نیاز "
"به قالب %required_theme دارد."

msgid ""
"Unable to uninstall the %theme theme since the %dependent_theme theme "
"is installed."
msgstr ""
"قادر به حذف قالب %theme نیستید زیرا قالب "
"%dependent_theme نصب شده است."

msgid ""
"Configuration %name depends on the %owner module that will not be "
