msgstr "نمایش چندین فایل"

msgid "Welcome!"
msgstr "خوش آمدید!"

msgid "Configuration Translation"
msgstr "ترجمهٔ پیکربندی"

msgid "- empty image -"
msgstr "- تصویر خالی -"

