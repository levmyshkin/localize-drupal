msgstr "Tüm uzak CRUD isteklerine dâhil edilecek özel verileri girin."

msgid ""
"If checked, elements with 'Display element' unchecked (i.e., "
"<code>'#access': false</code> will not be included in the request "
"data."
msgstr ""
"İşaretlenirse, “Öğeyi görüntüle” seçeneği işaretli "
"olmayan öğeler (ör. <code>'#access': false</code>) istek verilerine "
"dahil edilmez."

msgid "Remote CRUD request return @status_code status code."
msgstr "Uzak CRUD isteği, @status_code durum kodunu döndürür."

msgid "Remote HTTP operation successful!"
msgstr "Uzak HTTP işlemi başarıyla tamamlandı!"

msgid "Debug: Remote HTTP operation: @title [@state]"
msgstr "Hata ayıklama: Uzak HTTP işlemi: @title [@state]"

msgid "Remote HTTP Operations"
msgstr "Uzak HTTP İşlemleri"

