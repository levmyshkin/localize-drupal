msgstr "Kaydet + Öğe ekle"

msgid "Webform access controls"
msgstr "Webform erişim kontrolleri"

msgid "Access Control | Tag1 Consulting"
msgstr "Erişim Kontrolü | Tag1 Consulting"

msgid "Opening webforms in modal dialogs"
msgstr "Modal iletişim kutularında webformları açma"

