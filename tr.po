msgstr "<a href=\":href\">CDN uyarısını devre dışı bırak</a>"

msgid ""
"@total libraries (@installed installed; @excluded excluded; @missing "
"CDN)"
msgstr ""
"@total kütüphane (@installed yüklü; @excluded hariç tutulmuş; "
"@missing CDN)"

msgid "Drupal Association"
msgstr "Drupal Derneği"

msgid ""
"The below requirements are checked by the <a href=\":href\">Status "
"report</a>."
msgstr ""
"Aşağıdaki gereksinimler <a href=\":href\">Durum raporu</a> "
"tarafından kontrol edilir."

msgid ""
"If unchecked, all warnings about Webform SPAM protection will be "
"disabled."
msgstr ""
"İşaretlenmezse, Webform SPAM korumasıyla ilgili tüm uyarılar "
"devre dışı bırakılır."

msgid "Check that all entered values for this element are unique."
msgstr ""
"Bu öğe için girilen tüm değerlerin benzersiz olduğundan emin "
"olun."

msgid ""
"Check that entered values for this element is unique for the current "
"source entity."
msgstr ""
"Bu öğe için girilen değerlerin, mevcut kaynak varlık için "
"benzersiz olduğunu kontrol edin."

