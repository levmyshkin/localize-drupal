msgstr "%name, %min tarihinde veya sonrasında olmalıdır."

msgid "%name must be on or before %max."
msgstr "%name, %max değerinden geç olmamalıdır."

msgid "Select the date parts and order that should be used in the element."
msgstr "Öğede kullanılacak tarih bölümlerini ve sırasını seçin."

