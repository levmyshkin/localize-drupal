msgstr "@label (Kullanıcılar, özel e-posta adresleri, Yöneticiler)"

msgid ""
"If you enjoy and value Drupal and the Webform module consider <a "
"href=\":href_involved\">getting involved in the Drupal community</a>, "
"<a href=\":href_join\">joining the Drupal Association</a>, and <a "
"href=\":href_opencollective\">contributing funds to the Webform "
"module's Open Collective</a>."
msgstr ""
"Drupal ve Webform modülünden keyif alıyor ve değer veriyorsanız, "
"<a href=\":href_involved\">Drupal topluluğuna dahil olmayı</a>, <a "
"href=\":href_join\">Drupal Association’a katılmayı</a> ve <a "
"href=\":href_opencollective\">Webform modülünün Open "
"Collective’ine maddi katkıda bulunmayı</a> düşünebilirsiniz."

msgid "This behavior is not supported when Ajax is enabled."
msgstr "Ajax etkinleştirildiğinde bu davranış desteklenmez."

