msgid "MSApplication - Allow domain API calls"
msgstr "MSApplication - Alan adı API çağrılarına izin ver"

msgid "MSApplication - Allow domain meta tags"
msgstr "MSApplication - Alan adı meta etiketlerine izin ver"

