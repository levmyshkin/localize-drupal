msgstr "Otomatik ilerleme sırasında sonraki düğmesini gizle"

msgid "Default delete button label"
msgstr "Varsayılan silme düğmesi etiketi"

msgid ""
"Check if Webform Clientside Validation module is installed when using "
"the Clientside Validation module"
msgstr ""
"Clientside Validation modülünü kullanırken Webform Clientside "
"Validation modülünün yüklü olup olmadığını kontrol edin"

msgid "Webform: Clientside validation"
msgstr "Webform: İstemci tarafı doğrulama"

msgid "Webform Clientside Validation module installed."
msgstr "Webform Clientside Validation modülü kuruldu."

msgid "Webform Clientside Validation module not installed."
msgstr "Webform Clientside Validation modülü kurulu değil."

msgid ""
"The Webform Clientside Validation module helps support Webform "
"Clientside Validation integration. <a href=\":href\">Disable Webform "
"Clientside Validation warning</a>"
msgstr ""
"Webform Clientside Validation modülü, Webform Clientside Validation "
"entegrasyonunu desteklemeye yardımcı olur. <a href=\":href\">Webform "
"Clientside Validation uyarısını devre dışı bırakın</a>"

msgid "Helps support Webform Clientside Validation integration."
msgstr ""
"Webform İstemci Tarafı Doğrulama entegrasyonunu desteklemeye "
"yardımcı olur."

msgid "Show add element button"
msgstr "Öğe ekle düğmesini göster"

