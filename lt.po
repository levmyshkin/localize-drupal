msgstr "DOMPurify biblioteka"

msgid "DOMPurify is already present at @path. No download required."
msgstr "DOMPurify jau yra @path. Atsisiuntimas nereikalingas."

msgid ""
"Drush was unable to download the DOMPurify library from @remote. "
"@exception"
msgstr ""
"Drush nepavyko atsisiųsti DOMPurify bibliotekos iš @remote. "
"@exception"

