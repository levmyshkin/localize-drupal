msgstr "Pakeiskite failo pavadinimą jo aprašymu, jei jis yra prieinamas"

msgid "Use description as link text"
msgstr "Naudokite aprašymą kaip nuorodos tekstą"

msgid "Display the file using an HTML5 audio tag."
msgstr "Rodykite failą naudodami HTML5 audio žymę."

msgid "Playback controls: %controls"
msgstr "Atkūrimo valdikliai: %controls"

msgid "Multiple file display: Multiple HTML tags"
msgstr "Kelių failų rodymas: Keli HTML žymėjimai"

