msgid "The field name through which this comment was added."
msgstr "Lauko pavadinimas, per kurį buvo pridėtas šis komentaras."

msgid "Last comment ID"
msgstr "Paskutinio komentaro ID"

msgid "Last comment timestamp"
msgstr "Paskutinio komentaro laiko žyma"

msgid "The time that the last comment was created."
msgstr "Laikas, kada buvo sukurtas paskutinis komentaras."

msgid "Last comment name"
msgstr "Paskutinio komentaras vardas"

msgid "The name of the user posting the last comment."
msgstr "Vartotojo, paskelbusio paskutinį komentarą, vardas."

msgid "Last comment user ID"
msgstr "Paskutinio komentaro vartotojo ID"

msgid "The number of comments."
msgstr "Komentarų skaičius."

msgid ""
"This field manages configuration and presentation of comments on an "
"entity."
msgstr ""
"Šis laukas valdo komentarų konfigūraciją ir pateikimą apie "
"objektą."

msgid "Comment list"
msgstr "Komentarų sąrašas"

msgid ""
"Show the comment link in the form used on standard entity teasers, "
