msgstr "Priderinkite atnaujinimo mygtuko tekstą."

msgid "Generate new CAPTCHA image"
msgstr "Generuoti naują CAPTCHA vaizdą"

msgid ""
"Select the default <em>CAPTCHA Point</em> challenge type. This can be "
"overridden for each <em>CAPTCHA Point</em> individually."
msgstr ""
"Pasirinkite numatytąjį <em>CAPTCHA taško</em> iššūkio tipą. Jį "
"galima pakeisti kiekvienam <em>CAPTCHA taškui</em> atskirai."

msgid "Challenge title"
msgstr "Iššūkio pavadinimas"

