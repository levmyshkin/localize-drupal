msgstr "@lygis - žemas"

msgid "@level - medium"
msgstr "@lygis - vidutinis"

msgid "@level - high"
msgstr "@lygis - aukštas"

msgid "No TrueType support"
msgstr "Nėra TrueType palaikymo"

