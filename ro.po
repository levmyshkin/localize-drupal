msgstr "Completare automată cu mesajul trimiterii anterioare"

msgid "Autofill excluded elements"
msgstr "Elemente excluse de la completarea automată"

msgid "Display required indicator label"
msgstr "Afișează eticheta indicatorului obligatoriu"

msgid "Default submission locked message"
msgstr "Mesajul implicit pentru trimitere blocată"

msgid "Default submission autofill message"
msgstr "Mesaj implicit de completare automată a trimiterii"

msgid ""
"Elements contain a duplicate element key %name found on line "
"@line_numbers."
msgid_plural ""
"Elements contain a duplicate element key %name found on lines "
"@line_numbers."
msgstr[0] ""
"Elementele conțin o cheie de element duplicată %name găsită pe "
"linia @line_numbers.  \n"
"Elementele conțin o cheie de element "
"duplicată %name găsită pe liniile @line_numbers."

msgid "Generate %title submissions"
msgstr "Generează trimiteri %title"

msgid "If checked, this submissions will be starred when reviewing results."
msgstr ""
"Dacă este bifat, aceste trimiteri vor fi evidențiate cu o stea la "
"revizuirea rezultatelor."

msgid ""
"To customize only webform specific elements, you should use the "
"'.webform-submission-form' selector"
msgstr ""
"Pentru a personaliza doar elementele specifice webform-ului, ar trebui "
"să folosiți selectorul '.webform-submission-form'"

msgid "Required indicator is displayed on all forms."
msgstr "Indicatorul de câmp obligatoriu este afișat pe toate formularele."

msgid ""
"If checked, a required elements indicator will be added to this "
"webform."
msgstr ""
"Dacă este bifat, un indicator pentru elementele obligatorii va fi "
"adăugat acestui formular web."

msgid "Autofill with previous submission data"
msgstr "Autocompletare cu datele din trimiterea anterioară"

msgid "Autofill message"
msgstr "Mesaj de completare automată"

msgid ""
"A message to be displayed when form is autofilled with previous "
"submission data."
