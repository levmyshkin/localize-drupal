msgstr ""
"'@key' este o cheie necunoscută deoarece @dynamic_type_property_path "
"este @dynamic_type_property_value (vezi schema de configurare tip "
"@resolved_dynamic_type)."

msgid "'@key' is a required key."
msgstr "'@key' este o cheie obligatorie."

