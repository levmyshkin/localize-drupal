msgstr "Profilul de instalare '@profile_name' necesită '@module_name'"

msgid ""
"Ideal for exact counts and measures (prices, temperatures, distances, "
"volumes, etc.)"
msgstr ""
"Ideal pentru numărători și măsurători exacte (prețuri, "
"temperaturi, distanțe, volume etc.)"

