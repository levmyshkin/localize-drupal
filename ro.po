msgid "The configuration ignored in all cases"
msgstr "Configurația ignorată în toate cazurile"

msgid ""
"One configuration name per line.<br />\n"
"Examples: "
"<ul>\n"
"<li>user.settings</li>\n"
"<li>views.settings</li>\n"
"<li>contact.settings</li>\n"
"<li>webform.webform.* "
"(will ignore all config entities that starts with "
"<em>webform.webform</em>)</li>\n"
"<li>*.contact_message.custom_contact_form.* "
"(will ignore all config entities that starts with "
"<em>.contact_message.custom_contact_form.</em> like fields attached to "
"a custom contact form)</li>\n"
"<li>* (will ignore "
"everything)</li>\n"
"<li>~webform.webform.contact (will force import for "
"this configuration, even if ignored by a "
"wildcard)</li>\n"
"<li>user.mail:register_no_approval_required.body "
"(will ignore the body of the no approval required email setting, but "
"will not ignore other user.mail "
"configuration.)</li>\n"
"<li>language.*|* (will ignore all language "
"collections)</li>\n"
"<li>language.fr|* (will ignore all fr language "
"collection)</li>\n"
"<li>language.fr|field.field.* (will ignore all fr "
"field "
"translations)</li>\n"
"<li>~language.fr|field.field.media.file.field_media_file "
"(will force import for certain field "
"translation)</li>\n"
"<li>language.*|system.site:name (will ignore just "
"the site name but in all translations)</li>\n"
"</ul>"
msgstr ""
"Un nume de configurație pe linie.<br />\n"
"Exemple: "
"<ul>\n"
"<li>user.settings</li>\n"
"<li>views.settings</li>\n"
"<li>contact.settings</li>\n"
"<li>webform.webform.* "
"(va ignora toate entitățile de config care încep cu "
"<em>webform.webform</em>)</li>\n"
"<li>*.contact_message.custom_contact_form.* "
"(va ignora toate entitățile de config care încep cu "
"<em>.contact_message.custom_contact_form.</em>, cum ar fi câmpurile "
"atașate unui formular de contact personalizat)</li>\n"
"<li>* (va "
"ignora tot)</li>\n"
"<li>~webform.webform.contact (va forța importul "
"acestei configurații, chiar dacă este ignorată printr-un "
"wildcard)</li>\n"
"<li>user.mail:register_no_approval_required.body (va "
"ignora conținutul setării emailului fără necesitatea aprobării, "
"dar nu va ignora alte configurări user.mail)</li>\n"
"<li>language.*|* "
"(va ignora toate colecțiile de limbi)</li>\n"
"<li>language.fr|* (va "
"ignora toată colecția de limba "
"franceză)</li>\n"
"<li>language.fr|field.field.* (va ignora toate "
"traducerile câmpurilor pentru limba "
"franceză)</li>\n"
"<li>~language.fr|field.field.media.file.field_media_file "
"(va forța importul pentru o anumită traducere a "
"câmpului)</li>\n"
"<li>language.*|system.site:name (va ignora doar "
"numele site-ului, dar în toate traducerile)</li>\n"
"</ul>"

