msgstr "Unități de timp"

msgid "A worker for @queue queue suspended further processing of the queue."
msgstr ""
"Un lucrător pentru coada @queue a suspendat continuarea procesării "
"cozii."

msgid ""
"Updates failed for the entity type %entity_type, for %entity_ids. <a "
"href=\":url\">Check the logs</a>."
msgstr ""
"Actualizările au eșuat pentru tipul de entitate %entity_type, pentru "
"%entity_ids. <a href=\":url\">Verifică jurnalele</a>."

