msgstr ""
"Directorul activ nu este protejat de PHP-TUF, care este necesar pentru "
"a utiliza în siguranță Package Manager."

msgid "The <code>@plugin</code> plugin is not installed."
msgstr "Pluginul <code>@plugin</code> nu este instalat."

msgid ""
"@message See <a href=\":url\">the help page</a> for more information "
"on how to install the plugin."
msgstr ""
"@message Vezi <a href=\":url\">pagina de ajutor</a> pentru mai multe "
"informații despre cum să instalezi pluginul."

msgid "The <code>@plugin</code> plugin is not listed as an allowed plugin."
msgstr "Pluginul <code>@plugin</code> nu este listat ca un plugin permis."

msgid ""
"@message See <a href=\":url\">the help page</a> for more information "
"on how to configure the plugin."
msgstr ""
"@message Vezi <a href=\":url\">pagina de ajutor</a> pentru mai multe "
"informații despre cum să configurezi pluginul."

msgid ""
"@message See <a href=\":url\">the help page</a> for more information "
"on how to set up this repository."
msgstr ""
"@message Vezi <a href=\":url\">pagina de ajutor</a> pentru mai multe "
"informații despre cum să configurezi acest depozit."

msgid ""
"@message See the <a href=\":url\">Package Manager help</a> for more "
