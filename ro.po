msgstr "Un șablon de formular web de contact de bază."

msgid "An employee evaluation webform template."
msgstr "Un șablon de formular web pentru evaluarea angajaților."

msgid "An issue webform template."
msgstr "Un șablon de formular web pentru probleme."

msgid "A job application webform template."
msgstr "Un șablon de formular web pentru aplicații de angajare."

msgid "A job seeker profile webform template."
msgstr "Un șablon de formular web pentru profilul unui candidat."

msgid "A subscribe to mailing list webform template."
