msgstr "Valoarea introdusă %choice în elementul %name nu este permisă."

msgid ""
"The image toolkit '@toolkit' failed processing '@operation' for image "
"'@image'. Reported error: @class - @message"
msgstr ""
"Setul de unelte pentru imagini '@toolkit' a eșuat la procesarea "
"operațiunii '@operation' pentru imaginea '@image'. Eroarea "
"raportată: @class - @message"

