msgstr ""
"Oferă suport pentru definirea și gestionarea meta tag-urilor "
"personalizate."

msgid "Add Custom tag"
msgstr "Adaugă etichetă personalizată"

msgid "Administer Custom tags"
msgstr "Administrează etichetele personalizate"

msgid "Control the main settings pages and modify custom tags."
msgstr ""
"Controlează paginile principale de setări și modifică etichetele "
"personalizate."

msgid "Delete Custom tag"
msgstr "Șterge eticheta personalizată"

msgid "Specify the name of the custom tag."
msgstr "Specificați numele etichetei personalizate."

msgid "Specify the description of the Custom tag."
msgstr "Specificați descrierea etichetei personalizate."

msgid "Select the HTML element of the Custom tag."
msgstr "Selectați elementul HTML al etichetei personalizate."

msgid "Value attribute"
msgstr "Atributul value"

