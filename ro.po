msgstr "@start of @end"

msgid "Current card"
msgstr "Card curent"

msgid "The current card."
msgstr "Cardul curent."

msgid "Do you want to convert this webform's wizard pages to cards?"
msgstr ""
"Doriți să convertiți paginile expertului acestui formular web în "
"carduri?"

msgid "Form wizard/cards settings"
msgstr "Setări pentru asistentul de formulare/carduri"

