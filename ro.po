msgstr "<a href=\":href\">Dezactivează avertizarea CDN</a>"

msgid ""
"@total libraries (@installed installed; @excluded excluded; @missing "
"CDN)"
msgstr ""
"@total biblioteci (@installed instalate; @excluded excluse; @missing "
"CDN)"

msgid "Drupal Association"
msgstr "Asociația Drupal"

msgid ""
"The below requirements are checked by the <a href=\":href\">Status "
"report</a>."
msgstr ""
"Următoarele cerințe sunt verificate de <a href=\":href\">Raportul de "
"stare</a>."

msgid ""
"If unchecked, all warnings about Webform SPAM protection will be "
"disabled."
msgstr ""
"Dacă nu este bifat, toate avertismentele legate de protecția SPAM "
"pentru Webform vor fi dezactivate."

msgid "Check that all entered values for this element are unique."
msgstr ""
"Verifică dacă toate valorile introduse pentru acest element sunt "
"unice."

