msgid "Webform Cards"
msgstr "Tarjetas de Webform"

msgid ""
"Provides a 'Card' container element for fast clientside multistep form "
"pagination."
msgstr ""
"Proporciona un elemento contenedor “Card” para la paginación "
"rápida en el lado del cliente de formularios de varios pasos."

