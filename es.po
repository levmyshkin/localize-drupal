msgstr "Este screencast muestra cómo abrir webforms en diálogos modales."

msgid "Creating a modal in Drupal 8 | Befused"
msgstr "Crear un modal en Drupal 8 | Befused"

msgid "Display forms in a modal dialog with Drupal 8 | Agaric"
msgstr ""
"Mostrar formularios en un cuadro de diálogo modal con Drupal 8 | "
"Agaric"

