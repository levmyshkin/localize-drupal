msgid "Event date/time"
msgstr "Fecha/hora del evento"

msgid "Maximum number of registrants"
msgstr "Número máximo de inscritos"

msgid "Demo: Event Registration"
msgstr "Demo: Registro de eventos"

msgid "A demonstration of an event registration form."
msgstr "Una demostración de un formulario de registro a un evento."

msgid "Demo: Region Contact"
msgstr "Demo: Región de contacto"

msgid "A demonstration of a region based contact form."
msgstr "Una demostración de un formulario de contacto basado en regiones."

msgid "Employee: Email"
msgstr "Empleado: Correo electrónico"

