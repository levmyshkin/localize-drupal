msgstr "tipo de mapa del sitio"

msgid "sitemap types"
msgstr "tipos de mapa del sitio"

msgid ""
"At least one sitemap needs to be defined for a bundle to be "
"indexable.<br>Sitemaps can be configured <a href=\"@url\">here</a>."
msgstr ""
"Es necesario definir al menos un sitemap para que un bundle sea "
"indexable.<br>Los sitemaps se pueden configurar <a "
"href=\"@url\">aquí</a>."

msgid "Sitemap type %label has been updated."
msgstr "Se ha actualizado el tipo de mapa del sitio %label."

