msgstr "Permite programar el envío de correos electrónicos de Webform."

msgid "Handler @id is not a scheduled email handler."
msgstr "El manejador @id no es un manejador de correo electrónico programado."

msgid "Webform Scheduled Email Handler"
msgstr "Manejador de correos electrónicos programados de Webform"

msgid "scheduled"
msgstr "programado"

msgid "Scheduled email @action for @handler handler."
msgstr "Correo electrónico programado @action para el manejador @handler."

msgid "queued to be sent."
msgstr "en cola para ser enviado."

msgid "Scheduled email status (@total)"
msgstr "Estado del correo electrónico programado (@total)"

msgid ""
"It is strongly recommended that <a href=\":href\">submission "
