msgstr "Elija la acción a realizar."

msgid ""
"Invalid action argument \"@invalid_action\". Please use one of: "
"@valid_actions"
msgstr ""
"Argumento de acción no válido \"@invalid_action\". Utilice uno de "
"los siguientes: @valid_actions"

