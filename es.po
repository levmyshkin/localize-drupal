"Do not index entities of type <em>@bundle</em> in sitemap "
"<em>@sitemap</em>"
msgstr ""
"No indexar entidades del tipo <em>@bundle</em> en el sitemap "
"<em>@sitemap</em>"

msgid "Index entities of type <em>@bundle</em> in sitemap <em>@sitemap</em>"
msgstr ""
"Indexar entidades del tipo <em>@bundle</em> en el mapa del sitio "
"<em>@sitemap</em>"

msgid "Do not index this <em>@bundle</em> entity in sitemap <em>@sitemap</em>"
msgstr ""
"No indexar esta entidad <em>@bundle</em> en el mapa del sitio "
"<em>@sitemap</em>"

msgid "Index this <em>@bundle</em> entity in sitemap <em>@sitemap</em>"
msgstr ""
"Indexar esta entidad <em>@bundle</em> en el mapa del sitio "
"<em>@sitemap</em>"

msgid "Do not index entities of this type in sitemap <em>@sitemap</em>"
msgstr ""
"No indexar entidades de este tipo en el mapa del sitio "
"<em>@sitemap</em>"

msgid "Index entities of this type in sitemap <em>@sitemap</em>"
msgstr ""
"Indexar las entidades de este tipo en el mapa del sitio "
"<em>@sitemap</em>"

msgid "Generates an index of your sitemaps."
msgstr "Genera un índice de tus sitemaps."

msgid "Sitemap URL generator"
msgstr "Generador de URL del mapa del sitio"

msgid "Generates sitemap URLs for a sitemap index."
msgstr "Genera las URL del mapa del sitio para un índice de mapas del sitio."

msgid "Hide branding"
msgstr "Ocultar la marca"

msgid ""
"Remove the 'Generated by the Simple XML Sitemap Drupal module' string "
"from the XSL output."
msgstr ""
"Eliminar la cadena “Generated by the Simple XML Sitemap Drupal "
"module” de la salida XSL."

msgid "Generated by the <a href=\"@url\">@module_name</a> Drupal module."
msgstr "Generado por el módulo de Drupal <a href=\"@url\">@module_name</a>."

msgid "Add custom internal drupal paths to specific sitemaps."
msgstr ""
"Añade rutas internas personalizadas de Drupal a sitemaps "
"específicos."

msgid ""
"Specify drupal internal (relative) paths, one per line. Do not forget "
"to prepend the paths with a '/'.<br>Optionally link priority <em>(0.0 "
"- 1.0)</em> can be added by appending it after a space.<br> Optionally "
"link change frequency <em>(always / hourly / daily / weekly / monthly "
"/ yearly / never)</em> can be added by appending it after a space."
msgstr ""
"Especifique las rutas internas (relativas) de Drupal, una por línea. "
"No olvide anteponer un «/» a las rutas.<br>De forma opcional, se "
"puede añadir la prioridad del enlace <em>(0.0 - 1.0)</em> "
"agregándola al final, después de un espacio.<br>De forma opcional, "
"se puede añadir la frecuencia de cambio del enlace <em>(always / "
"hourly / daily / weekly / monthly / yearly / never)</em> agregándola "
"al final, después de un espacio."

msgid ""
"<strong>Examples:</strong><br><em>/ 1.0 daily</em> -> home page with "
"the highest priority and daily change frequency<br><em>/contact</em> "
"-> contact page with the default priority and no change frequency "
"information"
msgstr ""
"<strong>Ejemplos:</strong><br><em>/ 1.0 daily</em> -> página de "
"inicio con la prioridad más alta y frecuencia de cambio "
"diaria<br><em>/contact</em> -> página de contacto con la prioridad "
"predeterminada y sin información sobre la frecuencia de cambio"

msgid ""
"<strong>@sitemap, line @line</strong>: The path <em>@path</em> does "
"not exist."
msgstr ""
"<strong>@sitemap, línea @line</strong>: La ruta <em>@path</em> no "
"existe."

msgid ""
"<strong>@sitemap, line @line</strong>: The path <em>@path</em> needs "
"to start with a '/'."
msgstr ""
"<strong>@sitemap, line @line</strong>: La ruta <em>@path</em> debe "
"comenzar con un '/'."

msgid ""
"<strong>@sitemap, line @line</strong>: The priority setting "
"<em>@priority</em> for path <em>@path</em> is incorrect. Set the "
"priority from 0.0 to 1.0."
msgstr ""
"<strong>@sitemap, line @line</strong>: La configuración de prioridad "
"<em>@priority</em> para la ruta <em>@path</em> es incorrecta. "
"Establece la prioridad entre 0.0 y 1.0."

msgid ""
"<strong>@sitemap, line @line</strong>: The changefreq setting "
"<em>@changefreq</em> for path <em>@path</em> is incorrect. The "
"following are the correct values: <em>@changefreq_options</em>."
msgstr ""
"<strong>@sitemap, line @line</strong>: La configuración changefreq "
"<em>@changefreq</em> para la ruta <em>@path</em> es incorrecta. Los "
"siguientes son los valores correctos: <em>@changefreq_options</em>."

