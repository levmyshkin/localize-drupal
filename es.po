msgstr "Guardar + Añadir elemento"

msgid "Webform access controls"
msgstr "Controles de acceso de Webform"

msgid "Access Control | Tag1 Consulting"
msgstr "Control de acceso | Tag1 Consulting"

msgid "Opening webforms in modal dialogs"
msgstr "Abrir formularios web en diálogos modales"

