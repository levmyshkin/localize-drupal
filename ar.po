msgstr ""
"هل تريد الإرفاق قبل عرض العنصر الأب أم "
"بعده؟"

msgid "Select which display or displays this should attach to."
msgstr ""
"حدِّد العرض أو العروض التي يجب إرفاق "
"هذا بها."

