msgstr "إعادة توجيه النطاق"

msgid "Allows users to redirect between domains."
msgstr ""
"يتيح للمستخدمين إعادة التوجيه بين "
"النطاقات."

msgid "Redirect domains"
msgstr "إعادة توجيه النطاقات"

