msgid ""
"The priority entities of this type will have in the eyes of search "
"engine bots."
msgstr ""
"ستحظى الكيانات ذات الأولوية من هذا "
"النوع بمكانة أعلى في نظر روبوتات "
"محركات البحث."

msgid "Settings for this entity can be overridden here."
msgstr "يمكن تجاوز إعدادات هذا الكيان هنا."

msgid "Skip untranslated"
msgstr "تخطي غير المترجم"

msgid "Entity bundle settings"
msgstr "إعدادات حزمة الكيان"

