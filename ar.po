"Delete revisions of entities that are no longer used in Entity "
"Reference Revisions fields."
msgstr ""
"حذف مراجعات الكيانات التي لم تعد "
"مستخدمة في حقول **Entity Reference Revisions**."

msgid "Delete orphan revisions"
msgstr "حذف المراجعات اليتيمة"

msgid "Removing orphaned entities."
msgstr "إزالة الكيانات اليتيمة."

msgid ""
"@label: Deleted @revision_count revisions (@entity_count entities) in "
"@interval."
msgstr ""
"@label: تم حذف @revision_count من المراجعات "
"(@entity_count من الكيانات) خلال @interval."

msgid ""
"The submission of the current form can cause the deletion of entities "
"that are still used, backup all data first."
msgstr ""
"قد يؤدي إرسال النموذج الحالي إلى حذف "
"كيانات لا تزال قيد الاستخدام. يُرجى "
"عمل نسخة احتياطية من جميع البيانات "
"أولًا."

msgid "Delete orphaned composite revisions"
msgstr "حذف مراجعات المركّبات اليتيمة"

msgid "Choose the entity type to clear"
msgstr "اختر نوع الكيان لمسحه"

msgid "Group name"
msgstr "اسم المجموعة"

msgid "Attributes"
msgstr "سمات"

msgid "Clone"
msgstr "استنساخ"

msgid "Tab"
msgstr "علامة تبويب"

msgid "Default state"
msgstr "الحالة الافتراضية"

msgid "Collapsible"
msgstr "قابل للطي"

msgid "Slow"
msgstr "بطيء"

msgid "Fast"
msgstr "سريع"

msgid "Speed"
msgstr "السرعة"

