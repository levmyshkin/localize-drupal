msgstr "إنشاء محتوى"

msgid "Configuration files"
msgstr "ملفات الإعدادات"

msgid "Default moderation state"
msgstr "حالة الإشراف الافتراضية"

msgid "Theme files"
msgstr "ملفات القالب"

