msgid "Default file upload limit per form"
msgstr ""
"الحدّ الافتراضي لرفع الملفات لكل "
"نموذج"

msgid "Invoked @id: @class_name:@method_name @context1"
msgstr "تم استدعاء @id: ‏@class_name:@method_name ‏@context1"

msgid "Example of a webform submission handler."
msgstr "مثال على معالج عمليات إرسال نموذج ويب."

msgid ""
"Inline (Displays message when access is denied to field, nodes, and "
"blocks)"
msgstr ""
"مضمَّن (يعرض رسالة عند رفض الوصول إلى "
"الحقل، والعُقَد، والكتل)"

msgid ""
"Page (Displays message when access is denied to forms, fields, nodes, "
"and blocks)"
msgstr ""
"الصفحة (تعرض رسالة عند رفض الوصول إلى "
"النماذج والحقول والعُقَد والكتل)"

msgid ""
"Login (Redirects to user login form and displays message. Field, "
"nodes, and block only display the message.)"
msgstr ""
"تسجيل الدخول (يعيد التوجيه إلى نموذج "
"تسجيل دخول المستخدم ويعرض رسالة. في "
"حالة الحقل والعُقد والكتلة، يتم عرض "
"الرسالة فقط.)"

msgid ""
"When this container is hidden all this container's subelement values "
"will be cleared."
msgstr ""
"عند إخفاء هذا الحاوي، سيتم مسح جميع "
"قيم العناصر الفرعية الخاصة به."

msgid "When this element is hidden, this element's value will be cleared."
msgstr ""
"عند إخفاء هذا العنصر، سيتم مسح قيمة "
"هذا العنصر."

msgid "Input hiding"
msgstr "إخفاء حقل الإدخال"

msgid "Hide the input of the element when the input is not being focused."
msgstr ""
"إخفاء حقل الإدخال الخاص بالعنصر عندما "
"لا يكون حقل الإدخال في حالة تركيز."

msgid "Append the below suffixes to alter the returned value."
msgstr ""
"أضِف اللواحق أدناه لتغيير القيمة "
"المُعادة."

msgid "<code>:urlencode</code> URL encodes returned value."
msgstr ""
"<code>:urlencode</code> يشفّر القيمة المُعادة "
"ترميزًا مناسبًا لعناوين URL."

msgid "Submission exclude empty elements"
msgstr "استبعاد العناصر الفارغة عند الإرسال"

msgid "Submission exclude unselected checkboxes"
msgstr ""
"استبعاد الخيارات غير المحددة من "
"الإرسال"

msgid "@source_entity: @webform"
msgstr "@source_entity: @webform"

msgid ""
"Select how the form's title is displayed when this webform is attached "
"to a source entity. This title is only displayed when a webform is "
"linked to from a source entity or opened in dialog."
msgstr ""
"حدّد كيفية عرض عنوان النموذج عند إرفاق "
"هذا النموذج الإلكتروني بكيانٍ مصدر. لا "
"يُعرض هذا العنوان إلا عندما يكون "
"النموذج الإلكتروني مرتبطًا من كيانٍ "
"مصدر أو يتم فتحه ضمن مربع حوار."

msgid "Source entity: Webform"
msgstr "الكيان المصدر: نموذج ويب"

msgid "Webform: Source entity"
msgstr "Webform: الكيان المصدر"

msgid "Included submission values"
msgstr "قيم الإرسال المضمَّنة"

msgid ""
"If you wish to include only parts of the submission when viewing as "
"HTML, table, or plain text, select the elements that should be "
"included. Please note, element specific access controls are still "
"applied to displayed elements."
msgstr ""
"إذا كنت ترغب في تضمين أجزاء فقط من "
"الإرسال عند عرضه بصيغة HTML أو كجدول أو "
"كنص عادي، فحدّد العناصر التي ينبغي "
"تضمينها. يُرجى ملاحظة أنّ ضوابط الوصول "
"الخاصة بكل عنصر لا تزال تُطبَّق على "
"العناصر المعروضة."

msgid "If checked, an add more input will be added below the multiple values."
msgstr ""
"إذا تم تحديده، سيتم إضافة حقل إدخال "
"«إضافة المزيد» أسفل القيم المتعددة."

msgid "Wrapper type and attributes"
msgstr "نوع الغلاف وسماته"

msgid "Wraps inputs in a fieldset."
msgstr "يُغلِّف حقول الإدخال داخل عنصر fieldset."

msgid "Wraps inputs in a basic form element with title and description."
msgstr ""
"يلفّ حقول الإدخال داخل عنصر نموذج "
"أساسي يتضمن عنوانًا ووصفًا."

msgid "Wraps inputs in a basic div with no title or description."
msgstr ""
"يلفّ حقول الإدخال داخل عنصر div بسيط دون "
"عنوان أو وصف."

msgid ""
"Use this paragraph field's main entity as the webform submission's "
"source entity."
msgstr ""
"استخدم الكيان الرئيسي لحقل الفقرة هذا "
"ككيان مصدر لإرسالات الويبفورم."

msgid ""
"If unchecked, the current page's entity will be used as the webform "
"submission's source entity."
msgstr ""
"إذا لم يتم تحديده، فسيتم استخدام كيان "
"الصفحة الحالية ككيان المصدر لإرسال "
"نموذج الويب."

msgid ""
"This paragraph field's main entity will be used as the webform "
"submission's source entity."
msgstr ""
"سيُستخدم الكيان الرئيسي لحقل الفقرة "
"هذا بوصفه الكيانَ المصدر لإرسال نموذج "
"الويب (Webform)."

msgid ""
"If set, this message will be used when a pattern is not matched, "
"instead of the default \"@message\" message."
msgstr ""
"إذا تم ضبطه، فسيتم استخدام هذه الرسالة "
"عندما لا يتطابق النمط، بدلاً من "
"الرسالة الافتراضية \"@message\"."

msgid "@title minimum message"
msgstr "الحد الأدنى لرسالة @title"

msgid "@title maximum message"
msgstr "الحد الأقصى لعدد الرسائل في @title"

msgid "Limit user to one submission per source entity"
msgstr ""
"قصر المستخدم على إرسال واحد لكل كيان "
"مصدر"

msgid "Advanced Webforms"
msgstr "نماذج ويب متقدمة"

msgid ""
"This presentation gives you the extra knowledge you need to get the "
"most out the Webform module."
msgstr ""
"يمنحك هذا العرض التقديمي المعرفة "
"الإضافية التي تحتاجها لتحقيق أقصى "
"استفادة من وحدة Webform."

msgid "Allow users to update a submission using a secure token"
msgstr ""
"السماح للمستخدمين بتحديث الإرسال "
"باستخدام رمز مميّز آمن"

msgid "Limit total to one submission per webform/source entity"
msgstr ""
"اقتصر إجمالي عدد الإرسالات على إرسال "
"واحد لكل نموذج ويب/كيان مصدر"

msgid ""
"Only submission administrators will only be able to create and update "
"the unique submission."
msgstr ""
"لن يتمكّن من إنشاء وتحديث الإرسال "
"الفريد إلا مسؤولو الإرسالات."

msgid ""
"Webform blocks can be used to place this webform on the desired source "
"entity types."
msgstr ""
"يمكن استخدام كتل Webform لوضع هذا النموذج "
"في أنواع الكيانات المصدر المطلوبة."

msgid "Limit users to one submission per webform/source entity"
msgstr ""
"حصر المستخدمين في إرسال واحد فقط لكل "
"نموذج ويب/كيان مصدر"

msgid ""
"Only authenticated users will be able to create and update their "
"unique submission."
msgstr ""
"لن يتمكّن سوى المستخدمين المصادق "
"عليهم من إنشاء وتحديث إرسالهم الفريد."

msgid ""
"<strong>Warning</strong>: The below settings give users, permissions, "
"and roles full access to this webform's configuration via API "
"requests."
msgstr ""
"<strong>تحذير</strong>: تمنح الإعدادات أدناه "
"المستخدمين والأذونات والأدوار صلاحية "
"وصول كاملة إلى إعدادات هذا النموذج "
"الإلكتروني (Webform) عبر طلبات واجهة برمجة "
"التطبيقات (API)."

msgid "Affect any elements which use these images"
msgstr "تؤثّر على أي عناصر تستخدم هذه الصور"

msgid "%label is used by the below webform(s)."
msgstr ""
"يُستخدَم %label بواسطة نموذج/نماذج الويب "
"التالية."

msgid "Delete all related submissions"
msgstr "حذف جميع الإرساليات ذات الصلة"

msgid "Affect any fields or nodes which reference this webform"
msgstr ""
"التأثير على أي حقول أو عُقَد تشير إلى "
"نموذج الويب هذا"

