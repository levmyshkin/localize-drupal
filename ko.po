msgstr "가시성 표현식입니다."

msgid "Pages list."
msgstr "페이지 목록입니다."

msgid "Cache rule."
msgstr "캐시 규칙입니다."

msgid "The numeric identifier of the block/box"
msgstr "블록/상자에 대한 숫자 ID입니다."

msgid "The block/box content"
msgstr "블록/상자 컨텐츠"

