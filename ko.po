msgstr ""
"이제 다른 모든 사이트맵을 나열하는 사이트맵 "
"인덱스를 사용할 수 있으며 활성화할 수 있습니다."

msgid "IndexNow notification"
msgstr "IndexNow 알림"

msgid "IndexNow notification checkbox"
msgstr "IndexNow 알림 확인란"

msgid "Remove verification key from state"
msgstr "상태에서 인증 키 제거"

