msgid "Action ID"
msgstr "조치 ID"

msgid "Action configuration"
msgstr "액션 설정"

msgid "Action description"
msgstr "조치 설명"

msgid "The block numeric identifier."
msgstr "블록 숫자 ID입니다."

msgid "The module providing the block."
msgstr "블록을 제공하는 모듈입니다."

msgid "The block's delta."
msgstr "블록의 델타입니다."

