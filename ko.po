msgstr ""
"<a href=\":href\">이 개별 요소 삭제</a> 웹폼 UI를 "
"사용하여 삭제합니다."

msgid ""
"If unchecked, this webform must be attached to a <a "
"href=\":node_href\">node</a> or a <a href=\":block_href\">block</a> to "
"receive submissions."
msgstr ""
"선택하지 않으면 이 웹폼을 <a href=\":node_href\">노드</a> "
"또는 <a href=\":block_href\">블록</a>에 첨부해야 제출물을 "
"받을 수 있습니다."

msgid "Webform URL alias"
msgstr "웹 양식 URL 별칭"

msgid "Webform status"
msgstr "웹 양식 상태"

msgid "Disable back button for all webforms"
msgstr "모든 웹 양식에서 뒤로 가기 버튼 비활성화"

