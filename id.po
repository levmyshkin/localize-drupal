msgstr ""
"Tag-tag ini bukan bagian dari Metadata Element Set, tetapi dapat "
"berguna untuk skenario tertentu."

msgid "Accrual Method"
msgstr "Metode Akrual"

msgid "Accrual Periodicity"
msgstr "Periodisitas Akrual"

