msgstr ""
"'@key' adalah kunci yang tidak dikenal karena "
"@dynamic_type_property_path bernilai @dynamic_type_property_value "
"(lihat tipe skema konfigurasi @resolved_dynamic_type)."

msgid "'@key' is a required key."
msgstr "'@key' adalah kunci yang wajib diisi."

