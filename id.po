msgstr ""
"Menyediakan tag meta tambahan Open Graph Protocol untuk "
"mendeskripsikan produk."

msgid "Undefined group '%group' on tag '%tag'"
msgstr "Grup '%group' tidak terdefinisi pada tag '%tag'"

msgid ""
