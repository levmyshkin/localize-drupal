msgid ""
"<strong>ATTENTION DEVELOPERS!!!</strong> The webform submission form's "
" BASE_FORM_ID and FORM_ID have changed."
msgstr ""
"<strong>PERHATIAN PARA PENGEMBANG!!!</strong> BASE_FORM_ID dan FORM_ID "
"pada formulir pengiriman webform telah berubah."

msgid ""
"Please make sure to update all webform related "
"<code>hook_form_BASE_FORM_ID_alter()</code> and "
"<code>hook_form_FORM_ID_alter()</code> hooks."
msgstr ""
"Pastikan untuk memperbarui semua hook "
"<code>hook_form_BASE_FORM_ID_alter()</code> dan "
"<code>hook_form_FORM_ID_alter()</code> yang terkait dengan webform."

