msgstr ""
"Jika dicentang, peristiwa akan dicatat dalam log untuk setiap "
"pengiriman ke webform ini."

msgid "Webform submissions store passwords as plain text."
msgstr "Pengiriman Webform menyimpan kata sandi dalam teks biasa."

