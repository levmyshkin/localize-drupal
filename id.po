msgstr ""
"Sekumpulan tag meta khusus untuk mengontrol ringkasan yang ditampilkan "
"saat konten dibagikan di <a href='https://twitter.com/'>Twitter</a>."

msgid "Custom Tag"
msgstr "Tag Kustom"

msgid "Custom tag"
msgstr "Tag kustom"

msgid "Alternative language links (hreflang)"
msgstr "Tautan bahasa alternatif (hreflang)"

