msgstr "Lietotāju kontu izveides un dzēšanas konfigurēšana"

msgid "Modifying or deleting a user account"
msgstr "Lietotāja konta modificēšana vai dzēšana"

msgid "Module Link"
msgstr "Moduļa saite"

msgid "Mobile menu all widths"
msgstr "Mobilā izvēlne visos platumos"

