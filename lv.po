msgstr "@level - augsts"

msgid "No TrueType support"
msgstr "Nav TrueType atbalsta"

msgid ""
"The Image CAPTCHA module can not use TrueType fonts because your PHP "
"setup does not support it. You can only use a PHP built-in bitmap font "
"of fixed size."
msgstr ""
"Attēla CAPTCHA modulis nevar izmantot TrueType fontus, jo jūsu PHP "
"iestatījumi tos neatbalsta. Jūs varat izmantot tikai PHP iebūvēto "
