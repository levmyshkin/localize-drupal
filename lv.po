msgstr "CAPTCHA: \"@type\" izaicinājums iespējots"

msgid "CAPTCHA: no challenge enabled"
msgstr "CAPTCHA: izaicinājums nav aktivizēts"

msgid "Test one two three"
msgstr "Tests viens divi trīs"

msgid "Already 1 blocked form submission"
msgid_plural "Already @count blocked form submissions"
msgstr[0] ""
"Jau bloķēta 1 formas iesniegšana  \n"
"Jau bloķētas @count formas "
"iesniegšanas"

msgid "Presolved image CAPTCHA example, generated with the current settings."
msgstr ""
"Iepriekš atrisināts attēla CAPTCHA piemērs, ģenerēts ar "
"pašreizējiem iestatījumiem."

msgid "extra large"
msgstr "ļoti liels"

msgid "tight"
msgstr "šaurš"

msgid "wide"
msgstr "plata"

msgid "extra wide"
msgstr "Īpaši plats"

msgid ""
"The built-in font only supports Latin2 characters. Only use \"a\" to "
