msgstr "Moduļa instalēšana"

msgid "Uninstalling a module"
msgstr "Moduļa atinstalēšana"

msgid "Running reports on your site"
msgstr "Pārskatu izpilde jūsu vietnē"

msgid "Installing a theme and setting default themes"
msgstr "Tēmas instalēšana un noklusējuma tēmu iestatīšana"

