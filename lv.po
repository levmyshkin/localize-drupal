msgstr ""
"Nodrošina veidlapas elementu video faila augšupielādei un "
"saglabāšanai."

msgid "Disable system tray"
msgstr "Atspējot sistēmas trauku"

msgid "Display elements in table columns"
msgstr "Rādīt elementus tabulas slejās"

msgid ""
"If checked, the <a href=\":href\">autocomplete</a> attribute will be "
