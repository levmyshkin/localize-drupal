msgstr ""
"Pieņem jebkuru datumu jebkurā <a "
"href=\"https://www.gnu.org/software/tar/manual/html_chapter/tar_7.html#Date-input-formats\">GNU "
"datuma/laika ievades formātā</a>. Derīgas ir virknes, piemēram, "
"today, +2 months un Dec 9 2004 10:00 PM."

msgid "Date/time maximum"
msgstr "Maksimālais datums/laiks"

msgid "Specifies the maximum date/time."
msgstr "Norāda maksimālo datumu/laiku."

msgid "Other maximum"
msgstr "Cits maksimums"

