msgstr ""
"%user tagad izmanto jaunu īsceļu komplektu, kas saucas %set_name. To "
"varat rediģēt no šīs lapas."

msgid "You are now using the %set_name shortcut set."
msgstr "Jūs tagad izmantojat īsinājumtaustiņu komplektu %set_name."

