msgstr ""
"Nodrošina formas elementu vienas vai vairāku terminu izvēlei, kas "
"tiek attēloti kā hierarhisks koks vai kā sīkmaiņu navigācija, "
"izmantojot izvēles izvēlni."

msgid "Demo: Application Evaluation"
msgstr "Demo: Lietotnes novērtēšana"

msgid "Limit term depth"
msgstr "Ierobežot termiņa dziļumu"

msgid "Default submission logging"
msgstr "Noklusējuma iesniegumu reģistrēšana"

