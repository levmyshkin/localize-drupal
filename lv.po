msgstr ""
"Piemērot klases elementa attēlošanas iepakojumam. Izvēlieties "
"'custom…', lai ievadītu pielāgotas klases."

msgid "Apply custom styles to the element's display wrapper."
msgstr "Pielietot pielāgotus stilus elementa attēlošanas ietvaram."

msgid ""
"Enter additional attributes to be added to the element's display "
"wrapper."
msgstr ""
"Ievadiet papildu atribūtus, kas tiks pievienoti elementa "
"attēlošanas ietvaram."

msgid "Vehicle identification number (VIN)"
msgstr "Transportlīdzekļa identifikācijas numurs (VIN)"

msgid "No error response messages entered. Please add messages below."
msgstr ""
"Nav ievadītas kļūdu atbildes ziņas. Lūdzu, pievienojiet ziņas "
"zemāk."

msgid "<strong>@title</strong> (Installed)"
msgstr "<strong>@title</strong> (Uzstādīts)"

msgid ""
"The <a href=\":homepage_href\">@title</a> library is installed by the "
"<b><a href=\":module_href\">@module</a></b> module."
msgstr ""
"<a href=\":homepage_href\">@title</a> bibliotēku instalē <b><a "
