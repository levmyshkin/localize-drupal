msgstr ""
"Iebūvētā fonta atbalsts ir tikai Latin2 rakstzīmēm. Izmantojiet "
"tikai \"a\" līdz \"z\" un ciparus."

msgid ""
"CAPTCHA validation error: unknown CAPTCHA session ID. Contact the site "
