msgid "Convert anonymous drafts and submissions to authenticated"
msgstr "Pārvērst anonīmus melnrakstus un iesniegumus par autentificētiem"

msgid "Submission exception message"
msgstr "Iesniegšanas izņēmuma ziņojums"

