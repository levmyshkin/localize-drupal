msgid "A job seeker profile webform template."
msgstr "Darba meklētāja profila tīmekļa veidnes paraugs."

msgid "A subscribe to mailing list webform template."
msgstr "Tēma e-pasta saraksta abonēšanai webformai."

msgid "A user profile webform template."
msgstr "Lietotāja profila tīmekļa veidlapas veidne."

