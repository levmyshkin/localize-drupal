msgstr ""
"Navigationsmodulet giver en venstrejusteret, sammenklappelig, lodret "
"sidebar-navigation."

msgid ""
"For more information, see the <a href=\":docs\">online documentation "
"for the Navigation module</a>."
msgstr ""
"Du kan få flere oplysninger i <a href=\":docs\">onlinedokumentationen "
"for navigationsmodulet</a>."

