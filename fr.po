msgstr "Limite de l'entité Intervalle total"

msgid "Entity limit user interval"
msgstr "Limite de l'entité Intervalle de l'utilisateur"

msgid "Webform select display format settings"
msgstr "Webform sélectionner les paramètres du format d'affichage"

msgid "Default submission exception message"
msgstr "Message d'exception de soumission par défaut"

msgid "Promotions: Drupal Association"
msgstr "Promotions : Association Drupal"

