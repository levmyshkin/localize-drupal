msgstr ""
"Génère les URLs définies dans "
"admin/config/search/simplesitemap/custom."

msgid "Menu link URL generator"
msgstr "Générateur d'URL de lien de menu"

msgid "Generates menu link URLs by overriding the 'entity' URL generator."
msgstr ""
"Génère les URL des liens de menu en remplaçant le générateur "
"d'URL \"entité\"."

msgid "Entity URL generator"
msgstr "Générateur d'URL d'entités"

msgid "Generates URLs for entity bundles and bundle overrides."
msgstr ""
"Génère des URLs pour les bundles d'entités et les surcharges de "
"bundles."

