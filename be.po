msgid ""
"<strong>ATTENTION DEVELOPERS!!!</strong> The webform submission form's "
" BASE_FORM_ID and FORM_ID have changed."
msgstr ""
"<strong>УВАГА, РАЗРАБОТЧЫКІ!!!</strong> BASE_FORM_ID "
"і FORM_ID формы адпраўкі вэб-форы былі "
"зменены."

msgid ""
"Please make sure to update all webform related "
"<code>hook_form_BASE_FORM_ID_alter()</code> and "
"<code>hook_form_FORM_ID_alter()</code> hooks."
msgstr ""
"Будзьце ласкавы, пераканайцеся, што "
"абнавілі ўсе звязаныя з вэб-формамі "
"<code>hook_form_BASE_FORM_ID_alter()</code> і "
"<code>hook_form_FORM_ID_alter()</code> хукі."

