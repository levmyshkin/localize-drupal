msgstr "Паказаны @start - @end з @total"

msgid "Needs to be updated"
msgstr "Патрабуецца абнаўленне"

msgid "Does not need to be updated"
msgstr "Не патрабуе абнаўлення"

msgid "Edit comment @subject"
msgstr "Рэдагаваць каментар @subject"

