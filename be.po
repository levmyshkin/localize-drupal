msgid "User's roles"
msgstr "Ролі карыстальнікаў"

msgid "Single name"
msgstr "Адзінкавае імя"

msgid "If none are selected, all are allowed."
msgstr ""
"Калі ніводны не выбраны, дазваляюцца "
