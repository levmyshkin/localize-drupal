msgstr "Тып старонкі майстра"

msgid "Wizard page title tag"
msgstr "Тэг загалоўка старонкі майстра"

msgid "Default enable page"
msgstr "Уключыць старонку па змаўчанні"

msgid "email scheduled"
msgstr "электронная пошта запланавана"

msgid "email rescheduled"
msgstr "email перапланаваны"

msgid "email unscheduled"
msgstr "электронная пошта не запланавана"

msgid "skipped (disabled)"
msgstr "прапушчана (адключана)"

msgid "scheduled email disabled"
msgstr ""
"запланаваны электронны ліст "
"адключаны"

msgid "scheduled email skipped"
msgstr ""
"запланаваны электронны ліст "
"прапушчаны"

