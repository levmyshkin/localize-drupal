msgid ""
"Submission import completed. (total: @total; created: @created; "
"updated: @updated; skipped: @skipped)"
msgstr ""
"Імпарт адпраўленняў завершаны. "
"(агульная колькасць: @total; створана: "
"@created; абноўлена: @updated; прапушчана: "
"@skipped)"

msgid "Webform module now supports importing submissions | Drupal.org"
msgstr ""
"Модуль Webform цяпер падтрымлівае імпарт "
"адпраўленых форм | Drupal.org"

