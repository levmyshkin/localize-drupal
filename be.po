msgstr ""
"Гэта налада перапісваецца <a "
"href=\":editUrl\">бягучым карыстальнікам</a>. "
"@title: %value"

msgid "Secondary toolbar in Frontend"
msgstr "Другасная панэль інструментаў у Frontend"

