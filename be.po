msgstr ""
"Наладка %name залежыць ад модуля %owner, які "
"не будзе ўсталяваны пасля імпарту."

msgid ""
"Configuration %name depends on the %owner theme that will not be "
"installed after import."
msgstr ""
"Канфігурацыя %name залежыць ад тэмы %owner, "
"якая не будзе ўсталяваная пасля "
"імпарту."

msgid ""
"Configuration %name depends on the %owner extension that will not be "
