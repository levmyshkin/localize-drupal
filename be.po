msgstr ""
"Падпіс па змаўчанні для адлюстравання "
"ўсіх элементаў майстра"

msgid "Default wizard hide all elements label"
msgstr ""
"Па змаўчанні майстар хавае ўсе "
"элементы пазнакі"

msgid "@start of @end"
msgstr "@start of @end"

