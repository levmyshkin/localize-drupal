msgstr "Ці блок уключаны ці не."

msgid "Weight of the block for ordering within regions."
msgstr ""
"Вага блока для сартавання ў межах "
"рэгіёнаў."

msgid "Region the block is placed in."
msgstr "Рэгіён дзе блок размешчаны."

msgid "Visibility expression."
msgstr "Выраз бачнасці."

msgid "Pages list."
msgstr "Спіс старонак."

msgid "Cache rule."
msgstr "Правіла кэшавання."

