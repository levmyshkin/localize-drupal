msgid ""
"A unique machine-readable name for this @entity_type. It must only "
"contain lowercase letters, numbers, and underscores."
msgstr ""
"Унікальная назва, чытаемая машынай, "
"для гэтага @entity_type. Яна павінна "
"ўтрымліваць толькі літары ў ніжнім "
"рэгістры, лічбы і падкрэсліванні."

msgid "Entity Mask"
msgstr "Маска сутнасці"

