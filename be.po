msgstr ""
"Тэматычная гэта пераклад "
"апублікавана. Каб скасаваць яго "
"публікацыю, трэба апублікаваць яшчэ "
"хаця б адзін пераклад."

msgid "Time interval"
msgstr "Часавы інтэрвал"

msgid "Views plugins"
msgstr "Плагіны Views"

