msgstr "Εισήχθη @count of @total submissions..."

msgid ""
"Submission import completed. (total: @total; created: @created; "
"updated: @updated; skipped: @skipped)"
msgstr ""
"Ολοκληρώθηκε η εισαγωγή υποβολών. (total: "
"@total- created: @created- updated: @updated- skipped: @skipped)"

