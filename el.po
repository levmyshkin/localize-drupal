msgstr ""
"Χρησιμοποιήστε προσαρμοσμένες "
"ρυθμίσεις οθόνης για τις ακόλουθες "
"λειτουργίες @display_context"

msgid "Supported entity types"
msgstr "Υποστηριζόμενοι τύποι οντοτήτων"

