msgid ""
"You can find new features in the <a href=\"@url_colorbox_load\" "
"target=\"blank\">Colorbox Load</a> and <a "
"href=\"@url_colorbox_inline\" target=\"blank\">Colorbox Inline</a>"
msgstr ""
"Μπορείτε να βρείτε νέα χαρακτηριστικά "
"στα <a href=\"@url_colorbox_load\" target=\"blank\">Colorbox "
"Load</a> και <a href=\"@url_colorbox_inline\" "
"target=\"blank\">Colorbox Inline</a>."

