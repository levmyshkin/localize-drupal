msgstr ""
"Κατάργηση του @submission_total @submissions στο "
"@form_total @forms"

msgid "Scheduled email settings"
msgstr "Προγραμματισμένες ρυθμίσεις email"

msgid "Webform scheduled email settings"
msgstr "Ρυθμίσεις προγραμματισμένου email Webform"

