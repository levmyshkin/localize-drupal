msgid "Put this site into <a href=\":url\">maintenance mode</a>."
msgstr ""
"Θέστε αυτόν τον ιστότοπο σε <a "
"href=\":url\">λειτουργία συντήρησης</a>."

msgid "Source database"
msgstr "Πηγή βάσης δεδομένων"

msgid ""
