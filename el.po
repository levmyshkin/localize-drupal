msgstr "Αντιστοίχιση στυλ εικόνας"

msgid "Image style mapping"
msgstr "Χαρτογράφηση στυλ εικόνας"

msgid "Responsive image mapping type"
msgstr ""
"Ανταποκρινόμενος τύπος απεικόνισης "
"εικόνας"

msgid "Sizes attribute"
msgstr "Χαρακτηριστικό μέγεθος"

msgid "Image styles to be used when using the 'sizes' attribute"
msgstr ""
"Στυλ εικόνας που πρέπει να "
"χρησιμοποιείται όταν χρησιμοποιείται "
"το χαρακτηριστικό 'sizes'"

msgid "<em>Duplicate responsive image style</em> @label"
msgstr ""
"<em>Διπλό στυλ εικόνας που "
"ανταποκρίνεται</em> @label"

