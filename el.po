msgstr ""
"Δεν είναι δυνατή η αλλαγή του προφίλ "
"εγκατάστασης από %profile σε %new_profile αφού "
"εγκατασταθεί το Drupal."

msgid "Disclaimer block"
msgstr "Μπλοκ αποποίησης ευθύνης"

