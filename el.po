"Η διαδρομή του μενού ή η διεύθυνση URL "
"αυτής της προβολής"

msgid "No menu entry"
msgstr "Στο μενού εισόδου"

msgid "Normal menu entry"
msgstr "Κανονική είσοδος στο μενού"

msgid "Menu tab"
msgstr "Καρτέλα πλοήγηγης"

msgid "Default menu tab"
msgstr "Προεπιλεγμένο μενού καρτελών"

msgid "Default tab options"
msgstr "Προεπιλεγμένες επιλογές καρτέλας"

msgid "Already exists"
msgstr "Υπάρχει ήδη"

msgid "\"%\" may not be used for the first segment of a path."
msgstr ""
"Το \"%\" δεν μπορεί να χρησιμοποιηθεί "
"για το πρώτο τμήμα μιας διαδρομής."

msgid "A display whose path ends with a % cannot be a tab."
msgstr ""
"Μια οθόνη της οποίας η διαδρομή "
