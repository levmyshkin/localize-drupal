"'U.S. States'\n"
"  '#required': true\n"
"button:\n"
"  '#type': "
"'webform_options_custom:buttons'\n"
"  '#title': 'Buttons'\n"
"  "
"'#required': true\n"
"  '#options':\n"
"    one: One -- This is the number "
