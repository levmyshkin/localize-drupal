msgstr "επίπεδο(α)"

msgid "Default wizard/cards show all elements label"
msgstr ""
"Ο προεπιλεγμένος οδηγός/κάρτες "
"εμφανίζουν την ετικέτα όλων των "
"στοιχείων"

