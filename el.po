msgstr ""
"Έγινε έλεγχος διαθέσιμων στοιχείων "
"ενημέρωσης για το %title."

msgid "Failed to check available update data for %title."
msgstr ""
"Ο έλεγχος διαθέσιμων στοιχείων "
"ενημέρωσης για το %title απέτυχε."

