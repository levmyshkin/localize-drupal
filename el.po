msgstr "Απέτυχε η λήψη %project from %url"

msgid "Includes:"
msgstr "Περιλαμβάνει:"

msgid "Enabled: %includes"
msgstr "Ενεργοποιημένο: %includes"

msgid "Disabled: %disabled"
msgstr "Απενεργοποιημένη: %disabled"

