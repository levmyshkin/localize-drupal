msgstr "%vocabulary: Επεξεργασία όρων"

msgid "Output the URL as text"
msgstr "Εξαγωγή της διεύθυνσης URL ως κείμενο"

msgid "Output an absolute link"
msgstr "Εξαγωγή απόλυτου συνδέσμου"

msgid "Min placeholder"
msgstr "Min placeholder"

