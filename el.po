msgstr ""
"Εάν επιλεγεί, ένα κουμπί επαναφοράς θα "
"τοποθετηθεί πριν από το στοιχείο "
"αξιολόγησης."

msgid "Changing from %type"
msgstr "Αλλαγή από %type"

