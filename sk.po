msgid "How to Create Forms using Webform and Contact in Drupal 8"
msgstr "Ako vytvoriť formuláre pomocou Webform a Contact v Drupale 8"

msgid "WebWash"
msgstr "WebWash"

msgid ""
"Learn how to create forms using Webform and Contact module in Drupal "
"8."
msgstr ""
"Naučte sa, ako vytvárať formuláre pomocou modulov Webform a "
"Contact v Drupale 8."

msgid "Learn how to download and install the Webform module."
msgstr "Naučte sa, ako stiahnuť a nainštalovať modul Webform."

msgid "Using Webform in Drupal 8, 1.2: Create a Form"
msgstr "Použitie Webform v Drupale 8, 1.2: Vytvorenie formulára"

msgid ""
"Learn how to create a form from scratch and add three elements to it: "
"Name, Email and Telephone."
msgstr ""
"Naučte sa vytvoriť formulár od začiatku a pridať do neho tri "
"prvky: Meno, Email a Telefón."

msgid "Learn how to create conditional elements."
msgstr "Naučte sa, ako vytvárať podmienené prvky."

msgid "Using Webform in Drupal 8, 2.2: Create Multi-step Wizard"
msgstr ""
"Použitie Webform v Drupale 8, 2.2: Vytvorenie viacstupňového "
"sprievodcu"

msgid "Learn how to create a multi-step page form."
msgstr "Naučte sa, ako vytvoriť stránkový formulár s viacerými krokmi."

msgid "Using Webform in Drupal 8, 2.3: Float Elements Next to Each Other"
msgstr ""
"Použitie Webform v Drupale 8, 2.3: Zarovnanie prvkov float vedľa "
"seba"

msgid "Learn how to float elements next to each other on a form."
msgstr "Naučte sa, ako plávať prvky vedľa seba na formulári."

