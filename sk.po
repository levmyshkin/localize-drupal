"  '#multiple': true\n"
"  "
"'#multiple__header': true"

msgid "Example: Webform Element"
msgstr "Príklad: Webform Element"

msgid "An example of a custom Webform element."
msgstr "Príklad vlastného prvku Webform."

msgid "Example: Webform Handler"
msgstr "Príklad: Správca webformulára"

msgid "An example of a custom Webform handler."
msgstr "Príklad vlastného spracovateľa Webformu."

msgid "Example: Remote post"
msgstr "Príklad: Vzdialený príspevok"

msgid "An example of a webform submission posted to a remote server."
msgstr "Príklad odoslania webového formulára na vzdialený server."

msgid "Example: Computed"
msgstr "Príklad: Vypočítané"

msgid "Examples of a computed elements."
msgstr "Príklady vypočítaných prvkov."

msgid "Example: Computed Ajax"
msgstr "Príklad: Vypočítaný Ajax"

msgid "Example of a computed element using Ajax."
msgstr "Príklad vypočítaného prvku používajúceho Ajax."

msgid ""
"checkbox_example:\n"
"  '#type': details\n"
"  '#title': 'Checkbox "
"example'\n"
"  '#open': true\n"
"  checkbox:\n"
"    '#type': checkbox\n"
"    "
"'#title': 'Please check this box'\n"
"  checkbox_explain:\n"
"    '#type': "
"textarea\n"
"    '#title': 'Please explain why you checked the above "
"box'\n"
"    '#states':\n"
"      visible:\n"
"        "
"':input[name=\"checkbox\"]':\n"
"          checked: true\n"
"      "
"required:\n"
"        ':input[name=\"checkbox\"]':\n"
"          checked: "
"true\n"
"checkboxes_example:\n"
"  '#type': details\n"
"  '#title': "
"'Checkboxes example'\n"
"  '#open': true\n"
"  checkboxes:\n"
"    '#type': "
"checkboxes\n"
"    '#title': 'Please check all'\n"
"    '#options':\n"
"     "
" one: One\n"
"      two: Two\n"
"  checkboxes_explain:\n"
"    '#type': "
"textarea\n"
"    '#title': 'Please explain why you checked all the above "
