msgstr "správanie hoverIntent"

msgid "hoverIntent timeout"
msgstr "časový limit hoverIntent"

msgid "Hide Toolbar (Alt+p)"
msgstr "Skryť panel nástrojov (Alt+p)"

msgid "Toolbar sticky behavior"
msgstr "Nástrojový panel - lepkavé správanie"

msgid "Toolbar hoverIntent behavior"
msgstr "Správanie hoverIntent na paneli nástrojov"

