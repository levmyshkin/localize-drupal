"to start with a '/'."
msgstr ""
"<strong>@sitemap, riadok @line</strong>: Cesta <em>@path</em> musí "
"začínať znakom '/'."

msgid ""
"<strong>@sitemap, line @line</strong>: The priority setting "
"<em>@priority</em> for path <em>@path</em> is incorrect. Set the "
"priority from 0.0 to 1.0."
msgstr ""
"<strong>@sitemap, riadok @line</strong>: Nastavenie priority "
"<em>@priority</em> pre cestu <em>@path</em> je nesprávne. Nastavte "
"prioritu v rozmedzí od 0.0 do 1.0."

