msgstr "Dokumentový koreň pre verejné súbory"

msgid "Document root for private files"
msgstr "Dokumentový koreň pre súkromné súbory"

msgid "Enables the mobile menu toggle at all widths."
msgstr "Umožňuje prepínanie mobilného menu na všetkých šírkach."

