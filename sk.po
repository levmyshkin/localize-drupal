msgstr ""
"Určuje, či by mali byť nepoužité súbory odoslaní webového "
"formulára označené ako dočasné"

msgid "Immediately deleted temporary managed webform submission files"
msgstr ""
"Ihneď vymazané dočasné súbory spravovaných webformulárových "
"odoslaní"

msgid ""
"Existing submissions that have conditionally hidden elements will have "
"the element's submission data cleared when the submission is updated."
msgstr ""
"Existujúce odoslané údaje, ktoré obsahujú podmienečne skryté "
"prvky, budú mať dáta týchto prvkov vymazané pri aktualizácii "
"odoslania."

msgid ""
"The <strong>Access group</strong> page lists reusable groups used to "
"access webform source entity and users."
msgstr ""
"Stránka <strong>Prístupová skupina</strong> zobrazuje "
"znovupoužiteľné skupiny používané na prístup k zdrojovej entite "
"webového formulára a používateľom."

msgid ""
"The <strong>Access type</strong> page lists types of groups used to "
"send email notifications to users."
msgstr ""
"Stránka <strong>Typ prístupu</strong> obsahuje zoznam typov skupín "
"používaných na odosielanie e-mailových upozornení "
"používateľom."

msgid "Provides webform access controls for webform nodes."
msgstr "Poskytuje ovládanie prístupu k webformám pre uzly webform."

msgid "Prevent scheduling past actions"
msgstr "Zabrániť plánovaniu minulých akcií"

msgid "Ignore past:"
msgstr "Ignorovať minulosť:"

