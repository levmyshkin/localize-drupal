msgstr ""
"URL adresa obrázka, ktorý sa použije ako pozadie pre živú "
"dlaždicu."

msgid "MSApplication - Tooltip"
msgstr "MSApplication - Nápoveda"

msgid "Controls the text shown in the tooltip for the pinned site's shortcut."
msgstr "Riadi text zobrazený v nápovede pre skratku pripnutého webu."

msgid "MSApplication - Window"
msgstr "MSApplication - Okno"

