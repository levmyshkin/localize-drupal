msgstr "Je podanie webového formulára v návrhu."

msgid ""
"The 'items' can be 'comma', 'semicolon', 'and', 'ol', 'ul', or custom "
"delimiter"
msgstr ""
"'items' môžu byť 'čiarka', 'bodkočiarka', 'a', 'ol', 'ul' alebo "
"vlastný oddeľovač"

