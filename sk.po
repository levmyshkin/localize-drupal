msgstr "Vytvoriť odoslanie"

msgid "Enter 'name': 'value' pairs…"
msgstr "Zadajte páry 'name': 'value'…"

msgid ""
"You should consider using a dedicated Time element, instead of this "
"Date/time element, which will prepend the current date to the "
"submitted time."
msgstr ""
"Mali by ste zvážiť použitie špeciálneho prvku Čas namiesto "
"tohto prvku Dátum/čas, ktorý pred pridaním času automaticky "
"vloží aktuálny dátum."

msgid "Please select predefined options."
msgstr "Prosím, vyberte preddefinované možnosti."

msgid "@title visible"
msgstr "@title viditeľné"

msgid "@title title display"
msgstr "@title zobrazenie nadpisu"

msgid "Remove whitespace around the"
