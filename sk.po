"      "
"required:\n"
"        ':input[name=\"select\"]':\n"
"          value: "
"other\n"
"select_multiple_example:\n"
"  '#type': details\n"
"  '#title': "
"'Select multiple example'\n"
"  '#open': true\n"
"  select_multiple:\n"
"    "
