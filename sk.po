msgid "Enable form sharing"
msgstr "Povoliť zdieľanie formulára"

msgid "Enable form sharing for webform nodes"
msgstr "Povoliť zdieľanie formulárov pre uzly webform"

msgid "Shared form theme"
msgstr "Zdieľaná téma formulára"

msgid "Display shared form title"
msgstr "Zobraziť zdieľaný názov formulára"

