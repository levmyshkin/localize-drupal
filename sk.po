msgstr ""
"Modul Image CAPTCHA nemôže generovať obrázky, pretože vaše PHP "
"nastavenie to nepodporuje (chýba <a href=\"!gdlib\" "
"target=\"_blank\">GD knižnica</a> s podporou JPEG)."

msgid "Captcha Point form ID"
msgstr "Captcha Point form ID"

