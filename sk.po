msgstr ""
"Nedá sa zobraziť tento webový formulár. Prosím, kontaktujte "
"správcu stránky."

msgid "New submission added to [webform:title]."
msgstr "Nový príspevok pridaný do [webform:title]."

msgid "A registration webform template."
msgstr "Šablóna registračného webového formulára."

msgid "A session evaluation webform template."
msgstr "Šablóna webového formulára na vyhodnotenie relácie."

