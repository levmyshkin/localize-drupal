msgstr ""
"Táto správa sa zobrazí, keď nie sú nastavené žiadne limity "
"odoslaní."

msgid ""
"The message is displayed when an element has validation error is "
"submitted."
msgstr "Správa sa zobrazí, keď je odoslaný prvok s validačnou chybou."

