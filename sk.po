msgid ""
"Inline (Displays message when access is denied to field, nodes, and "
"blocks)"
msgstr ""
"Inline (Zobrazuje správu, keď je prístup k poľu, uzlom a blokom "
"odepretý)"

msgid ""
"Page (Displays message when access is denied to forms, fields, nodes, "
"and blocks)"
msgstr ""
"Stránka (Zobrazuje správu, keď je prístup k formulárom, poliam, "
"uzlom a blokom odmietnutý)"

msgid ""
"Login (Redirects to user login form and displays message. Field, "
"nodes, and block only display the message.)"
msgstr ""
"Prihlásenie (Presmeruje na prihlasovací formulár používateľa a "
"zobrazí správu. Pole, uzly a blok zobrazujú iba správu.)"

msgid ""
"When this container is hidden all this container's subelement values "
"will be cleared."
msgstr ""
"Keď je tento kontajner skrytý, všetky hodnoty podprvkov tohto "
"kontajnera budú vymazané."

msgid "When this element is hidden, this element's value will be cleared."
msgstr "Keď je tento prvok skrytý, jeho hodnota bude vymazaná."

msgid "Input hiding"
msgstr "Skrytie vstupu"

msgid "Hide the input of the element when the input is not being focused."
msgstr "Skryť vstup prvku, keď nie je vstup zaostrený."

msgid "Append the below suffixes to alter the returned value."
msgstr "Pripojte nižšie uvedené prípony na úpravu vrátenej hodnoty."

