msgstr ""
"Ak je začiarknuté, IP adresa používateľa nebude zaznamenávaná "
"pre všetky webové formuláre."

msgid "Webforms for Everyone"
msgstr "Webformuláre pre každého"

msgid ""
"This presentation explores how site owners, site builders, and "
"developers can leverage the Webform module for Drupal 8 to build "
"complex and robust forms for their end-users."
msgstr ""
"Táto prezentácia skúma, ako môžu majitelia stránok, tvorcovia "
"stránok a vývojári využiť modul Webform pre Drupal 8 na tvorbu "
"zložitých a stabilných formulárov pre svojich koncových "
"používateľov."

msgid "Broken/missing webform variant plugin."
msgstr "Chýbajúci alebo poškodený plugin variantu webového formulára."

msgid "<code>:htmldecode</code> decodes HTML entities in returned value."
msgstr "<code>:htmldecode</code> dekóduje HTML entity v navrátenej hodnote."

msgid "Hide the next button when auto-forwarding"
msgstr "Skryť tlačidlo „Ďalej“ pri automatickom presmerovaní"

msgid "Default delete button label"
msgstr "Predvolené označenie tlačidla odstrániť"

msgid ""
"Check if Webform Clientside Validation module is installed when using "
"the Clientside Validation module"
msgstr ""
"Skontrolujte, či je nainštalovaný modul Webform Clientside "
"Validation pri používaní modulu Clientside Validation"

msgid "Webform: Clientside validation"
msgstr "Webform: Validácia na strane klienta"

msgid "Webform Clientside Validation module installed."
msgstr "Modul Webform Clientside Validation nainštalovaný."

msgid "Webform Clientside Validation module not installed."
msgstr "Modul Webform Clientside Validation nie je nainštalovaný."

msgid ""
"The Webform Clientside Validation module helps support Webform "
"Clientside Validation integration. <a href=\":href\">Disable Webform "
"Clientside Validation warning</a>"
msgstr ""
"Modul Webform Clientside Validation pomáha podporovať integráciu "
"Webform Clientside Validation. <a href=\":href\">Vypnúť upozornenie "
"Webform Clientside Validation</a>"

msgid "Helps support Webform Clientside Validation integration."
msgstr "Pomáha podporovať integráciu Webform Clientside Validation."

