msgstr "Nie je možné spracovať aktuálnu požiadavku."

msgid "Do you want to reload the current page?"
msgstr "Chcete znovu načítať aktuálnu stránku?"

msgid "Provides a more slideout element."
msgstr "Poskytuje ďalší vysúvací prvok."

msgid "Custom error response redirect URL"
msgstr "Vlastná adresa URL pre presmerovanie odpovede na chybu"

msgid "The URL or path to redirect to when a remote fails."
msgstr ""
"URL alebo cesta, na ktorú sa má presmerovať v prípade zlyhania "
"vzdialeného pripojenia."

msgid "Error URL:"
msgstr "Chybná URL:"

