msgstr "<a href=\":href\">Vypnúť upozornenie CDN</a>"

msgid ""
"@total libraries (@installed installed; @excluded excluded; @missing "
"CDN)"
msgstr ""
"@total knižníc (@installed nainštalovaných; @excluded "
"vylúčených; @missing CDN)"

msgid "Drupal Association"
msgstr "Drupal asociácia"

msgid ""
"The below requirements are checked by the <a href=\":href\">Status "
"report</a>."
msgstr ""
"Nasledujúce požiadavky sú kontrolované v <a "
"href=\":href\">Prehľade stavu</a>."

msgid ""
"If unchecked, all warnings about Webform SPAM protection will be "
"disabled."
msgstr ""
"Ak nie je zaškrtnuté, všetky upozornenia o ochrane proti SPAMu vo "
"Webforme budú vypnuté."

msgid "Check that all entered values for this element are unique."
msgstr ""
"Skontrolujte, či sú všetky zadané hodnoty pre tento prvok "
"jedinečné."

msgid ""
"Check that entered values for this element is unique for the current "
