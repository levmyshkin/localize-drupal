msgid "The view mode that is used by default"
msgstr "Režim zobrazenia, ktorý sa používa predvolene"

msgid "Media types selectable in the Media Library"
msgstr "Typy médií voliteľné v Knižnici médií"

msgid "View modes selectable in the \"Edit media\" dialog"
msgstr ""
"Zobraziace režimy vyberateľné v dialógovom okne \"Upraviť "
