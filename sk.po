msgstr "Predvolený formát položiek"

msgid "Webform: Spam protection"
msgstr "Webform: Ochrana proti spamu"

msgid "Webform Spam protection module installed."
msgstr "Modul na ochranu proti spamu vo Webforme je nainštalovaný."

msgid ""
"Webform <a href=\":href\">Spam protection module</a> missing. Please "
