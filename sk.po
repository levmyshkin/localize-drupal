msgstr "Integrácia D8 Webform a Webform Views na Drupalcampe Colorado"

msgid "RateIt is used to provide a customizable rating element."
msgstr ""
"RateIt sa používa na poskytovanie prispôsobiteľného hodnotiaceho "
"prvku."

msgid "more submission views"
msgstr "viac zobrazení odoslaní"

