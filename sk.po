msgid "Sharing Webforms"
msgstr "Zdieľanie webových formulárov"

msgid ""
"This screencast walks through how to share a webform with any website, "
"webpage, or application."
msgstr ""
"Tento screencast ukazuje, ako zdieľať webový formulár s "
"ľubovoľnou webovou stránkou, podstránkou alebo aplikáciou."

msgid "Default wizard/cards start label"
msgstr "Predvolený štartovací popisovač sprievodcu/karty"

msgid "Default section/card title tag"
msgstr "Predvolený nadpis sekcie/karty"

msgid "Show wizard/cards progress bar"
msgstr "Zobraziť ukazovateľ priebehu sprievodcu/kartičiek"

msgid "Show wizard/cards progress pages"
msgstr "Zobraziť priebeh sprievodcu/kartičiek"

msgid "Show wizard/cards progress percentage"
msgstr "Zobraziť percentuálny postup sprievodcu/kariérok"

